---
/**
 * Category Page — Flat URL (English, Root Level)
 * Catches: /product/acetate-sunglasses  (no pagination suffix)
 * Pagination is handled by: /product/[category]/[...page].astro
 */

import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { translations } from '../../translations';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { isCategoryMatch } from '../../utils/categoryMatching';

const lang = 'en';
const t = translations[lang] || translations.en;

// Primary Categories (Hierarchical)
const primaryCategories = [
  {
    label: t.sidebar.sunglasses,
    href: '/product/sunglasses',
    items: [
      { label: t.sidebar.acetate_sunglasses, href: '/product/acetate-sunglasses' },
      { label: t.sidebar.metal_sunglasses, href: '/product/metal-sunglasses' },
      { label: t.sidebar.titanium_sunglasses, href: '/product/titanium-sunglasses' },
      { label: t.sidebar.carbon_fiber_sunglasses, href: '/product/carbon-fiber-sunglasses' },
      { label: t.sidebar.rimless_sunglasses, href: '/product/rimless-sunglasses' }
    ]
  },
  {
    label: t.sidebar.optical_frames,
    href: '/product/optical-frames',
    items: [
      { label: t.sidebar.acetate_glasses, href: '/product/acetate-optical-frames' },
      { label: t.sidebar.metal_glasses, href: '/product/metal-optical-frames' },
      { label: t.sidebar.titanium_glasses, href: '/product/titanium-optical-frames' },
      { label: t.sidebar.carbon_glasses, href: '/product/carbon-optical-frames' },
      { label: t.sidebar.rimless_glasses, href: '/product/rimless-optical-frames' }
    ]
  }
];

// Tags / Filters (Flat Groups)
const sidebarTags = [
  {
    label: t.sidebar.fashion_group || t.sidebar.fashion,
    href: '/product/fashion',
    items: [
      { label: t.sidebar.fashion_acetate_sunglasses, href: '/product/fashion-acetate-sunglasses' },
      { label: t.sidebar.fashion_metal_sunglasses, href: '/product/fashion-metal-sunglasses' },
      { label: t.sidebar.fashion_acetate_glasses, href: '/product/fashion-acetate-glasses' },
      { label: t.sidebar.fashion_metal_glasses, href: '/product/fashion-metal-glasses' }
    ]
  },
  {
    label: t.sidebar.luxury_group || t.sidebar.luxury,
    href: '/product/luxury',
    items: [
      { label: t.sidebar.luxury_acetate_sunglasses, href: '/product/luxury-acetate-sunglasses' },
      { label: t.sidebar.luxury_titanium_sunglasses, href: '/product/luxury-titanium-sunglasses' },
      { label: t.sidebar.luxury_acetate_glasses, href: '/product/luxury-acetate-glasses' },
      { label: t.sidebar.luxury_titanium_glasses, href: '/product/luxury-titanium-glasses' }
    ]
  },
  {
    label: t.sidebar.carbon_fiber_group || t.sidebar.carbon_fiber,
    href: '/product/carbon-fiber',
    items: [
      { label: t.sidebar.carbon_fiber_sunglasses, href: '/product/carbon-fiber-sunglasses' },
      { label: t.sidebar.carbon_glasses, href: '/product/carbon-glasses' }
    ]
  },
  {
    label: t.sidebar.rimless_group || t.sidebar.rimless,
    href: '/product/rimless',
    items: [
      { label: t.sidebar.rimless_sunglasses, href: '/product/rimless-sunglasses' },
      { label: t.sidebar.rimless_glasses, href: '/product/rimless-glasses' }
    ]
  }
];

export async function getStaticPaths() {
  const lang = 'en';

  // 10 core flat categories: material × product-type
  const CORE_CATEGORIES = [
    'acetate-sunglasses',
    'acetate-optical-frames',
    'metal-sunglasses',
    'metal-optical-frames',
    'titanium-sunglasses',
    'titanium-optical-frames',
    'carbon-fiber-sunglasses',
    'carbon-optical-frames',
    'rimless-sunglasses',
    'rimless-optical-frames',
  ];

  // Series/Tag categories (flat URLs for filter pages)
  const SERIES_CATEGORIES = [
    'fashion',
    'luxury',
    'rimless',
    'carbon-fiber',
    'carbon',
  ];

  const ALL_CATEGORIES = [...CORE_CATEGORIES, ...SERIES_CATEGORIES];

  // Sidebar categories (duplicated here so it's available inside getStaticPaths scope)
  const SIDEBAR = [
    { href: '/product/luxury-customized' },
    { href: '/product/luxury-sunglasses' },
    { href: '/product/luxury-optical-frames' },
    { href: '/product/high-couture-series' },
    { href: '/product/high-couture-sunglasses' },
    { href: '/product/high-couture-optical-frames' },
    { href: '/product/classics-series' },
    { href: '/product/classics-sunglasses' },
    { href: '/product/classics-optical-frames' },
    { href: '/product/fashion-series' },
    { href: '/product/acetate-sunglasses' },
    { href: '/product/metal-sunglasses' },
    { href: '/product/metal-optical-frames' },
    { href: '/product/titanium-sunglasses' },
    { href: '/product/titanium-optical-frames' },
    { href: '/product/rimless-series' },
    { href: '/product/rimless-sunglasses' },
    { href: '/product/rimless-optical-frames' },
    { href: '/product/carbon-series' },
    { href: '/product/carbon-fiber-sunglasses' },
    { href: '/product/carbon-optical-frames' },
    { href: '/product/fashion' },
    { href: '/product/luxury' },
    { href: '/product/rimless' },
    { href: '/product/carbon-fiber' },
    { href: '/product/carbon' },
  ];

  const allProducts = await getCollection('products');

  return ALL_CATEGORIES.map((category) => {
    // Check if this is a series category
    const isSeriesCategory = SERIES_CATEGORIES.includes(category);

    // Derive material + productType from slug (for core categories)
    const parts = category.split('-');
    const typePart = parts.pop() || '';
    const productType = typePart.charAt(0).toUpperCase() + typePart.slice(1);
    const materialRaw = parts.join('-');
    const material = materialRaw.charAt(0).toUpperCase() + materialRaw.slice(1);

    // Filter English products
    const categoryProducts = allProducts.filter((p) => {
      const pParts = p.id.split('.');
      const pLang = pParts.length > 1 ? pParts.pop() : 'en';
      if (pLang !== lang) return false;

      const cats = p.data.categories || '';

      // For series categories, match if category contains the series name
      if (isSeriesCategory) {
        const seriesVariants = [
          category,
          `${category}-series`,
          `${category}-sunglasses`,
          `${category}-glasses`,
          `${category}-frames`,
        ];
        return seriesVariants.some(variant => isCategoryMatch(cats, variant));
      }

      // For core categories, match material + productType
      if (!isCategoryMatch(cats, category)) return false;

      const pMaterial = p.data.material || '';
      const pProductType = p.data.productType || '';
      if (pMaterial && pProductType) {
        const matMatch = pMaterial.toLowerCase().replace(/-/g, ' ').includes(material.toLowerCase().replace(/-/g, ' '));
        const typeMatch = pProductType.toLowerCase() === productType.toLowerCase();
        if (!matMatch || !typeMatch) return false;
      }

      return true;
    });

    const sorted = categoryProducts.sort((a, b) => {
      if (a.data.featured && !b.data.featured) return -1;
      if (!a.data.featured && b.data.featured) return 1;
      const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
      const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
      if (dateA !== dateB) return dateB - dateA;
      return b.id.localeCompare(a.id);
    });

    // Pre-compute all sidebar counts
    const sidebarCounts: Record<string, number> = {};
    for (const item of SIDEBAR) {
      const slug = item.href.replace('/product/', '');
      sidebarCounts[item.href] = allProducts.filter((p) => {
        const pParts = p.id.split('.');
        return pParts.pop() === lang && isCategoryMatch(p.data.categories || '', slug);
      }).length;
    }

    return {
      params: { category },
      props: {
        categorySlug: category,
        material,
        productType,
        products: sorted,
        sidebarCounts,
      },
    };
  });
}

const { categorySlug, material, productType, products, sidebarCounts } = Astro.props;
const pt = t.product || {
  viewAllCollections: 'View All Collections',
  productsInCategory: 'products in this category',
};

// Display title from slug parts
const categoryTitle = `${material} ${productType}`;

// Total EN product count for "All Products" link
const TOTAL_EN_COUNT = (await getCollection('products')).filter((p) => {
  const parts = p.id.split('.');
  return parts.pop() === lang;
}).length;

function isActiveCategory(href: string): boolean {
  const pathWithoutQuery = href.split('?')[0];
  const hrefSlug = pathWithoutQuery.replace('/product/', '');
  return hrefSlug === categorySlug;
}
---

<Layout title={`${categoryTitle} - ${t.nav.products}`}>
  <Header />

  <main class="w-full min-h-screen py-6 lg:py-8 bg-stone-50">
    <div class="w-[94%] lg:w-[90%] 2xl:w-[85%] max-w-[1800px] mx-auto px-4">

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Sidebar -->
        <aside class="hidden lg:block lg:col-span-1">
          <div class="sticky top-24 space-y-6">
            <div class="bg-gradient-to-br from-white to-[#faf8f5] rounded-xl shadow-sm p-6 border border-stone-200/50">
              <!-- All Products -->
              <a
                href="/product"
                class="flex justify-between items-center py-2 px-3 rounded-lg mb-3 transition-colors text-gray-600 hover:bg-stone-50 hover:text-[#8B7355]"
              >
                <span class="font-medium">{t.sidebar.all_products}</span>
                <span class="text-xs px-2 py-1 rounded-full bg-gray-100">{TOTAL_EN_COUNT}</span>
              </a>

              <div class="space-y-3">
                {primaryCategories.map((cat) => (
                  <div class="border-b border-gray-100 pb-3 last:border-0 last:pb-0">
                    <a
                      href={cat.href}
                      class={`flex items-center justify-between py-2 px-2 text-sm font-bold rounded-lg transition-colors ${
                        isActiveCategory(cat.href)
                          ? 'bg-[#8B7355] text-white'
                          : 'text-[#8B7355] hover:bg-stone-50'
                      }`}
                    >
                      <span class="flex items-center gap-2">
                        {cat.label}
                        <span class={`text-xs font-normal px-2 py-0.5 rounded-full ${
                          isActiveCategory(cat.href) ? 'bg-white/20 text-white' : 'bg-gray-100 text-gray-500'
                        }`}>{sidebarCounts[cat.href] ?? 0}</span>
                      </span>
                      <svg class={`w-4 h-4 ${isActiveCategory(cat.href) ? 'text-white/70' : 'text-gray-400'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                    <ul class="ms-3 mt-1 space-y-1">
                      {cat.items.map((sub) => (
                        <li>
                          <a
                            href={sub.href}
                            class={`flex items-center justify-between py-1.5 px-2 text-sm rounded transition-colors ${
                              isActiveCategory(sub.href)
                                ? 'bg-[#8B7355] text-white'
                                : 'text-gray-600 hover:text-[#8B7355] hover:bg-stone-50'
                            }`}
                          >
                            <span>{sub.label}</span>
                            <span class={`text-xs ${
                              isActiveCategory(sub.href) ? 'text-white/80' : 'text-gray-400'
                            }`}>{sidebarCounts[sub.href] ?? 0}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>

              <!-- Tags & Filters -->
              <div class="mt-8 pt-6 border-t border-gray-100">
                <h4 class="text-xs font-bold text-gray-900 uppercase tracking-wider mb-4">{t.sidebar.tags_filters}</h4>
                <div class="space-y-6">
                  {sidebarTags.map((group) => (
                    <div>
                      <a href={group.href} class="text-sm font-bold text-gray-900 mb-2.5 flex items-center hover:text-[#8B7355] transition-colors">
                        <span class="text-[#8B7355] mr-1">#</span> {group.label}
                      </a>
                      <div class="flex flex-col gap-1.5">
                        {group.items.map((tag) => {
                          const isActive = isActiveCategory(tag.href);
                          return (
                            <a
                              href={tag.href}
                              class={`px-3 py-1.5 text-[11px] font-bold rounded-md border transition-all duration-200 w-full ${
                                isActive
                                  ? 'bg-[#8B7355] text-white border-[#8B7355] shadow-md'
                                  : 'bg-white text-stone-600 border-stone-200 hover:border-[#8B7355] hover:text-[#8B7355] hover:bg-stone-50'
                              }`}
                            >
                              {tag.label}
                            </a>
                          );
                        })}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>

            <!-- CTA Card -->
            <div class="bg-[#8B7355] rounded-xl p-6 text-white">
              <h4 class="font-bold mb-2">{pt.needCustomEyewear || 'Need Custom Eyewear?'}</h4>
              <p class="text-sm text-white/80 mb-4">
                {pt.oemServices || 'We offer full OEM & ODM services for your brand.'}
              </p>
              <a
                href="/quote"
                class="inline-block bg-white text-[#8B7355] px-4 py-2 rounded-lg text-sm font-semibold hover:bg-gray-100 transition-colors"
              >
                {t.cta.quote}
              </a>
            </div>
          </div>
        </aside>

        <!-- Product Grid -->
        <div class="col-span-1 lg:col-span-3">
          {products.length === 0 ? (
            <div class="text-center py-16 bg-white rounded-xl shadow-sm">
              <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
              <p class="text-gray-500 mb-4">No products in this category.</p>
              <a href="/product" class="text-[#8B7355] hover:underline">View All Products</a>
            </div>
          ) : (
            <>
              <div class="flex justify-between items-center mb-6 text-sm text-gray-500">
                <span>
                  Showing 1-{products.length} of {products.length} products
                </span>
              </div>

              <div class="grid grid-cols-2 xl:grid-cols-3 gap-4 xl:gap-6">
                {products.map((product: any) => (
                  <ProductCard product={product} lang={lang} />
                ))}
              </div>

              {products.length > 12 && (
                <nav class="mt-12 flex justify-center">
                  <a
                    href={`/product/${categorySlug}/2`}
                    class="flex items-center gap-2 px-6 py-3 bg-[#8B7355] text-white rounded-lg text-sm font-semibold hover:bg-[#5D4E37] transition-colors"
                  >
                    View More
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </nav>
              )}
            </>
          )}
        </div>
      </div>

      <!-- Back to All -->
      <div class="mt-12 text-center">
        <a
          href="/product"
          class="inline-flex items-center gap-2 text-[#8B7355] hover:text-[#5D4E37] font-medium transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          {pt.viewAllCollections}
        </a>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>

---
/**
 * Category Page (English - Root Level)
 * Displays products filtered by a specific category
 * URL format: /product/[category-slug] (e.g., /product/optical-frames)
 */

import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { translations } from '../../translations';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const lang = 'en'; // Fixed to English for root level

export async function getStaticPaths() {
  const lang = 'en'; // Define inside function for build-time access
  const allProducts = await getCollection('products');

  // Collect all unique categories from English products
  const allCategories = new Set<string>();
  allProducts.forEach(p => {
    // ID format: "kso-001.en" -> extract "en" by splitting on "."
    const parts = p.id.split('.');
    const productLang = parts.length > 1 ? parts.pop() : 'en';
    if (productLang === lang) {
      p.data.categories?.forEach(cat => {
        allCategories.add(cat.toLowerCase().replace(/\s+/g, '-'));
      });
    }
  });

  const paths = [];

  for (const category of allCategories) {
    // Find English products in this category
    const categoryProducts = allProducts.filter(p => {
      const parts = p.id.split('.');
      const pLang = parts.length > 1 ? parts.pop() : 'en';
      const hasCategory = p.data.categories?.some(
        c => c.toLowerCase().replace(/\s+/g, '-') === category
      );
      return pLang === lang && hasCategory;
    });

    // Only create page if there are products
    if (categoryProducts.length > 0) {
      paths.push({
        params: { category },
        props: { products: categoryProducts, categorySlug: category }
      });
    }
  }

  return paths;
}

const { products, categorySlug } = Astro.props;
const t = translations.en;
const currentPath = ''; // English is at root

// Format category name for display (convert slug back to title case)
const categoryTitle = categorySlug
  .split('-')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ');

// Get product translations
const pt = t.product || {
  viewAllCollections: "View All Collections",
  productsInCategory: "products in this category",
  allProducts: "All Products",
};

// Get all products for count
const allProducts = await getCollection('products');
const langProducts = allProducts.filter((product) => {
  const parts = product.id.split('.');
  const productLang = parts.length > 1 ? parts.pop() : 'en';
  return productLang === lang;
});

// Sidebar Categories - Matches Header Mega Menu Structure
const sidebarCategories = [
  {
    label: t.nav.luxury,
    href: '/product/luxury-customized',
    items: [
      { label: t.nav.luxury_sunglasses, href: '/product/luxury-sunglasses' },
      { label: t.nav.luxury_glasses, href: '/product/luxury-glasses' }
    ]
  },
  {
    label: t.nav.couture,
    href: '/product/high-couture-series',
    items: [
      { label: t.nav.couture_sunglasses, href: '/product/high-couture-sunglasses' },
      { label: t.nav.couture_glasses, href: '/product/high-couture-glasses' }
    ]
  },
  {
    label: t.nav.classics,
    href: '/product/classics-series',
    items: [
      { label: t.nav.classics_sunglasses, href: '/product/classics-sunglasses' },
      { label: t.nav.classics_glasses, href: '/product/classics-glasses' }
    ]
  },
  {
    label: t.nav.fashion,
    href: '/product/fashion-series',
    items: [
      { label: t.nav.acetate_sun, href: '/product/acetate-sunglasses' },
      { label: t.nav.metal_sun, href: '/product/metal-sunglasses' },
      { label: t.nav.metal_glass, href: '/product/metal-glasses' },
      { label: t.nav.titanium_sun, href: '/product/titanium-sunglasses' },
      { label: t.nav.titanium_glass, href: '/product/titanium-glasses' }
    ]
  },
  {
    label: t.nav.rimless,
    href: '/product/rimless-series',
    items: [
      { label: t.nav.rimless_sun, href: '/product/rimless-sunglasses' },
      { label: t.nav.rimless_glass, href: '/product/rimless-glasses' }
    ]
  },
  {
    label: t.nav.carbon,
    href: '/product/carbon-series',
    items: [
      { label: t.nav.carbon_sun, href: '/product/carbon-sunglasses' },
      { label: t.nav.carbon_glass, href: '/product/carbon-glasses' }
    ]
  }
];

// Sort products: featured first, then by date
const sortedProducts = products.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
  const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
  return dateB - dateA;
});

// Check if current category matches any in sidebar
function isActiveCategory(href: string): boolean {
  const hrefSlug = href.replace('/product/', '');
  return hrefSlug === categorySlug;
}
---

<Layout title={`${categoryTitle} - ${t.nav.products}`} lang={lang}>
  <Header lang={lang} />

  <main class="w-full min-h-screen py-12 lg:py-16 bg-gray-50">
    <div class="w-[94%] lg:w-[90%] 2xl:w-[85%] max-w-[1800px] mx-auto px-4">
      <!-- Breadcrumb -->
      <nav class="mb-8 text-sm">
        <ol class="flex items-center flex-wrap gap-1">
          <li>
            <a href="/" class="text-gray-500 hover:text-[#8B7355] transition-colors">
              {t.nav.home}
            </a>
          </li>
          <li class="text-gray-300 mx-2">/</li>
          <li>
            <a href="/product" class="text-gray-500 hover:text-[#8B7355] transition-colors">
              {t.nav.products}
            </a>
          </li>
          {sidebarCategories.map(cat => {
            const currentSub = cat.items.find(sub => isActiveCategory(sub.href));
            if (isActiveCategory(cat.href) || currentSub) {
              return (
                <>
                  <li class="text-gray-300 mx-2">/</li>
                  <li>
                    {currentSub ? (
                      <a href={cat.href} class="text-gray-500 hover:text-[#8B7355] transition-colors">
                        {cat.label}
                      </a>
                    ) : (
                      <span class="text-[#8B7355] font-medium">{cat.label}</span>
                    )}
                  </li>
                  {currentSub && (
                    <>
                      <li class="text-gray-300 mx-2">/</li>
                      <li class="text-[#8B7355] font-medium">
                        {currentSub.label}
                      </li>
                    </>
                  )}
                </>
              );
            }
            return null;
          })}
        </ol>
      </nav>

      <!-- Page Header -->
      <div class="mb-10">
        <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-2">
          {categoryTitle}
        </h1>
        <p class="text-gray-600">
          {sortedProducts.length} {pt.productsInCategory || 'products in this category'}
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Sidebar: Category Filter (Hidden on mobile/tablet) -->
        <aside class="hidden lg:block lg:col-span-1">
          <div class="sticky top-24 space-y-6">
            <!-- Categories Card -->
            <div class="bg-gradient-to-br from-white to-[#faf8f5] rounded-xl shadow-sm p-6 border border-stone-200/50">
              <!-- All Products Link -->
              <a
                href="/product"
                class={`flex justify-between items-center py-2 px-3 rounded-lg mb-3 transition-colors ${
                  categorySlug === ''
                    ? 'bg-[#8B7355] text-white'
                    : 'text-gray-600 hover:bg-stone-50 hover:text-[#8B7355]'
                }`}
              >
                <span class="font-medium">{pt.allProducts || 'All Products'}</span>
                <span class={`text-xs px-2 py-1 rounded-full ${
                  categorySlug === '' ? 'bg-white/20' : 'bg-gray-100'
                }`}>
                  {langProducts.length}
                </span>
              </a>

              <!-- Category Groups with Sub-categories -->
              <div class="space-y-3">
                {sidebarCategories.map((cat) => (
                  <div class="border-b border-gray-100 pb-3 last:border-0 last:pb-0">
                    <!-- Main Category -->
                    <a
                      href={cat.href}
                      class={`flex items-center justify-between py-2 px-2 text-sm font-bold rounded-lg transition-colors ${
                        isActiveCategory(cat.href)
                          ? 'bg-[#8B7355] text-white'
                          : 'text-[#8B7355] hover:bg-stone-50'
                      }`}
                    >
                      <span>{cat.label}</span>
                      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                    <!-- Sub-categories -->
                    <ul class="ms-3 mt-1 space-y-1">
                      {cat.items.map((sub) => (
                        <li>
                          <a
                            href={sub.href}
                            class={`block py-1.5 px-2 text-sm rounded transition-colors ${
                              isActiveCategory(sub.href)
                                ? 'bg-[#8B7355] text-white'
                                : 'text-gray-600 hover:text-[#8B7355] hover:bg-stone-50'
                            }`}
                          >
                            {sub.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </div>

            <!-- CTA Card - Always visible below categories -->
            <div class="bg-[#8B7355] rounded-xl p-6 text-white">
              <h4 class="font-bold mb-2">{pt.needCustomEyewear || 'Need Custom Eyewear?'}</h4>
              <p class="text-sm text-white/80 mb-4">
                {pt.oemServices || 'We offer full OEM & ODM services for your brand.'}
              </p>
              <a
                href="/quote"
                class="inline-block bg-white text-[#8B7355] px-4 py-2 rounded-lg text-sm font-semibold hover:bg-gray-100 transition-colors"
              >
                {t.cta.quote || 'Get Quote'}
              </a>
            </div>
          </div>
        </aside>

        <!-- Product Grid -->
        <div class="col-span-1 lg:col-span-3">
          {sortedProducts.length === 0 ? (
            <div class="text-center py-16 bg-white rounded-xl shadow-sm">
              <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
              <p class="text-gray-500 mb-4">No products in this category.</p>
              <a
                href="/product"
                class="text-[#8B7355] hover:underline"
              >
                View All Products
              </a>
            </div>
          ) : (
            <>
              <!-- Products Grid -->
              <div class="grid grid-cols-2 xl:grid-cols-3 gap-4 xl:gap-6">
                {sortedProducts.map((product) => (
                  <ProductCard product={product} lang={lang} />
                ))}
              </div>
            </>
          )}
        </div>
      </div>

      <!-- Back to All Products -->
      <div class="mt-12 text-center">
        <a
          href="/product"
          class="inline-flex items-center gap-2 text-[#8B7355] hover:text-[#5D4E37] font-medium transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          {pt.viewAllCollections}
        </a>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>

---
/**
 * Product Detail Page (English - Root Level)
 * Enhanced version with all sections matching yeetian.com reference
 */

import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../translations';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import TechnicalSpecs from '../../components/TechnicalSpecs.astro';
import InquiryForm from '../../components/InquiryForm.astro';
import RelatedProducts from '../../components/RelatedProducts.astro';

const lang = 'en'; // Fixed to English for root level

export async function getStaticPaths() {
  const lang = 'en';
  const products = await getCollection('products');

  return products
    .filter(product => {
      const parts = product.id.split('.');
      const productLang = parts.length > 1 ? parts.pop() : 'en';
      return productLang === lang;
    })
    .map(product => {
      const slug = product.data.slug || 'product';
      return {
        params: { slug },
        props: { product },
      };
    });
}

const { product } = Astro.props;
const { slug } = Astro.params;

const {
  title,
  cover,
  gallery,
  videoId,
  materials,
  moq,
  categories,
  itemNo,
  colors,
  serviceMode,
  specs,
  customizable,
  featured
} = product.data;

const { body: bodyHtml } = await render(product);

const t = translations.en;
const pt = t.product || {};

const breadcrumbItems = [
  { label: t.nav.home, href: '/' },
  { label: 'Product', href: '/product' },
  ...(categories && categories.length > 0
    ? [{
        label: categories[0],
        href: `/product/${categories[0].toLowerCase().replace(/\s+/g, '-')}`
      }]
    : []),
  ...(categories && categories.length > 1
    ? [{
        label: categories[1],
        href: `/product/${categories[1].toLowerCase().replace(/\s+/g, '-')}`
      }]
    : [])
];

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": title,
  "image": cover,
  "description": bodyHtml?.replace(/<[^>]*>/g, '').slice(0, 200),
  "brand": { "@type": "Brand", "name": "KSSMI Eyewear" },
  "manufacturer": {
    "@type": "ManufacturingBusiness",
    "name": "KSSMI Eyewear",
    "address": { "addressCountry": "CN" }
  }
};

let videoSchema = null;
if (videoId) {
  videoSchema = {
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": title,
    "description": bodyHtml?.replace(/<[^>]*>/g, '').slice(0, 200),
    "thumbnailUrl": [cover],
    "uploadDate": product.data.date || new Date().toISOString(),
    "contentUrl": `https://play.gumlet.io/embed/${videoId}`,
    "embedUrl": `https://play.gumlet.io/embed/${videoId}`
  };
}
---

<Layout title={title} lang={lang} image={cover}>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  {videoSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(videoSchema)} />
  )}

  {/* Pagefind metadata for better search indexing */}
  <div class="sr-only" data-pagefind-meta="title">{title}</div>
  {itemNo && <div class="sr-only" data-pagefind-meta="itemNo">{itemNo}</div>}
  {itemNo && <div class="sr-only" data-pagefind-weight="10">{itemNo}</div>}
  {materials && materials.length > 0 && <div class="sr-only" data-pagefind-meta="materials">{materials.join(', ')}</div>}
  {colors && colors.length > 0 && <div class="sr-only" data-pagefind-meta="colors">{colors.join(', ')}</div>}
  {categories && categories.length > 0 && <div class="sr-only" data-pagefind-meta="category">{categories.join(', ')}</div>}
  {cover && <img src={cover} alt={title} data-pagefind-meta="image" class="sr-only" />}

  <Header lang={lang} />

  <main data-pagefind-body>
    {/* Pagefind anchor for better excerpt */}
    <div id="pagefind-content" class="contents">
    <!-- SECTION 1: Breadcrumb Navigation -->
    <Breadcrumb items={breadcrumbItems} lang={lang} />

    <!-- SECTION 2: Product Hero -->
    <section class="py-12 lg:py-16 bg-white">
      <div class="w-[94%] lg:w-[90%] 2xl:w-[85%] max-w-[1800px] mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">

          <!-- Image Gallery Column - Centered -->
          <div class="space-y-4 flex flex-col items-center">
            <!-- Main Image with Magnifier Zoom Effect -->
            <div class="relative aspect-square bg-gray-50 rounded-xl overflow-hidden shadow-lg w-full max-w-[500px]">
              {cover ? (
                <div
                  id="image-zoom-container"
                  class="w-full h-full cursor-zoom-in"
                >
                  <img
                    id="main-image"
                    src={cover}
                    alt={title}
                    class="w-full h-full object-cover"
                    decoding="async"
                  />
                </div>
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <svg class="w-24 h-24 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              )}

              <!-- Badge - Customizable -->
              {customizable && (
                <div class="absolute top-4 start-4 z-10">
                  <span class="bg-[#8B7355] text-white text-xs font-semibold px-3 py-1 rounded-full shadow-md">
                    Customizable
                  </span>
                </div>
              )}
            </div>

            <!-- Gallery Thumbnails - Centered -->
            <div class="flex justify-center gap-2">
              {cover && (
                <button
                  class="thumb aspect-square w-16 h-16 rounded-lg overflow-hidden border-2 border-[#8B7355] shadow-sm hover:shadow-md transition-shadow"
                  aria-label="View main image"
                >
                  <img src={cover} alt="Main" class="w-full h-full object-cover" decoding="async" />
                </button>
              )}
              {gallery?.map((img, index) => (
                <button
                  class="thumb aspect-square w-16 h-16 rounded-lg overflow-hidden border-2 border-transparent hover:border-[#8B7355] shadow-sm hover:shadow-md transition-all"
                  aria-label={`View gallery image ${index + 1}`}
                >
                  <img src={img} alt={`Gallery ${index + 1}`} class="w-full h-full object-cover" decoding="async" />
                </button>
              ))}
            </div>

            <!-- Video Embed (if available) -->
            {videoId && (
              <div class="aspect-video bg-gray-900 rounded-xl overflow-hidden shadow-lg w-full max-w-[500px]">
                <iframe
                  src={`https://play.gumlet.io/embed/${videoId}`}
                  title={`${title} - Product Video`}
                  class="w-full h-full"
                  allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture"
                  allowfullscreen
                ></iframe>
              </div>
            )}
          </div>

          <!-- Product Info Column -->
          <div class="lg:py-4">
            <!-- Collection Label -->
            {categories && categories.length > 0 && (
              <p class="text-sm text-[#8B7355] font-medium uppercase tracking-wider mb-2">
                - KSSMI Collection
              </p>
            )}

            <!-- Product Title - Smaller (2/3 size) -->
            <h1 class="text-2xl lg:text-3xl font-bold mb-6 text-gray-900">
              {title}
            </h1>

            <!-- Quick Specs - Left Aligned -->
            <div class="border-y border-gray-200 py-6 mb-6 space-y-3">
              {itemNo && (
                <div class="flex items-center gap-2">
                  <span class="text-sm text-gray-500 min-w-[120px]">{pt.itemNo || 'Item No'}:</span>
                  <span class="text-sm font-medium text-gray-900">{itemNo}</span>
                </div>
              )}

              {colors && colors.length > 0 && (
                <div class="flex items-center gap-2">
                  <span class="text-sm text-gray-500 min-w-[120px]">{pt.color || 'Color'}:</span>
                  <span class="text-sm font-medium text-gray-900">{colors.join(' & ')}</span>
                </div>
              )}

              {materials && materials.length > 0 && (
                <div class="flex items-center gap-2">
                  <span class="text-sm text-gray-500 min-w-[120px]">{pt.materials || 'Materials'}:</span>
                  <span class="text-sm font-medium text-gray-900">{materials.join(', ')}</span>
                </div>
              )}

              <div class="flex items-center gap-2">
                <span class="text-sm text-gray-500 min-w-[120px]">{pt.serviceMode || 'Service Mode'}:</span>
                <span class="text-sm font-medium text-gray-900">
                  {(serviceMode || ['OEM', 'ODM']).join(' & ')}
                </span>
              </div>

              <div class="flex items-center gap-2">
                <span class="text-sm text-gray-500 min-w-[120px]">{pt.moq || 'MOQ'}:</span>
                <span class="text-sm font-medium text-gray-900">{moq || 100} PCS/Model</span>
              </div>
            </div>

            <!-- Product Description -->
            {bodyHtml && (
              <div class="prose prose-stone max-w-none text-gray-700 mb-8 prose-headings:text-gray-900">
                <Fragment set:html={bodyHtml} />
              </div>
            )}

            <!-- CTA Buttons -->
            <div class="flex flex-wrap gap-4 mb-8">
              <a
                href="/quote"
                class="flex-1 min-w-[200px] bg-[#8B7355] text-white px-6 py-4 rounded-lg font-semibold
                       hover:bg-[#5D4E37] active:bg-[#4a4030] transition-colors duration-200
                       text-center flex items-center justify-center gap-2"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                {t.cta.quote}
              </a>
              <a
                href="/product"
                class="flex-1 min-w-[200px] border-2 border-[#8B7355] text-[#8B7355] px-6 py-4 rounded-lg font-semibold
                       hover:bg-[#8B7355] hover:text-white transition-colors duration-200
                       text-center flex items-center justify-center gap-2"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                {pt.backToCatalog || 'Back to Catalog'}
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 3: Technical Specifications -->
    <TechnicalSpecs specs={specs} product={product} lang={lang} />

    <!-- SECTION 4: CTA Banner -->
    <section class="py-16 lg:py-20 bg-gradient-to-r from-[#8B7355] to-[#5D4E37] text-white">
      <div class="w-[94%] lg:w-[90%] 2xl:w-[85%] max-w-[1800px] mx-auto px-4">
        <div class="text-center mb-10">
          <h2 class="text-2xl lg:text-3xl font-bold mb-4">
            Partner to Build Your Private-Label Luxury Eyewear Brand
          </h2>
          <p class="text-lg text-white/90 max-w-3xl mx-auto">
            Collaborate with a manufacturer trusted by industry leaders for over a century. Fully customize every aspect—materials, shapes, colors, and technical specifications—delivering exceptional craftsmanship and premium quality at scale.
          </p>
        </div>

        <!-- Benefits Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          <div class="flex items-start gap-3 bg-white/10 backdrop-blur-sm rounded-lg p-4 transition-all duration-300 hover:-translate-y-1 hover:bg-white/20 hover:shadow-lg hover:shadow-black/20 cursor-default group">
            <svg class="w-5 h-5 mt-0.5 text-amber-300 shrink-0 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm text-white/95">Decades of expertise in luxury eyewear manufacturing.</span>
          </div>
          <div class="flex items-start gap-3 bg-white/10 backdrop-blur-sm rounded-lg p-4 transition-all duration-300 hover:-translate-y-1 hover:bg-white/20 hover:shadow-lg hover:shadow-black/20 cursor-default group">
            <svg class="w-5 h-5 mt-0.5 text-amber-300 shrink-0 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm text-white/95">Precision customization of materials, design, and technical specs.</span>
          </div>
          <div class="flex items-start gap-3 bg-white/10 backdrop-blur-sm rounded-lg p-4 transition-all duration-300 hover:-translate-y-1 hover:bg-white/20 hover:shadow-lg hover:shadow-black/20 cursor-default group">
            <svg class="w-5 h-5 mt-0.5 text-amber-300 shrink-0 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm text-white/95">Exceptional quality control ensuring flawless finishes.</span>
          </div>
          <div class="flex items-start gap-3 bg-white/10 backdrop-blur-sm rounded-lg p-4 transition-all duration-300 hover:-translate-y-1 hover:bg-white/20 hover:shadow-lg hover:shadow-black/20 cursor-default group">
            <svg class="w-5 h-5 mt-0.5 text-amber-300 shrink-0 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm text-white/95">Advanced scalable production with consistent accuracy.</span>
          </div>
          <div class="flex items-start gap-3 bg-white/10 backdrop-blur-sm rounded-lg p-4 transition-all duration-300 hover:-translate-y-1 hover:bg-white/20 hover:shadow-lg hover:shadow-black/20 cursor-default group">
            <svg class="w-5 h-5 mt-0.5 text-amber-300 shrink-0 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm text-white/95">Cutting-edge materials compliant with industry standards.</span>
          </div>
          <div class="flex items-start gap-3 bg-white/10 backdrop-blur-sm rounded-lg p-4 transition-all duration-300 hover:-translate-y-1 hover:bg-white/20 hover:shadow-lg hover:shadow-black/20 cursor-default group">
            <svg class="w-5 h-5 mt-0.5 text-amber-300 shrink-0 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm text-white/95">Reliable delivery aligned with your production timelines.</span>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 5: Inquiry Form -->
    <InquiryForm lang={lang} productName={title} />

    <!-- SECTION 6: Related Products -->
    <RelatedProducts
      category={categories?.[0]}
      currentProductId={product.id}
      lang={lang}
      limit={4}
    />
    </div>{/* End data-pagefind-body */}
  </main>

  <Footer lang={lang} />
</Layout>

<script>
  function initGallery() {
    const mainImage = document.getElementById('main-image') as HTMLImageElement;
    const zoomContainer = document.getElementById('image-zoom-container');

    if (!mainImage) return;

    // Use event delegation for thumbnail clicks - attach to parent container
    const thumbsParent = document.querySelector('.space-y-4.flex.flex-col.items-center');
    if (thumbsParent) {
      thumbsParent.addEventListener('click', (e: Event) => {
        const target = e.target as HTMLElement;
        const thumb = target.closest('.thumb') as HTMLElement;

        if (thumb) {
          const thumbImg = thumb.querySelector('img') as HTMLImageElement;
          if (thumbImg && mainImage) {
            mainImage.src = thumbImg.src;
            mainImage.srcset = thumbImg.srcset || '';
            mainImage.sizes = thumbImg.sizes || '';
            mainImage.style.transform = 'scale(1)';

            // Update active state
            document.querySelectorAll('.thumb').forEach(t => {
              t.classList.remove('border-[#8B7355]');
              t.classList.add('border-transparent');
            });
            thumb.classList.remove('border-transparent');
            thumb.classList.add('border-[#8B7355]');
          }
        }
      });
    }

    // Magnifier zoom effect
    if (zoomContainer) {
      zoomContainer.addEventListener('mouseenter', () => {
        mainImage.style.transform = 'scale(2)';
        mainImage.style.transition = 'transform 0.1s ease-out';
        mainImage.style.transformOrigin = 'center center';
      });

      zoomContainer.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = zoomContainer.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        mainImage.style.transformOrigin = `${x}% ${y}%`;
      });

      zoomContainer.addEventListener('mouseleave', () => {
        mainImage.style.transform = 'scale(1)';
      });
    }
  }

  // Run on initial load
  initGallery();

  // Run after View Transitions navigation
  document.addEventListener('astro:page-load', initGallery);
</script>

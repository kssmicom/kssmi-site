---
/**
 * Product Index Pagination Pages (English - Root Level)
 * Catches: /product/2, /product/3, etc.
 */

import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { translations } from '../../translations';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { isCategoryMatch } from '../../utils/categoryMatching';

const lang = 'en';
const PAGE_SIZE = 12;

const allProducts = await getCollection('products');

const langProducts = allProducts.filter((product) => {
  const parts = product.id.split('.');
  const productLang = parts.length > 1 ? parts.pop() : 'en';
  return productLang === lang;
});

const sortedProducts = langProducts.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  const dateA = (a.data as any).date ? new Date((a.data as any).date).getTime() : 0;
  const dateB = (b.data as any).date ? new Date((b.data as any).date).getTime() : 0;
  if (dateA !== dateB) return dateB - dateA;
  return b.id.localeCompare(a.id);
});

const totalPages = Math.ceil(sortedProducts.length / PAGE_SIZE);

export async function getStaticPaths() {
  const PAGE_SIZE = 12;
  const lang = 'en';
  const all = await getCollection('products');
  const en = all.filter((p) => {
    const parts = p.id.split('.');
    return parts.pop() === 'en';
  });
  const sorted = en.sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
    const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
    if (dateA !== dateB) return dateB - dateA;
    return b.id.localeCompare(a.id);
  });
  const total = Math.ceil(sorted.length / PAGE_SIZE);
  return Array.from({ length: total }, (_, i) => ({
    params: { page: String(i + 2) },
  }));
}

const { page } = Astro.params;
const pageNum = parseInt(page, 10);

if (pageNum < 2 || pageNum > totalPages) {
  return Astro.redirect('/product');
}

const start = (pageNum - 1) * PAGE_SIZE;
const end = start + PAGE_SIZE;
const products = sortedProducts.slice(start, end);

const t = translations.en;
const pt = t.product || {
  viewAllCollections: "View All Collections",
};

// Primary Categories (Hierarchical)
const primaryCategories = [
  {
    label: t.sidebar.sunglasses,
    href: '/product/sunglasses',
    items: [
      { label: t.sidebar.acetate_sunglasses, href: '/product/acetate-sunglasses' },
      { label: t.sidebar.metal_sunglasses, href: '/product/metal-sunglasses' },
      { label: t.sidebar.titanium_sunglasses, href: '/product/titanium-sunglasses' },
      { label: t.sidebar.carbon_fiber_sunglasses, href: '/product/carbon-fiber-sunglasses' },
      { label: t.sidebar.rimless_sunglasses, href: '/product/rimless-sunglasses' }
    ]
  },
  {
    label: t.sidebar.optical_frames,
    href: '/product/optical-frames',
    items: [
      { label: t.sidebar.acetate_glasses, href: '/product/acetate-optical-frames' },
      { label: t.sidebar.metal_glasses, href: '/product/metal-optical-frames' },
      { label: t.sidebar.titanium_glasses, href: '/product/titanium-optical-frames' },
      { label: t.sidebar.carbon_glasses, href: '/product/carbon-fiber-optical-frames' },
      { label: t.sidebar.rimless_glasses, href: '/product/rimless-optical-frames' }
    ]
  }
];

const sidebarTags = [
  {
    label: t.sidebar.fashion,
    href: '/product/fashion-eyewear',
    items: [
      { label: t.sidebar.fashion_acetate_sunglasses, href: '/product/fashion-acetate-sunglasses' },
      { label: t.sidebar.fashion_metal_sunglasses, href: '/product/fashion-metal-sunglasses' },
      { label: t.sidebar.fashion_acetate_glasses, href: '/product/fashion-acetate-optical-frames' },
      { label: t.sidebar.fashion_metal_glasses, href: '/product/fashion-metal-optical-frames' }
    ]
  },
  {
    label: t.sidebar.luxury,
    href: '/product/luxury-eyewear',
    items: [
      { label: t.sidebar.luxury_acetate_sunglasses, href: '/product/luxury-acetate-sunglasses' },
      { label: t.sidebar.luxury_titanium_sunglasses, href: '/product/luxury-titanium-sunglasses' },
      { label: t.sidebar.luxury_acetate_glasses, href: '/product/luxury-acetate-optical-frames' },
      { label: t.sidebar.luxury_titanium_glasses, href: '/product/luxury-titanium-optical-frames' }
    ]
  },
  {
    label: t.sidebar.carbon_fiber,
    href: '/product/carbon-fiber-eyewear',
    items: [
      { label: t.sidebar.carbon_fiber_sunglasses, href: '/product/carbon-fiber-sunglasses' },
      { label: t.sidebar.carbon_glasses, href: '/product/carbon-fiber-optical-frames' }
    ]
  },
  {
    label: t.sidebar.rimless,
    href: '/product/rimless-eyewear',
    items: [
      { label: t.sidebar.rimless_sunglasses, href: '/product/rimless-sunglasses' },
      { label: t.sidebar.rimless_glasses, href: '/product/rimless-optical-frames' }
    ]
  }
];

function getCategoryCount(href: string): number {
  const targetSlug = href.split('/').pop() || '';
  return langProducts.filter(p => {
    const cats = p.data.series || '';
    return isCategoryMatch(cats, targetSlug);
  }).length;
}
---

<Layout title={`${t.nav.products} - Page ${pageNum}`} lang={lang}>
  <Header lang={lang} />

  <main class="w-full min-h-screen py-6 lg:py-8 bg-stone-50">
    <div class="w-[94%] lg:w-[90%] 2xl:w-[85%] max-w-[1800px] mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Sidebar -->
        <aside class="hidden lg:block lg:col-span-1">
          <div class="sticky top-24 space-y-6">
            <div class="bg-gradient-to-br from-white to-[#faf8f5] rounded-xl shadow-sm p-6 border border-stone-200/50">
              <div class="flex items-center mb-3">
                <a href="/product" class="flex-1 text-base lg:text-lg font-bold text-[#8B7355] hover:underline">
                  {t.sidebar.all_products}
                </a>
                <span class="text-xs font-normal text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full">
                  {langProducts.length}
                </span>
              </div>

              <div class="space-y-3">
                {primaryCategories.map((cat) => (
                  <div class="border-b border-gray-100 pb-3 last:border-0 last:pb-0">
                    <a
                      href={cat.href}
                      class="flex items-center justify-between py-2 px-2 text-sm font-bold text-[#8B7355] hover:bg-stone-50 rounded-lg transition-colors"
                    >
                      <span class="flex items-center gap-2">
                        {cat.label}
                        <span class="text-xs font-normal text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full">{getCategoryCount(cat.href)}</span>
                      </span>
                      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                    <ul class="ml-3 mt-1 space-y-1">
                      {cat.items.map((sub) => (
                        <li>
                          <a
                            href={sub.href}
                            class="flex items-center justify-between py-1.5 px-2 text-sm text-gray-600 hover:text-[#8B7355] hover:bg-stone-50 rounded transition-colors"
                          >
                            <span>{sub.label}</span>
                            <span class="text-xs text-gray-400">{getCategoryCount(sub.href)}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>

              <div class="mt-8 pt-6 border-t border-gray-100">
                <h4 class="text-xs font-bold text-gray-900 uppercase tracking-wider mb-4">{t.sidebar.tags_filters}</h4>
                <div class="space-y-6">
                  {sidebarTags.map((group) => (
                    <div>
                      <a href={group.href} class="text-sm font-bold text-gray-900 mb-2.5 flex items-center hover:text-[#8B7355] transition-colors">
                        <span class="text-[#8B7355] mr-1">#</span> {group.label}
                      </a>
                      <div class="flex flex-col gap-1.5">
                        {group.items.map((tag) => (
                          <a
                            href={tag.href}
                            class="px-3 py-1.5 text-[11px] font-bold rounded-md border bg-stone-50 text-stone-600 border-stone-200 hover:border-[#8B7355] hover:text-[#8B7355] hover:bg-stone-100 transition-all duration-200 w-full"
                          >
                            {tag.label}
                          </a>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>

            <div class="bg-[#8B7355] rounded-xl p-6 text-white">
              <h4 class="font-bold mb-2">{pt.needCustomEyewear || 'Need Custom Eyewear?'}</h4>
              <p class="text-sm text-white/80 mb-4">
                {pt.oemServices || 'We offer full OEM & ODM services for your brand.'}
              </p>
              <a
                href="/quote"
                class="inline-block bg-white text-[#8B7355] px-4 py-2 rounded-lg text-sm font-semibold hover:bg-gray-100 transition-colors"
              >
                {t.cta.quote || 'Get Quote'}
              </a>
            </div>
          </div>
        </aside>

        <!-- Product Grid -->
        <div class="col-span-1 lg:col-span-3">
          {products.length === 0 ? (
            <div class="text-center py-16 bg-white rounded-xl shadow-sm">
              <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
              <p class="text-gray-500 mb-4">{pt.noProducts || 'No products available yet.'}</p>
              <a href="/" class="text-[#8B7355] hover:underline">
                {pt.returnHome || 'Return to Homepage'}
              </a>
            </div>
          ) : (
            <>
              <div class="flex justify-between items-center mb-6 text-sm text-gray-500">
                <span>
                  Showing {start + 1}-{Math.min(end, langProducts.length)} of {langProducts.length} products
                </span>
              </div>

              <div class="grid grid-cols-2 xl:grid-cols-3 gap-4 xl:gap-6">
                {products.map((product) => (
                  <ProductCard product={product} lang={lang} />
                ))}
              </div>

              <!-- Pagination -->
              <nav class="mt-12 flex justify-center items-center gap-2" dir="ltr">
                <!-- Previous Button -->
                {pageNum > 2 ? (
                  <a
                    href={`/product/${pageNum - 1}`}
                    class="flex items-center gap-1 px-4 py-2 border border-gray-200 rounded-lg text-gray-600 hover:bg-gray-50 hover:border-[#8B7355] hover:text-[#8B7355] transition-colors"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                    <span class="hidden sm:inline">{pt.previousPage || 'Previous'}</span>
                  </a>
                ) : pageNum === 2 ? (
                  <a
                    href="/product"
                    class="flex items-center gap-1 px-4 py-2 border border-gray-200 rounded-lg text-gray-600 hover:bg-gray-50 hover:border-[#8B7355] hover:text-[#8B7355] transition-colors"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                    <span class="hidden sm:inline">{pt.previousPage || 'Previous'}</span>
                  </a>
                ) : (
                  <span class="flex items-center gap-1 px-4 py-2 border border-gray-100 rounded-lg text-gray-300 cursor-not-allowed">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                    <span class="hidden sm:inline">{pt.previousPage || 'Previous'}</span>
                  </span>
                )}

                <!-- Page Numbers -->
                <div class="flex items-center gap-1">
                  <a
                    href="/product"
                    class="w-10 h-10 flex items-center justify-center rounded-lg text-sm font-medium border border-gray-200 text-gray-600 hover:bg-gray-50 hover:border-[#8B7355] hover:text-[#8B7355] transition-colors"
                  >
                    1
                  </a>

                  {pageNum > 3 && <span class="px-2 text-gray-400">...</span>}

                  {pageNum > 2 && (
                    <a
                      href={`/product/${pageNum - 1}`}
                      class="w-10 h-10 flex items-center justify-center rounded-lg text-sm font-medium border border-gray-200 text-gray-600 hover:bg-gray-50 hover:border-[#8B7355] hover:text-[#8B7355] transition-colors"
                    >
                      {pageNum - 1}
                    </a>
                  )}

                  <span class="w-10 h-10 flex items-center justify-center rounded-lg text-sm font-medium bg-[#8B7355] text-white">
                    {pageNum}
                  </span>

                  {pageNum < totalPages && pageNum + 1 < totalPages && (
                    <a
                      href={`/product/${pageNum + 1}`}
                      class="w-10 h-10 flex items-center justify-center rounded-lg text-sm font-medium border border-gray-200 text-gray-600 hover:bg-gray-50 hover:border-[#8B7355] hover:text-[#8B7355] transition-colors"
                    >
                      {pageNum + 1}
                    </a>
                  )}

                  {pageNum < totalPages - 2 && <span class="px-2 text-gray-400">...</span>}

                  {pageNum < totalPages && (
                    <a
                      href={`/product/${totalPages}`}
                      class="w-10 h-10 flex items-center justify-center rounded-lg text-sm font-medium border border-gray-200 text-gray-600 hover:bg-gray-50 hover:border-[#8B7355] hover:text-[#8B7355] transition-colors"
                    >
                      {totalPages}
                    </a>
                  )}
                </div>

                <!-- Next Button -->
                {pageNum < totalPages ? (
                  <a
                    href={`/product/${pageNum + 1}`}
                    class="flex items-center gap-1 px-4 py-2 border border-gray-200 rounded-lg text-gray-600 hover:bg-gray-50 hover:border-[#8B7355] hover:text-[#8B7355] transition-colors"
                  >
                    <span class="hidden sm:inline">{pt.nextPage || 'Next'}</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                ) : (
                  <span class="flex items-center gap-1 px-4 py-2 border border-gray-100 rounded-lg text-gray-300 cursor-not-allowed">
                    <span class="hidden sm:inline">{pt.nextPage || 'Next'}</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </span>
                )}
              </nav>
            </>
          )}
        </div>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>

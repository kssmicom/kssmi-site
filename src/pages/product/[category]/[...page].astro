---
/**
 * Category Page with Pagination — Flat URL (English, Root Level)
 * Catches: /product/acetate-sunglasses and /product/acetate-sunglasses/2
 */

import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import ProductCard from '../../../components/ProductCard.astro';
import { translations } from '../../../translations';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { isCategoryMatch } from '../../../utils/categoryMatching';
import type { Page } from 'astro';

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const lang = 'en';

  const CANONICAL_CATEGORIES = [
    'acetate-sunglasses',
    'acetate-glasses',
    'acetate-optical-frames', // For backward compatibility
    'metal-sunglasses',
    'metal-glasses',
    'metal-optical-frames',
    'titanium-sunglasses',
    'titanium-glasses',
    'titanium-optical-frames',
    'carbon-sunglasses',
    'carbon-fiber-sunglasses',
    'carbon-glasses',
    'carbon-optical-frames',
    'carbon-fiber-optical-frames',
    'rimless-sunglasses',
    'rimless-glasses',
    'rimless-optical-frames',
    'sunglasses',
    'optical-frames',
    'luxury-customized',
    'luxury-glasses',
    'luxury-sunglasses',
    'luxury-acetate-sunglasses',
    'luxury-titanium-sunglasses',
    'luxury-acetate-optical-frames',
    'luxury-titanium-optical-frames',
    'high-couture-series',
    'high-couture-sunglasses',
    'high-couture-glasses',
    'classics-series',
    'classics-sunglasses',
    'classics-glasses',
    'fashion-series',
    'fashion-acetate-sunglasses',
    'fashion-metal-sunglasses',
    'fashion-acetate-optical-frames',
    'fashion-metal-optical-frames',
    'rimless-series',
    'carbon-series',
    'metal',
    'acetate',
    'titanium',
    'luxury',
    'fashion',
    'carbon-fiber',
    'rimless'
  ];

  const allProducts = await getCollection('products');

  return CANONICAL_CATEGORIES.flatMap((category) => {
    const categoryProducts = allProducts.filter((p) => {
      const normalizedId = p.id.replace(/\.md$/, '');
      const pParts = normalizedId.split('.');
      const pLang = pParts.length > 1 ? pParts.pop() : 'en';
      if (pLang !== lang) return false;

      const series = p.data.series || p.data.categories || '';
      // Support matching slug like carbon-fiber or carbon-fiber-sunglasses
      return isCategoryMatch(series, category);
    });

    const sorted = categoryProducts.sort((a, b) => {
      if (a.data.featured && !b.data.featured) return -1;
      if (!a.data.featured && b.data.featured) return 1;
      const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
      const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
      if (dateA !== dateB) return dateB - dateA;
      return b.id.localeCompare(a.id);
    });

    return paginate(sorted, {
      params: { category },
      pageSize: 12,
      props: { categorySlug: category }
    });
  });
}

interface Props {
  page: Page<{
    id: string;
    data: any;
  }>;
  categorySlug: string;
}

const { page, categorySlug } = Astro.props as Props;
const products = page.data;
const lang = 'en';
const t = translations.en;
const pt = t.product || {
  viewAllCollections: 'View All Collections',
  productsInCategory: 'products in this category',
};

const allProducts = await getCollection('products');
const langProducts = allProducts.filter((product) => {
  const normalizedId = product.id.replace(/\.md$/, '');
  const parts = normalizedId.split('.');
  const productLang = parts.length > 1 ? parts.pop() : 'en';
  return productLang === lang;
});

function getCategoryCount(href: string): number {
  const targetSlug = href.split('/').pop() || '';
  return langProducts.filter(p => {
    const cats = p.data.series || p.data.categories || '';
    return isCategoryMatch(cats, targetSlug);
  }).length;
}

// Primary Categories (Hierarchical)
const primaryCategories = [
  {
    label: t.sidebar.sunglasses,
    href: '/product/sunglasses',
    items: [
      { label: t.sidebar.acetate_sunglasses, href: '/product/acetate-sunglasses' },
      { label: t.sidebar.metal_sunglasses, href: '/product/metal-sunglasses' },
      { label: t.sidebar.titanium_sunglasses, href: '/product/titanium-sunglasses' },
      { label: t.sidebar.carbon_fiber_sunglasses, href: '/product/carbon-fiber-sunglasses' },
      { label: t.sidebar.rimless_sunglasses, href: '/product/rimless-sunglasses' }
    ]
  },
  {
    label: t.sidebar.optical_frames,
    href: '/product/optical-frames',
    items: [
      { label: t.sidebar.acetate_glasses, href: '/product/acetate-optical-frames' },
      { label: t.sidebar.metal_glasses, href: '/product/metal-optical-frames' },
      { label: t.sidebar.titanium_glasses, href: '/product/titanium-optical-frames' },
      { label: t.sidebar.carbon_glasses, href: '/product/carbon-optical-frames' },
      { label: t.sidebar.rimless_glasses, href: '/product/rimless-optical-frames' }
    ]
  }
];

// Tags / Filters (Flat Groups)
const sidebarTags = [
  {
    label: t.sidebar.fashion_group || t.sidebar.fashion,
    href: '/product/fashion-eyewear',
    items: [
      { label: t.sidebar.fashion_acetate_sunglasses, href: '/product/fashion-acetate-sunglasses' },
      { label: t.sidebar.fashion_metal_sunglasses, href: '/product/fashion-metal-sunglasses' },
      { label: t.sidebar.fashion_acetate_glasses, href: '/product/fashion-acetate-optical-frames' },
      { label: t.sidebar.fashion_metal_glasses, href: '/product/fashion-metal-optical-frames' }
    ]
  },
  {
    label: t.sidebar.luxury_group || t.sidebar.luxury,
    href: '/product/luxury-eyewear',
    items: [
      { label: t.sidebar.luxury_acetate_sunglasses, href: '/product/luxury-acetate-sunglasses' },
      { label: t.sidebar.luxury_titanium_sunglasses, href: '/product/luxury-titanium-sunglasses' },
      { label: t.sidebar.luxury_acetate_glasses, href: '/product/luxury-acetate-optical-frames' },
      { label: t.sidebar.luxury_titanium_glasses, href: '/product/luxury-titanium-optical-frames' }
    ]
  },
  {
    label: t.sidebar.carbon_fiber_group || t.sidebar.carbon_fiber,
    href: '/product/carbon-fiber-eyewear',
    items: [
      { label: t.sidebar.carbon_fiber_sunglasses, href: '/product/carbon-fiber-sunglasses' },
      { label: t.sidebar.carbon_glasses, href: '/product/carbon-fiber-optical-frames' }
    ]
  },
  {
    label: t.sidebar.rimless_group || t.sidebar.rimless,
    href: '/product/rimless-eyewear',
    items: [
      { label: t.sidebar.rimless_sunglasses, href: '/product/rimless-sunglasses' },
      { label: t.sidebar.rimless_glasses, href: '/product/rimless-optical-frames' }
    ]
  }
];

const categoryTitle = (() => {
  for (const cat of primaryCategories) {
    if (cat.href === `/product/${categorySlug}`) return cat.label;
    for (const sub of cat.items) {
      if (sub.href === `/product/${categorySlug}`) return sub.label;
    }
  }
  for (const group of sidebarTags) {
    if (group.href === `/product/${categorySlug}`) return group.label;
    for (const item of group.items) {
      if (item.href === `/product/${categorySlug}`) return item.label;
    }
  }
  return categorySlug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
})();

function isActiveCategory(href: string): boolean {
  const pathWithoutQuery = href.split('?')[0];
  const hrefSlug = pathWithoutQuery.replace('/product/', '');
  return hrefSlug === categorySlug;
}
---

<Layout title={`${categoryTitle} - ${t.nav.products}`} lang={lang}>
  <Header lang={lang} />

  <main class="w-full min-h-screen py-6 lg:py-8 bg-stone-50">
    <div class="w-[94%] lg:w-[90%] 2xl:w-[85%] max-w-[1800px] mx-auto px-4">

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Sidebar -->
        <aside class="hidden lg:block lg:col-span-1">
          <div class="sticky top-24 space-y-6">
            <div class="bg-gradient-to-br from-white to-[#faf8f5] rounded-xl shadow-sm p-6 border border-stone-200/50">
              <!-- All Products Link - Page Title -->
              <div class="flex items-center mb-3">
                <a href="/product" class="flex-1 text-base lg:text-lg font-bold text-[#8B7355] hover:underline">
                  {t.sidebar.all_products}
                </a>
                <span class="text-xs font-normal text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full">
                  {langProducts.length}
                </span>
              </div>

              <div class="space-y-3">
                {primaryCategories.map((cat) => (
                  <div class="border-b border-gray-100 pb-3 last:border-0 last:pb-0">
                    <a
                      href={cat.href}
                      class={`flex items-center justify-between py-2 px-2 text-sm font-bold rounded-lg transition-colors ${
                        isActiveCategory(cat.href)
                          ? 'bg-[#8B7355] text-white'
                          : 'text-[#8B7355] hover:bg-stone-50'
                      }`}
                    >
                      <span class="flex items-center gap-2">
                        {cat.label}
                        <span class={`text-xs font-normal px-2 py-0.5 rounded-full ${
                          isActiveCategory(cat.href) ? 'bg-white/20 text-white' : 'bg-gray-100 text-gray-500'
                        }`}>{getCategoryCount(cat.href)}</span>
                      </span>
                      <svg class={`w-4 h-4 ${isActiveCategory(cat.href) ? 'text-white/70' : 'text-gray-400'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                    <ul class="ms-3 mt-1 space-y-1">
                      {cat.items.map((sub) => (
                        <li>
                          <a
                            href={sub.href}
                            class={`flex items-center justify-between py-1.5 px-2 text-sm rounded transition-colors ${
                              isActiveCategory(sub.href)
                                ? 'bg-[#8B7355] text-white'
                                : 'text-gray-600 hover:text-[#8B7355] hover:bg-stone-50'
                            }`}
                          >
                            <span>{sub.label}</span>
                            <span class={`text-xs ${
                              isActiveCategory(sub.href) ? 'text-white/80' : 'text-gray-400'
                            }`}>{getCategoryCount(sub.href)}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>

              <div class="mt-8 pt-6 border-t border-gray-100">
                <h4 class="text-xs font-bold text-gray-900 uppercase tracking-wider mb-4">{t.sidebar.tags_filters}</h4>
                <div class="space-y-6">
                  {sidebarTags.map((group) => (
                    <div>
                      <a href={group.href} class="text-sm font-bold text-gray-900 mb-2.5 flex items-center hover:text-[#8B7355] transition-colors">
                        <span class="text-[#8B7355] mr-1">#</span> {group.label}
                      </a>
                      <div class="flex flex-col gap-1.5">
                        {group.items.map((tag) => {
                          const isActive = isActiveCategory(tag.href);
                          return (
                            <a
                              href={tag.href}
                              class={`px-3 py-1.5 text-[11px] font-bold rounded-md border transition-all duration-200 w-full ${
                                isActive
                                  ? 'bg-[#8B7355] text-white border-[#8B7355] shadow-md'
                                  : 'bg-white text-stone-600 border-stone-200 hover:border-[#8B7355] hover:text-[#8B7355] hover:bg-stone-50'
                              }`}
                            >
                              {tag.label}
                            </a>
                          );
                        })}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>

            <div class="bg-[#8B7355] rounded-xl p-6 text-white">
              <h4 class="font-bold mb-2">{pt.needCustomEyewear || 'Need Custom Eyewear?'}</h4>
              <p class="text-sm text-white/80 mb-4">
                {pt.oemServices || 'We offer full OEM & ODM services for your brand.'}
              </p>
              <a
                href="/quote"
                class="inline-block bg-white text-[#8B7355] px-4 py-2 rounded-lg text-sm font-semibold hover:bg-gray-100 transition-colors"
              >
                {t.cta.quote || 'Get Quote'}
              </a>
            </div>
          </div>
        </aside>

        <!-- Product Grid -->
        <div class="col-span-1 lg:col-span-3">
          {page.total === 0 ? (
            <div class="text-center py-16 bg-white rounded-xl shadow-sm">
              <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
              <p class="text-gray-500 mb-4">No products in this category.</p>
              <a href="/product" class="text-[#8B7355] hover:underline">View All Products</a>
            </div>
          ) : (
            <>
              <!-- Results Info -->
              <div class="flex justify-between items-center mb-6 text-sm text-gray-500">
                <span>
                  {(pt.showingResults || 'Showing {start}-{end} of {total} products')
                    .replace('{start}', String(page.start + 1))
                    .replace('{end}', String(Math.min(page.end, page.total)))
                    .replace('{total}', String(page.total))}
                </span>
              </div>

              <div class="grid grid-cols-2 xl:grid-cols-3 gap-4 xl:gap-6">
                {products.map((product: any) => (
                  <ProductCard product={product} lang={lang} />
                ))}
              </div>

              <!-- Pagination -->
              {page.lastPage > 1 && (
                <nav class="mt-12 flex justify-center items-center gap-2" dir="ltr">
                  <!-- Previous Button -->
                  {page.url.prev ? (
                    <a
                      href={page.url.prev}
                      class="flex items-center gap-1 px-4 py-2 border border-gray-200 rounded-lg text-gray-600 hover:bg-gray-50 hover:border-[#8B7355] hover:text-[#8B7355] transition-colors"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                      </svg>
                      <span class="hidden sm:inline">{pt.previousPage || 'Previous'}</span>
                    </a>
                  ) : (
                    <span class="flex items-center gap-1 px-4 py-2 border border-gray-100 rounded-lg text-gray-300 cursor-not-allowed">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                      </svg>
                      <span class="hidden sm:inline">{pt.previousPage || 'Previous'}</span>
                    </span>
                  )}

                  <!-- Page Numbers -->
                  <div class="flex items-center gap-1">
                    {/* First page */}
                    <a
                      href={`/product/${categorySlug}`}
                      class={`w-10 h-10 flex items-center justify-center rounded-lg text-sm font-medium transition-colors ${
                        page.currentPage === 1
                          ? 'bg-[#8B7355] text-white shadow-sm'
                          : 'border border-gray-200 text-gray-600 hover:bg-gray-50 hover:border-[#8B7355] hover:text-[#8B7355]'
                      }`}
                    >
                      1
                    </a>

                    {/* Ellipsis before current if needed */}
                    {page.currentPage > 3 && (
                      <span class="px-2 text-gray-400">...</span>
                    )}

                    {/* Pages around current */}
                    {Array.from({ length: page.lastPage }, (_, i) => i + 1)
                      .filter(p => p > 1 && p < page.lastPage && Math.abs(p - page.currentPage) <= 1)
                      .map(p => (
                        <a
                          href={`/product/${categorySlug}/${p}`}
                          class={`w-10 h-10 flex items-center justify-center rounded-lg text-sm font-medium transition-colors ${
                            p === page.currentPage
                              ? 'bg-[#8B7355] text-white shadow-sm'
                              : 'border border-gray-200 text-gray-600 hover:bg-gray-50 hover:border-[#8B7355] hover:text-[#8B7355]'
                          }`}
                        >
                          {p}
                        </a>
                      ))}

                    {/* Ellipsis after current if needed */}
                    {page.currentPage < page.lastPage - 2 && (
                      <span class="px-2 text-gray-400">...</span>
                    )}

                    {/* Last page */}
                    {page.lastPage > 1 && (
                      <a
                        href={`/product/${categorySlug}/${page.lastPage}`}
                        class={`w-10 h-10 flex items-center justify-center rounded-lg text-sm font-medium transition-colors ${
                          page.currentPage === page.lastPage
                            ? 'bg-[#8B7355] text-white shadow-sm'
                            : 'border border-gray-200 text-gray-600 hover:bg-gray-50 hover:border-[#8B7355] hover:text-[#8B7355]'
                        }`}
                      >
                        {page.lastPage}
                      </a>
                    )}
                  </div>

                  <!-- Next Button -->
                  {page.url.next ? (
                    <a
                      href={page.url.next}
                      class="flex items-center gap-1 px-4 py-2 border border-gray-200 rounded-lg text-gray-600 hover:bg-gray-50 hover:border-[#8B7355] hover:text-[#8B7355] transition-colors"
                    >
                      <span class="hidden sm:inline">{pt.nextPage || 'Next'}</span>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                  ) : (
                    <span class="flex items-center gap-1 px-4 py-2 border border-gray-100 rounded-lg text-gray-300 cursor-not-allowed">
                      <span class="hidden sm:inline">{pt.nextPage || 'Next'}</span>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </span>
                  )}
                </nav>
              )}
            </>
          )}
        </div>
      </div>

      <!-- Back to All -->
      <div class="mt-12 text-center">
        <a
          href="/product"
          class="inline-flex items-center gap-2 text-[#8B7355] hover:text-[#5D4E37] font-medium transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          {pt.viewAllCollections}
        </a>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>

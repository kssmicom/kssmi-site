---
// Single smart 404 page — handles English traffic and redirects localized 404s
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const lang = 'en';
---

<Layout title="404 — Page Not Found | Kssmi" lang={lang}>
  <!-- Language Redirect Script -->
  <script is:inline>
    (function() {
      const pathParts = window.location.pathname.split('/').filter(Boolean);
      const supportedLangs = ['it', 'es', 'fr', 'de', 'pt', 'ru', 'ja', 'tr', 'ar', 'ko', 'zh', 'hi', 'vi', 'jv', 'ms', 'tg'];
      
      if (pathParts.length > 0 && supportedLangs.includes(pathParts[0])) {
        const lang = pathParts[0];
        // Prevent redirect loops
        if (window.location.pathname !== `/${lang}/404` && window.location.pathname !== `/${lang}/404/`) {
          // Hide document entirely to prevent Flash of English Content during redirect execution
          document.documentElement.style.opacity = '0';
          window.location.replace(`/${lang}/404`);
        }
      }
    })();
  </script>

  <Header lang={lang} />

  <main id="main-content" tabindex="-1" class="w-full min-h-screen bg-stone-100 pt-32 pb-24 flex items-center focus:outline-none">
    <div class="max-w-2xl mx-auto px-6 text-center">

      <!-- Kssmi Text Logo -->
      <div class="inline-flex flex-col items-center justify-center mb-8 hover:-translate-y-1 transition-transform duration-500">
        <span class="text-2xl font-bold text-[#503629] tracking-tight leading-none uppercase">KSSMI</span>
        <span class="h-[2px] w-6 bg-[#503629] mt-1"></span>
        <span class="text-[9px] font-bold uppercase tracking-[0.2em] text-[#503629] mt-1">Eyewear Mfg.</span>
      </div>

      <!-- 404 Number -->
      <div class="relative mb-6">
        <span class="text-[160px] font-black text-stone-200 leading-none select-none block">404</span>
        <div class="absolute inset-0 flex items-center justify-center">
          <svg class="w-16 h-16 text-[#8B7355]/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      </div>

      <!-- Heading & message -->
      <h1 class="text-3xl font-bold text-[#5D4E37] mb-3 tracking-tight">
        Page Not Found
      </h1>
      <p class="text-base text-stone-600 mb-8 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>

      <!-- Search Bar -->
      <form id="search-form" action="/search" method="GET" class="relative group max-w-3xl mx-auto mb-10">
        <div class="absolute inset-0 bg-[#5D4E37]/5 rounded-full blur-md opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

        <div class="flex items-center border-2 border-stone-200 bg-white rounded-full overflow-hidden focus-within:border-[#8B7355] shadow-sm transition-all duration-300 focus-within:ring-4 focus-within:ring-[#8B7355]/10 relative z-10">
          <input
            id="search-input"
            type="search"
            name="q"
            autocomplete="off"
            class="flex-grow py-4 px-6 bg-transparent border-none outline-none text-base text-stone-900 placeholder-stone-400 font-medium focus:ring-0"
            placeholder="Search products…"
          />

          <!-- Clear Button (X icon) - hidden by default -->
          <button type="button" id="search-clear" class="hidden px-3 text-stone-400 hover:text-[#5D4E37] transition-colors flex-shrink-0" aria-label="Clear search">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>

          <!-- Search Button -->
          <button type="submit" class="px-5 py-2.5 mr-1.5 bg-[#5D4E37] text-white rounded-full hover:bg-[#8B7355] transition-all duration-300 font-bold tracking-wide text-xs uppercase shadow-md flex-shrink-0 flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <span>Search</span>
          </button>
        </div>
      </form>

      <!-- Decorative divider -->
      <div class="flex items-center justify-center gap-3 mb-10">
        <span class="h-[1px] w-10 bg-[#8B7355]/30"></span>
        <span class="text-xs font-bold uppercase tracking-[0.2em] text-[#5D4E37]/40">Kssmi</span>
        <span class="h-[1px] w-10 bg-[#8B7355]/30"></span>
      </div>

      <!-- Action buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="/"
          class="inline-flex items-center gap-2 px-8 py-3 bg-[#5D4E37] text-white font-bold uppercase tracking-wider text-xs rounded-full hover:bg-[#8B7355] transition-colors duration-300 shadow-lg">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          <span>Back to Home</span>
        </a>
        <a href="/product"
          class="inline-flex items-center gap-2 px-8 py-3 border-2 border-[#5D4E37] text-[#5D4E37] font-bold uppercase tracking-wider text-xs rounded-full hover:bg-[#5D4E37] hover:text-white transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
          </svg>
          <span>View Catalog</span>
        </a>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>

<style is:global>
  /* Hide browser's default search clear button */
  input[type="search"]::-webkit-search-cancel-button {
    -webkit-appearance: none;
    appearance: none;
    display: none;
  }
  input[type="search"]::-moz-search-clear-button {
    display: none;
  }
</style>

<script>
  // Search Clear Logic
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const searchClear = document.getElementById('search-clear') as HTMLButtonElement | null;

  function updateClearButton() {
    if (searchInput && searchClear) {
      if (searchInput.value.trim()) {
        searchClear.classList.remove('hidden');
      } else {
        searchClear.classList.add('hidden');
      }
    }
  }

  if (searchInput) {
    searchInput.addEventListener('input', updateClearButton);
    updateClearButton();
  }

  if (searchClear && searchInput) {
    searchClear.addEventListener('click', () => {
      searchInput.value = '';
      searchClear.classList.add('hidden');
      searchInput.focus();
    });
  }
</script>

---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../translations';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProductCard from '../../components/ProductCard.astro';

export async function getStaticPaths() {
  const allProducts = await getCollection('products');
  const languages = ['en', 'it', 'es', 'fr', 'de', 'pt', 'ru', 'ja', 'tr', 'ar', 'ko', 'zh', 'hi', 'vi', 'jv', 'ms', 'tg'];

  return languages.map((lang) => {
    const langProducts = allProducts.filter((product) => {
      const productLang = product.id.split('/').pop()?.replace('.md', '') || 'en';
      return productLang === lang;
    });

    return {
      params: { lang },
      props: { products: langProducts, lang }  // Pass lang in props too!
    };
  });
}

const { products, lang } = Astro.props;

const t = translations[lang] || translations.en;
const currentPath = lang === 'en' ? '' : `${lang}/`;
---

<Layout title={t.nav.products} lang={lang}>
  <Header lang={lang} />

  <!-- LAYER 1: WRAPPER -->
  <main class="w-full min-h-screen py-12 lg:py-20 border-b border-stone-100 relative z-10">
    <!-- LAYER 2: CONSTRAINT -->
    <div class="w-[94%] lg:w-[90%] 2xl:w-[85%] max-w-[1800px] mx-auto">
      <!-- LAYER 3: BLOCK -->
      <h1 class="text-4xl md:text-5xl font-bold mb-12 text-center text-[#8B7355]">{t.nav.products}</h1>

      <!-- Product Grid -->
      {products.length === 0 ? (
        <div class="text-center py-12">
          <p class="text-gray-600">No products yet. Check back soon!</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 lg:gap-8">
          {products.map((product) => (
            <ProductCard product={product} lang={lang} />
          ))}
        </div>
      )}
    </div>
  </main>

  <Footer lang={lang} />
</Layout>

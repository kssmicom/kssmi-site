---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../translations';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Generate all language routes
export async function getStaticPaths() {
  const languages = ['it', 'es', 'fr', 'de', 'pt', 'ru', 'ja', 'tr', 'ar', 'ko', 'zh', 'hi', 'vi', 'jv', 'ms', 'tg'];
  return languages.map((lang) => ({
    params: { lang },
    props: { lang }
  }));
}

const { lang } = Astro.props;
const t = translations[lang] || translations.en;

// Read the merged single file
const entry = await getEntry('collection', `home/home.${lang}`);

const title = entry?.data?.seoTitle || "Kssmi - Premium Eyewear & Sunglasses Manufacturer";
const description = entry?.data?.seoDescription || "Premium eyewear manufacturer in China.";
---

<Layout title={title} description={description} lang={lang}>
  <Header lang={lang} />

  <main>
    <!-- Homepage content will be added here -->
  </main>

  <Footer lang={lang} />
</Layout>

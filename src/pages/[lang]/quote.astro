---
/**
 * Quote Request Page - Multi-language
 * URL: /{lang}/quote/
 *
 * Supported languages: it, es, fr, de, pt, ru, ja, tr, ar
 */

import Layout from '../../layouts/Layout.astro';
import { translations } from '../../translations';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import InquiryForm from '../../components/InquiryForm.astro';

export function getStaticPaths() {
  const supportedLangs = ['it', 'es', 'fr', 'de', 'pt', 'ru', 'ja', 'tr', 'ar', 'ko', 'zh', 'hi', 'vi', 'jv', 'ms', 'tg'];
  return supportedLangs.map(lang => ({
    params: { lang },
  }));
}

const { lang } = Astro.params;
const t = (translations as any)[lang as string] || translations.en;
const isRTL = lang === 'ar';

// Quote page translations
const quoteText = {
  title: {
    it: 'Richiedi un Preventivo',

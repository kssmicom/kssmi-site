---
// Language-aware search page
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { translations } from '../../translations';

// Generate static paths for all languages
export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'it' } },
    { params: { lang: 'es' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'de' } },
    { params: { lang: 'pt' } },
    { params: { lang: 'ru' } },
    { params: { lang: 'ja' } },
    { params: { lang: 'tr' } },
    { params: { lang: 'ar' } },
  ];
}

const lang = Astro.params.lang || 'en';
const t = translations[lang] || translations.en;

// Translations for all languages
const searchText = {
  en: "Search",
  it: "Cerca",
  es: "Buscar",
  fr: "Recherche",
  de: "Suche",
  pt: "Buscar",
  ru: "Поиск",
  ja: "検索",
  tr: "Ara",
  ar: "بحث"
};

const resultsFoundText = {
  en: "Results Found",
  it: "Risultati trovati",
  es: "Resultados encontrados",
  fr: "Résultats trouvés",
  de: "Ergebnisse gefunden",
  pt: "Resultados encontrados",
  ru: "Результатов найдено",
  ja: "件の結果",
  tr: "Sonuç bulundu",
  ar: "نتائج وجدت"
};

const noResultsText = {
  en: "No results found for",
  it: "Nessun risultato per",
  es: "Sin resultados para",
  fr: "Aucun résultat pour",
  de: "Keine Ergebnisse für",
  pt: "Sem resultados para",
  ru: "Нет результатов для",
  ja: "の結果はありません",
  tr: "için sonuç bulunamadı",
  ar: "لا توجد نتائج لـ"
};

const tryDifferentText = {
  en: "Try different keywords or check your spelling",
  it: "Prova parole chiave diverse",
  es: "Intenta con diferentes palabras clave",
  fr: "Essayez d'autres mots-clés",
  de: "Versuchen Sie andere Suchbegriffe",
  pt: "Tente palavras-chave diferentes",
  ru: "Попробуйте другие ключевые слова",
  ja: "別のキーワードを試してください",
  tr: "Farklı anahtar kelimeler deneyin",
  ar: "جرب كلمات مفتاحية مختلفة"
};

const viewDetailsText = {
  en: "View Details",
  it: "Vedi dettagli",
  es: "Ver detalles",
  fr: "Voir détails",
  de: "Details ansehen",
  pt: "Ver detalhes",
  ru: "Подробнее",
  ja: "詳細を見る",
  tr: "Detayları görüntüle",
  ar: "عرض التفاصيل"
};

const searchPlaceholder = {
  en: "Search products, pages, articles...",
  it: "Cerca prodotti, pagine, articoli...",
  es: "Buscar productos, páginas, artículos...",
  fr: "Rechercher produits, pages, articles...",
  de: "Produkte, Seiten, Artikel suchen...",
  pt: "Buscar produtos, páginas, artigos...",
  ru: "Поиск продуктов, страниц, статей...",
  ja: "製品、ページ、記事を検索...",
  tr: "Ürünler, sayfalar, makaleler ara...",
  ar: "البحث عن المنتجات والصفحات والمقالات..."
};

// Pagefind language code mapping
const pagefindLangMap: Record<string, string> = {
  en: 'en', it: 'it', es: 'es', fr: 'fr', de: 'de',
  pt: 'pt', ru: 'ru', ja: 'ja', tr: 'tr', ar: 'ar'
};
const pagefindLang = pagefindLangMap[lang] || 'en';
---

<Layout title={`${searchText[lang]} | KSSMI`} lang={lang}>
  <Header lang={lang} />

  <section class="w-full min-h-screen bg-stone-100 pt-32 pb-24">
    <div class="max-w-[1920px] mx-auto px-4 sm:px-6 lg:px-12">

      <!-- Search Header Block -->
      <div class="text-center mb-12 relative max-w-4xl mx-auto">
        <!-- KSSMI Text Logo -->
        <div class="inline-flex flex-col items-center justify-center mb-6 hover:-translate-y-1 transition-transform duration-500">
          <span class="text-3xl font-bold text-[#8B7355] tracking-tight leading-none">KSSMI</span>
          <span class="h-[2px] w-8 bg-[#8B7355] mt-1"></span>
          <span class="text-[9px] font-bold uppercase tracking-[0.2em] text-stone-500 mt-1">Eyewear</span>
        </div>

        <h1 class="text-3xl md:text-4xl font-bold text-[#5D4E37] mb-3 tracking-tight">
          {searchText[lang]} Results
        </h1>

        <!-- Query display (updated by JS) -->
        <div id="search-info" class="hidden">
          <div class="inline-block relative">
            <p class="text-lg text-stone-600 mb-3 font-light">
              Found matches for <span id="query-display" class="font-bold text-[#8B7355] border-b-2 border-[#8B7355]/20"></span>
            </p>
          </div>

          <div class="flex items-center justify-center gap-3">
            <span class="h-[1px] w-10 bg-[#8B7355]/30"></span>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#5D4E37]/60">
              <span id="count-number">0</span> {resultsFoundText[lang]}
            </p>
            <span class="h-[1px] w-10 bg-[#8B7355]/30"></span>
          </div>
        </div>
      </div>

      <!-- Search Form Block -->
      <div class="max-w-3xl mx-auto mb-16 relative z-10">
        <form action={`/${lang}/search`} method="GET" class="relative group">
          <div class="absolute inset-0 bg-[#5D4E37]/5 rounded-full blur-md opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <div class="flex items-center border-2 border-stone-200 bg-white rounded-full overflow-hidden focus-within:border-[#8B7355] shadow-sm transition-all duration-300 focus-within:ring-4 focus-within:ring-[#8B7355]/10 relative z-10">
            <input
              type="search"
              name="q"
              id="search-input"
              placeholder={searchPlaceholder[lang]}
              class="flex-grow py-4 px-6 bg-transparent border-none outline-none text-base text-stone-900 placeholder-stone-400 font-medium focus:ring-0"
              style="::-webkit-search-cancel-button{display:none}::-moz-search-clear-button{display:none}"
              autocomplete="off"
            >

            <!-- Clear Button (X icon) -->
            <button type="button" id="search-clear" class="hidden px-3 text-stone-400 hover:text-stone-600 transition-colors flex-shrink-0" aria-label="Clear search">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>

            <!-- Search Button -->
            <button type="submit" class="px-5 py-2.5 mr-1.5 bg-[#5D4E37] text-white rounded-full hover:bg-[#8B7355] transition-all duration-300 font-bold tracking-wide text-xs uppercase shadow-md flex-shrink-0 flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
              <span>{searchText[lang]}</span>
            </button>
          </div>
        </form>
      </div>

      <!-- Loading State -->
      <div id="loading-state" class="hidden text-center py-16">
        <svg class="w-12 h-12 mx-auto animate-spin text-[#8B7355]" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <p class="mt-4 text-stone-500">{searchText[lang]}...</p>
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="text-center py-24">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-white border border-stone-200 rounded-full mb-8 shadow-sm">
          <svg class="w-8 h-8 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </div>
        <h2 class="text-3xl font-bold text-[#5D4E37] mb-4">{searchText[lang]} KSSMI</h2>
        <p class="text-base text-stone-600 mb-10 max-w-md mx-auto">{searchPlaceholder[lang]}</p>
      </div>

      <!-- Results Grid -->
      <div id="search-results" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      </div>

      <!-- No Results State -->
      <div id="no-results" class="hidden text-center py-24">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-white border border-stone-200 rounded-full mb-8 shadow-sm hover:border-[#8B7355] transition-colors duration-500">
          <svg class="w-8 h-8 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <h2 class="text-3xl font-bold text-[#5D4E37] mb-4">{noResultsText[lang]}</h2>
        <p class="text-base text-stone-600 mb-10 max-w-md mx-auto" id="no-results-text">{tryDifferentText[lang]}</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a href={`/${lang === 'en' ? '' : lang + '/'}`} class="inline-flex items-center px-8 py-3 bg-[#5D4E37] text-white font-bold uppercase tracking-wider text-xs rounded-full hover:bg-[#8B7355] transition-colors duration-300 shadow-lg">
            {t.nav?.home || 'Home'}
          </a>
          <a href={`/${lang === 'en' ? '' : lang + '/'}product`} class="inline-flex items-center px-8 py-3 border-2 border-[#5D4E37] text-[#5D4E37] font-bold uppercase tracking-wider text-xs rounded-full hover:bg-[#5D4E37] hover:text-white transition-all duration-300">
            {t.nav?.products || 'Catalog'}
          </a>
        </div>
      </div>

      <!-- Error State -->
      <div id="error-state" class="hidden text-center py-24">
        <p class="text-red-600">{tryDifferentText[lang]}</p>
      </div>

      <!-- Pagination -->
      <div id="pagination" class="hidden mt-20 flex justify-center">
        <div class="inline-flex items-center gap-2" id="pagination-container">
        </div>
      </div>
    </div>
  </section>

  <Footer lang={lang} />
</Layout>


<style is:global>
  /* Search Result Card — mirrors ProductCard.astro */
  .src-card {
    display: block;
    text-decoration: none;
  }
  .src-card-inner {
    background: white;
    border-radius: 0.5rem;
    box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06);
    overflow: hidden;
    transition: box-shadow 0.3s ease;
  }
  .src-card:hover .src-card-inner {
    box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
  }
  .src-img-wrap {
    position: relative;
    width: 100%;
    padding-top: 75%;
    overflow: hidden;
    background-color: #f3f4f6;
  }
  .src-img,
  .src-img-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .src-img {
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .src-card:hover .src-img {
    transform: scale(1.05);
  }
  .src-img-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
  }
  .src-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.4);
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }
  .src-card:hover .src-overlay {
    opacity: 1;
  }
  .src-overlay-pill {
    background: white;
    color: #8B7355;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transform: translateY(0.5rem);
    transition: transform 0.3s ease;
  }
  .src-card:hover .src-overlay-pill {
    transform: translateY(0);
  }
  .src-info {
    padding: 1rem 1.25rem;
    text-align: center;
  }
  .src-item-no {
    font-size: 0.75rem;
    color: #8B7355;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  .src-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: #111827;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.3s ease;
  }
  .src-card:hover .src-title {
    color: #8B7355;
  }
</style>

<script define:vars={{ lang, pagefindLang, viewDetailsText }}>
  // Get query from URL at RUNTIME (not build time)
  const urlParams = new URLSearchParams(window.location.search);
  const query = urlParams.get('q') || '';

  // DOM elements
  const searchInput = document.getElementById('search-input');
  const searchInfo = document.getElementById('search-info');
  const queryDisplay = document.getElementById('query-display');
  const countNumber = document.getElementById('count-number');
  const loadingState = document.getElementById('loading-state');
  const emptyState = document.getElementById('empty-state');
  const searchResults = document.getElementById('search-results');
  const noResults = document.getElementById('no-results');
  const noResultsQuery = document.getElementById('no-results-query');
  const errorState = document.getElementById('error-state');
  const pagination = document.getElementById('pagination');

  const RESULTS_PER_PAGE = 12;
  let currentPage = 1;
  let allResults = [];

  // Pre-fill search input with query
  if (searchInput && query) {
    searchInput.value = query;
  }

  // Clear button logic
  const searchClear = document.getElementById('search-clear');
  if (searchInput && searchClear) {
    // Show clear button if input already has value (from pre-fill)
    if (searchInput.value.trim()) searchClear.classList.remove('hidden');
    searchInput.addEventListener('input', () => {
      searchInput.value.trim()
        ? searchClear.classList.remove('hidden')
        : searchClear.classList.add('hidden');
    });
    searchClear.addEventListener('click', () => {
      searchInput.value = '';
      searchClear.classList.add('hidden');
      searchInput.focus();
    });
  }

  function hideAllStates() {
    loadingState?.classList.add('hidden');
    emptyState?.classList.add('hidden');
    searchResults?.classList.add('hidden');
    noResults?.classList.add('hidden');
    errorState?.classList.add('hidden');
    pagination?.classList.add('hidden');
    searchInfo?.classList.add('hidden');
  }

  function showLoading() {
    hideAllStates();
    loadingState?.classList.remove('hidden');
    searchInfo?.classList.remove('hidden');
    if (queryDisplay) queryDisplay.textContent = query;
  }

  function showEmpty() {
    hideAllStates();
    emptyState?.classList.remove('hidden');
  }

  function showNoResults() {
    hideAllStates();
    noResults?.classList.remove('hidden');
    searchInfo?.classList.remove('hidden');
    if (queryDisplay) queryDisplay.textContent = query;
    if (noResultsQuery) noResultsQuery.textContent = query;
    if (countNumber) countNumber.textContent = '0';
  }

  function showError() {
    hideAllStates();
    errorState?.classList.remove('hidden');
  }

  function showResults() {
    hideAllStates();
    searchResults?.classList.remove('hidden');
    searchInfo?.classList.remove('hidden');
    if (queryDisplay) queryDisplay.textContent = query;
  }

  async function performSearch(searchQuery) {
    if (!searchQuery) {
      showEmpty();
      return;
    }

    showLoading();

    try {
      const pagefindPath = '/pagefind/pagefind.js';
      const pagefind = await import(/* @vite-ignore */ pagefindPath);

      // Initialize Pagefind without language filter so product pages are found
      // (Pagefind partitions by <html lang>, but product specs are shared across locales)
      await pagefind.init();

      const searchResponse = await pagefind.search(searchQuery);

      if (searchResponse.results.length === 0) {
        showNoResults();
        return;
      }

      // Fetch all result data
      allResults = await Promise.all(
        searchResponse.results.map((result) => result.data())
      );

      // Update count
      if (countNumber) {
        countNumber.textContent = allResults.length.toString();
      }

      // Render first page
      renderPage(1);
      showResults();

    } catch (error) {
      console.error('Search error:', error);
      showError();
    }
  }

  function createResultCard(data) {
    const url = data.url || '#';
    const title = data.meta?.title || 'Untitled';
    const itemNo = data.meta?.itemNo || '';
    // Pagefind may return image as an object {src, sizes} or a plain string
    const rawImage = data.meta?.image || null;
    const image = rawImage
      ? (typeof rawImage === 'object' ? rawImage.src : rawImage)
      : null;
    const viewDetails = viewDetailsText[lang] || viewDetailsText.en;

    const imageContent = image
      ? `<img src="${image}" alt="${title}" class="src-img" loading="lazy" />`
      : `<div class="src-img-placeholder">
           <svg style="width:3rem;height:3rem;color:#9ca3af" fill="none" stroke="currentColor" viewBox="0 0 24 24">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
               d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
           </svg>
         </div>`;

    return `
      <a href="${url}" class="src-card">
        <div class="src-card-inner">
          <div class="src-img-wrap">
            ${imageContent}
            <div class="src-overlay">
              <span class="src-overlay-pill">
                ${viewDetails}
                <svg style="width:1rem;height:1rem" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </div>
          <div class="src-info">
            ${itemNo ? `<p class="src-item-no">${itemNo}</p>` : ''}
            <h3 class="src-title">${title}</h3>
          </div>
        </div>
      </a>
    `;
  }

  function renderPage(page) {
    currentPage = page;
    const startIndex = (page - 1) * RESULTS_PER_PAGE;
    const endIndex = startIndex + RESULTS_PER_PAGE;
    const pageResults = allResults.slice(startIndex, endIndex);

    if (searchResults) {
      searchResults.innerHTML = pageResults.map(data => createResultCard(data)).join('');
    }
    renderPagination();
  }

  function renderPagination() {
    const totalPages = Math.ceil(allResults.length / RESULTS_PER_PAGE);

    if (totalPages <= 1) {
      pagination?.classList.add('hidden');
      return;
    }

    pagination?.classList.remove('hidden');
    const paginationContainer = pagination?.querySelector('div');
    if (!paginationContainer) return;

    let paginationHTML = '';

    // Previous button
    if (currentPage > 1) {
      paginationHTML += `
        <button class="px-4 py-2 rounded-lg border border-stone-300 bg-white text-stone-700 hover:bg-stone-50 transition-colors" data-page="${currentPage - 1}">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
      `;
    }

    // Page numbers
    for (let i = 1; i <= totalPages; i++) {
      if (i === currentPage) {
        paginationHTML += `
          <button class="px-4 py-2 rounded-lg bg-[#8B7355] text-white font-semibold" data-page="${i}">${i}</button>
        `;
      } else if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
        paginationHTML += `
          <button class="px-4 py-2 rounded-lg border border-stone-300 bg-white text-stone-700 hover:bg-stone-50 transition-colors" data-page="${i}">${i}</button>
        `;
      } else if (i === currentPage - 2 || i === currentPage + 2) {
        paginationHTML += `<span class="px-2 text-stone-400">...</span>`;
      }
    }

    // Next button
    if (currentPage < totalPages) {
      paginationHTML += `
        <button class="px-4 py-2 rounded-lg border border-stone-300 bg-white text-stone-700 hover:bg-stone-50 transition-colors" data-page="${currentPage + 1}">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      `;
    }

    paginationContainer.innerHTML = paginationHTML;

    // Add click handlers
    paginationContainer.querySelectorAll('button[data-page]').forEach(btn => {
      btn.addEventListener('click', () => {
        const page = parseInt(btn.getAttribute('data-page') || '1');
        renderPage(page);
        // Scroll to top of results
        searchResults?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  }

  // Intercept mid-page search form submission (Enter key or Search button click)
  const searchForm = searchInput?.closest('form');
  if (searchForm) {
    searchForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const newQuery = searchInput?.value.trim() || '';
      if (newQuery) {
        // Update URL so query is bookmarkable
        const newUrl = new URL(window.location.href);
        newUrl.searchParams.set('q', newQuery);
        history.pushState({}, '', newUrl.toString());
        performSearch(newQuery);
      } else {
        showEmpty();
      }
    });
  }

  // Run search on page load if query exists in URL
  if (query) {
    performSearch(query);
  } else {
    showEmpty();
  }
</script>

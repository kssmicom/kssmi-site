---

<Layout title={`${(searchResultsText as any)[lang]} | Kssmi`} lang={lang}>
  <Header lang={lang} />

  <div id="search-page" data-lang={lang} data-view-details={JSON.stringify(viewDetailsText)}>
  <section class="w-full min-h-screen bg-stone-100 pt-32 pb-24">
    <div class="max-w-[1920px] mx-auto px-4 sm:px-6 lg:px-12">

      <!-- Search Header Block -->
      <div class="text-center mb-12 relative max-w-4xl mx-auto">
        <!-- Kssmi Text Logo -->
        <div class="inline-flex flex-col items-center justify-center mb-6 hover:-translate-y-1 transition-transform duration-500">
          <span class="text-3xl font-bold text-[#503629] tracking-tight leading-none uppercase">KSSMI</span>
          <span class="h-[2px] w-8 bg-[#503629] mt-1"></span>
          <span class="text-[9px] font-bold uppercase tracking-[0.2em] text-[#503629] mt-1">{eyewearText}</span>
        </div>

        <h1 class="text-3xl md:text-4xl font-bold text-[#5D4E37] mb-3 tracking-tight">
          {(searchResultsText as any)[lang]}
        </h1>

        <!-- Query display (updated by JS) -->
        <div id="search-info" class="hidden">
          <div class="inline-block relative">
            <p class="text-lg text-stone-600 mb-3 font-light">
              {(foundMatchesFor as any)[lang]} <span id="query-display" class="font-bold text-[#8B7355] border-b-2 border-[#8B7355]/20"></span>
            </p>
          </div>

          <div class="flex items-center justify-center gap-3">
            <span class="h-[1px] w-10 bg-[#8B7355]/30"></span>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#5D4E37]/60">
              <span id="count-number">0</span> {(resultsFoundText as any)[lang]}
            </p>
            <span class="h-[1px] w-10 bg-[#8B7355]/30"></span>
          </div>
        </div>
      </div>

      <!-- Search Form Block -->
      <div class="max-w-3xl mx-auto mb-16 relative z-10">
        <form action={`/${lang}/search`} method="GET" class="relative group">
          <div class="absolute inset-0 bg-[#5D4E37]/5 rounded-full blur-md opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <div class="flex items-center border-2 border-stone-200 bg-white rounded-full overflow-hidden focus-within:border-[#8B7355] shadow-sm transition-all duration-300 focus-within:ring-4 focus-within:ring-[#8B7355]/10 relative z-10">
            <input
              type="search"
              name="q"
              id="search-input"
              placeholder={(searchPlaceholder as any)[lang]}
              class="flex-grow py-4 px-6 bg-transparent border-none outline-none text-base text-stone-900 placeholder-stone-400 font-medium focus:ring-0"
              autocomplete="off"
            >

            <!-- Clear Button (X icon) - hidden by default -->
            <button type="button" id="search-clear" class="hidden px-3 text-stone-400 hover:text-[#5D4E37] transition-colors flex-shrink-0" aria-label="Clear search">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>

            <!-- Search Button -->
            <button type="submit" class="px-5 py-2.5 mr-1.5 bg-[#5D4E37] text-white rounded-full hover:bg-[#8B7355] transition-all duration-300 font-bold tracking-wide text-xs uppercase shadow-md flex-shrink-0 flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
              <span>{(searchText as any)[lang]}</span>
            </button>
          </div>
        </form>
      </div>

      <!-- Loading State -->
      <div id="loading-state" class="hidden text-center py-16">
        <svg class="w-12 h-12 mx-auto animate-spin text-[#8B7355]" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <p class="mt-4 text-stone-500">{(searchText as any)[lang]}...</p>
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="text-center py-24">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-white border border-stone-200 rounded-full mb-8 shadow-sm">
          <svg class="w-8 h-8 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </div>
        <h2 class="text-3xl font-bold text-[#5D4E37] mb-4">{(searchText as any)[lang]} Kssmi</h2>
        <p class="text-base text-stone-600 mb-10 max-w-md mx-auto">{(searchPlaceholder as any)[lang]}</p>

        <!-- Suggestions -->
        <div class="mt-12 max-w-5xl mx-auto">
          <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-[#8B7355] mb-8">{(recommendedText as any)[lang] || recommendedText.en}</h3>
          <div class="flex flex-wrap gap-3 justify-center">
              {((searchKeywords as any)[lang] || searchKeywords.en).metal}
            </a>
          </div>
        </div>
      </div>

      <!-- Results Grid -->
      <div id="search-results" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      </div>

      <!-- No Results State -->
      <div id="no-results" class="hidden text-center py-24">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-white border border-stone-200 rounded-full mb-8 shadow-sm hover:border-[#8B7355] transition-colors duration-500">
          <svg class="w-8 h-8 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <h2 class="text-3xl font-bold text-[#5D4E37] mb-4">{(noResultsText as any)[lang]}</h2>
        <p class="text-base text-stone-600 mb-10 max-w-md mx-auto" id="no-results-text">{(tryDifferentText as any)[lang]}</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a href={`/${lang === 'en' ? '' : lang + '/'}`} class="inline-flex items-center px-8 py-3 bg-[#5D4E37] text-white font-bold uppercase tracking-wider text-xs rounded-full hover:bg-[#8B7355] transition-colors duration-300 shadow-lg">
            {t.nav?.home || 'Home'}
          </a>
          <a href={`/${lang === 'en' ? '' : lang + '/'}product`} class="inline-flex items-center px-8 py-3 border-2 border-[#5D4E37] text-[#5D4E37] font-bold uppercase tracking-wider text-xs rounded-full hover:bg-[#5D4E37] hover:text-white transition-all duration-300">
            {t.nav?.products || 'Catalog'}
          </a>
        </div>
      </div>

      <!-- Error State -->
      <div id="error-state" class="hidden text-center py-24">
        <p class="text-red-600">{(tryDifferentText as any)[lang]}</p>
      </div>

      <!-- Pagination -->
      <div id="pagination" class="hidden mt-20 flex justify-center">
        <div class="inline-flex items-center gap-2" id="pagination-container">
        </div>
      </div>
    </div>
  </section>

  <Footer lang={lang} />
  </div>
</Layout>


<style is:global>
  /* Hide browser's default search clear button */
  input[type="search"]::-webkit-search-cancel-button {
    -webkit-appearance: none;
    appearance: none;
    display: none;
  }
  input[type="search"]::-moz-search-clear-button {
    display: none;
  }

  /* Search Result Card — mirrors ProductCard.astro */
  .src-card {
    display: block;
    text-decoration: none;
  }
  .src-card-inner {
    background: white;
    border-radius: 0.5rem;
    box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06);
    overflow: hidden;
    transition: box-shadow 0.3s ease;
  }
  .src-card:hover .src-card-inner {
    box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
  }
  .src-img-wrap {
    position: relative;
    width: 100%;
    padding-top: 75%;
    overflow: hidden;
    background-color: #f3f4f6;
  }
  .src-img,
  .src-img-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .src-img {
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .src-card:hover .src-img {
    transform: scale(1.05);
  }
  .src-img-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
  }
  .src-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.4);
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }
  .src-card:hover .src-overlay {
    opacity: 1;
  }
  .src-overlay-pill {
    background: black;
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transform: translateY(0.5rem);
    transition: transform 0.3s ease;
  }
  .src-card:hover .src-overlay-pill {
    transform: translateY(0);
  }
  .src-overlay-pill .src-arrow {
    transition: transform 0.3s ease;
  }
  .src-card:hover .src-overlay-pill .src-arrow {
    transform: translateX(4px);
  }
  .src-info {
    padding: 1rem 1.25rem;
    text-align: center;
  }
  .src-item-no {
    font-size: 0.75rem;
    color: #8B7355;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  .src-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: #111827;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.3s ease;
  }
  .src-card:hover .src-title {
    color: #8B7355;
  }
  .src-desc {
    font-size: 0.75rem;
    color: #6b7280;
    margin-top: 0.25rem;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  /* ── Pagination ── */
  .page-numbers {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.25rem;
    height: 2.25rem;
    padding: 0 0.75rem;
    margin: 0 0.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #5D4E37;
    background-color: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.25rem;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    cursor: pointer;
  }
  .page-numbers:hover {
    color: #8B7355;
    border-color: #8B7355;
    transform: translateY(-1px);
    box-shadow: 0 4px 6px -1px rgba(139, 115, 85, 0.1);
  }
  .page-numbers.current {
    background-color: #5D4E37;
    border-color: #5D4E37;
    color: #ffffff;
    box-shadow: 0 4px 6px -1px rgba(93, 78, 55, 0.3);
  }
</style>

<script>
  import Fuse from 'fuse.js';

  document.addEventListener('astro:page-load', () => {
  // Get translation text and lang from data attributes
  const searchPage = document.getElementById('search-page');
  const lang = searchPage?.dataset.lang || 'en';
  const viewDetailsText = JSON.parse(searchPage?.dataset.viewDetails || '{}');
  // Read query fresh from URL each time (avoids stale-closure bugs)
  function getQuery() {
    return new URLSearchParams(window.location.search).get('q') || '';
  }

  // DOM elements
  const searchInput = document.getElementById('search-input');
  const searchClear = document.getElementById('search-clear');
  const searchInfo = document.getElementById('search-info');
  const queryDisplay = document.getElementById('query-display');
  const countNumber = document.getElementById('count-number');
  const loadingState = document.getElementById('loading-state');
  const emptyState = document.getElementById('empty-state');
  const searchResults = document.getElementById('search-results');
  const noResults = document.getElementById('no-results');
  const noResultsQuery = document.getElementById('no-results-query');
  const errorState = document.getElementById('error-state');
  const pagination = document.getElementById('pagination');
  const paginationContainer = document.getElementById('pagination-container');

  const RESULTS_PER_PAGE = 12;
  let currentPage = 1;
  let allResults = [];
  let fuse = null;

  // Clear button functionality
  function updateClearButton() {
    if (searchInput && searchClear) {
      if (searchInput.value.trim()) {
        searchClear.classList.remove('hidden');
      } else {
        searchClear.classList.add('hidden');
      }
    }
  }

  if (searchInput) {
    searchInput.addEventListener('input', updateClearButton);
  }

  if (searchClear && searchInput) {
    searchClear.addEventListener('click', () => {
      searchInput.value = '';
      searchClear.classList.add('hidden');
      searchInput.focus();
    });
  }

  // Pre-fill search input with query
  if (searchInput && getQuery()) {
    searchInput.value = getQuery();
    updateClearButton();
  }

  function hideAllStates() {
    loadingState?.classList.add('hidden');
    emptyState?.classList.add('hidden');
    searchResults?.classList.add('hidden');
    noResults?.classList.add('hidden');
    errorState?.classList.add('hidden');
    pagination?.classList.add('hidden');
    searchInfo?.classList.add('hidden');
  }

  function showLoading() {
    hideAllStates();
    loadingState?.classList.remove('hidden');
    searchInfo?.classList.remove('hidden');
    if (queryDisplay) queryDisplay.textContent = getQuery();
  }

  function showEmpty() {
    hideAllStates();
    emptyState?.classList.remove('hidden');
  }

  function showNoResults() {
    hideAllStates();
    noResults?.classList.remove('hidden');
    searchInfo?.classList.remove('hidden');
    if (queryDisplay) queryDisplay.textContent = getQuery();
    if (noResultsQuery) noResultsQuery.textContent = getQuery();
    if (countNumber) countNumber.textContent = '0';
  }

  function showError() {
    hideAllStates();
    errorState?.classList.remove('hidden');
  }

  function showResults() {
    hideAllStates();
    searchResults?.classList.remove('hidden');
    searchInfo?.classList.remove('hidden');
    if (queryDisplay) queryDisplay.textContent = getQuery();
  }

  // ── Unified Fuse.js search ──
  // Fetches the live per-language search index covering products, blog posts,
  // landing pages and key static pages. New content is picked up instantly in
  // dev mode via Astro HMR.
  async function initFuse() {
    try {
      const res = await fetch(`/api/search-index/${lang}.json`, { cache: 'no-store' });
      if (!res.ok) throw new Error(`Failed to fetch search index: ${res.status}`);
      const items = await res.json();

      fuse = new Fuse(items, {
        keys: [
          { name: 'itemNo',      weight: 0.40 },
          { name: 'slug',        weight: 0.30 },
          { name: 'title',       weight: 0.20 },
          { name: 'keywords',    weight: 0.05 },
          { name: 'description', weight: 0.05 },
        ],
        threshold: 0.4,
        includeScore: true,
        ignoreLocation: true,
        minMatchCharLength: 2,
      });
      // Keep raw items for the substring pre-filter
      fuse._items = items;
      return true;
    } catch (err) {
      console.error('Failed to initialize search:', err);
      return false;
    }
  }

  // Guarantee product-code substring matches always appear
  function substringFilter(items, q) {
    const lower = q.toLowerCase().replace(/\s+/g, '');
    return items.filter(item => {
      const itemNo = (item.itemNo || '').toLowerCase().replace(/\s+/g, '');
      const slug   = (item.slug   || '').toLowerCase().replace(/-/g, '');
      const title  = (item.title  || '').toLowerCase();
      return itemNo.includes(lower) || slug.includes(lower) || title.includes(lower);
    });
  }

  async function performSearch(searchQuery) {
    if (!searchQuery) {
      showEmpty();
      return;
    }

    showLoading();

    try {
      if (!fuse) {
        const initSuccess = await initFuse();
        if (!initSuccess) {
          showError();
          return;
        }
      }

      // 1. Guaranteed substring matches (always included)
      const rawItems = fuse._items || [];
      const subMatches = substringFilter(rawItems, searchQuery);
      const subMatchUrls = new Set(subMatches.map(i => i.url));

      // 2. Fuse fuzzy matches
      const fuseResults = fuse.search(searchQuery).map(r => r.item);

      // 3. Merge: substring matches first, then additional Fuse results
      const merged = [...subMatches];
      for (const item of fuseResults) {
        if (!subMatchUrls.has(item.url)) {
          merged.push(item);
        }
      }

      if (merged.length === 0) {
        showNoResults();
        return;
      }

      allResults = merged;

      if (countNumber) {
        countNumber.textContent = allResults.length.toString();
      }

      renderPage(1);
      showResults();

    } catch (error) {
      console.error('Search error:', error);
      showError();
    }
  }

  function createResultCard(data) {
    const url = data.url || '#';
    const title = data.title || 'Untitled';
    const type = data.type || 'product';
    const viewDetails = viewDetailsText[lang] || viewDetailsText['en'];

    // ── Product Card (image + itemNo badge) ────────────────────────────────────
    if (type === 'product') {
      const itemNo = data.itemNo || '';
      const image = data.image || null;
      const imageContent = image
        ? `<img src="${image}" alt="${title}" class="src-img" />`
        : `<div class="src-img-placeholder">
             <svg style="width:3rem;height:3rem;color:#9ca3af" fill="none" stroke="currentColor" viewBox="0 0 24 24">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                 d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
             </svg>
           </div>`;
      return `
        <a href="${url}" class="src-card">
          <div class="src-card-inner">
            <div class="src-img-wrap">
              ${imageContent}
              <div class="src-overlay">
                <span class="src-overlay-pill">
                  ${viewDetails}
                  <svg class="src-arrow" style="width:1rem;height:1rem" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </div>
            </div>
            <div class="src-info">
              ${itemNo ? `<p class="src-item-no">${itemNo}</p>` : ''}
              <h3 class="src-title">${title}</h3>
            </div>
          </div>
        </a>`;
    }

    // ── Blog / Page Card (branded logo placeholder + description snippet) ────────
    const desc = data.description || '';
    const image = data.image || null;
    const isPage = type === 'page';
    const kssmiLogo = `
      <div style="
        display:flex;flex-direction:column;align-items:center;justify-content:center;
        gap:4px;padding:1rem;
      ">
        <span style="
          font-size:1.6rem;font-weight:800;color:#503629;
          letter-spacing:0.15em;text-transform:uppercase;line-height:1;
        ">KSSMI</span>
        <span style="height:2px;width:2.5rem;background:#503629;display:block;"></span>
        <span style="
          font-size:0.5rem;font-weight:700;color:#503629;
          letter-spacing:0.25em;text-transform:uppercase;margin-top:2px;
        ">${isPage ? 'PAGE' : 'ARTICLE'}</span>
      </div>
    `;
    const imageContent = image
      ? `<img src="${image}" alt="${title}" class="src-img" />`
      : `<div class="src-img-placeholder" style="background:#faf8f5;">${kssmiLogo}</div>`;
    return `
      <a href="${url}" class="src-card">
        <div class="src-card-inner">
          <div class="src-img-wrap">
            ${imageContent}
            <div class="src-overlay">
              <span class="src-overlay-pill">
                ${viewDetails}
                <svg class="src-arrow" style="width:1rem;height:1rem" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </div>
          <div class="src-info">
            <h3 class="src-title" style="-webkit-line-clamp:1">${title}</h3>
            ${desc ? `<p style="font-size:0.72rem;color:#6b7280;margin-top:0.2rem;line-height:1.3;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden">${desc}</p>` : ''}
          </div>
        </div>
      </a>`;
  }

  function renderPage(page) {
    currentPage = page;
    const startIndex = (page - 1) * RESULTS_PER_PAGE;
    const endIndex = startIndex + RESULTS_PER_PAGE;
    const pageResults = allResults.slice(startIndex, endIndex);

    if (searchResults) {
      searchResults.innerHTML = pageResults.map(data => createResultCard(data)).join('');
    }
    renderPagination();
  }

  function renderPagination() {
    const totalPages = Math.ceil(allResults.length / RESULTS_PER_PAGE);

    if (totalPages <= 1) {
      pagination?.classList.add('hidden');
      return;
    }

    pagination?.classList.remove('hidden');
    if (!paginationContainer) return;

    let paginationHTML = '';

    // Previous button
    if (currentPage > 1) {
      paginationHTML += `
        <button class="page-numbers" data-page="${currentPage - 1}">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        </button>
      `;
    }

    // Page numbers
    for (let i = 1; i <= totalPages; i++) {
      if (i === currentPage) {
        paginationHTML += `<button class="page-numbers current" data-page="${i}">${i}</button>`;
      } else if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
        paginationHTML += `<button class="page-numbers" data-page="${i}">${i}</button>`;
      } else if (i === currentPage - 2 || i === currentPage + 2) {
        paginationHTML += `<span class="page-numbers" style="border:none;background:none;box-shadow:none;cursor:default;color:#9ca3af;">...</span>`;
      }
    }

    // Next button
    if (currentPage < totalPages) {
      paginationHTML += `
        <button class="page-numbers" data-page="${currentPage + 1}">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </button>
      `;
    }

    paginationContainer.innerHTML = paginationHTML;

    // Add click handlers
    paginationContainer.querySelectorAll('button[data-page]').forEach(btn => {
      btn.addEventListener('click', () => {
        const page = parseInt(btn.getAttribute('data-page') || '1');
        renderPage(page);
        // Scroll to top of results
        searchResults?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  }

  // Intercept mid-page search form submission
  const searchForm = searchInput?.closest('form');
  if (searchForm) {
    searchForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const newQuery = searchInput?.value.trim() || '';
      if (newQuery) {
        const newUrl = new URL(window.location.href);
        newUrl.searchParams.set('q', newQuery);
        history.pushState({}, '', newUrl.toString());
        performSearch(newQuery);
      } else {
        showEmpty();
      }
    });
  }

  // Run search on page load if query exists in URL
  const initialQuery = getQuery();
  if (initialQuery) {
    performSearch(initialQuery);
  } else {
    showEmpty();
  }
  }); // End astro:page-load
</script>

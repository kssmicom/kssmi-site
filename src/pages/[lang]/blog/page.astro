---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { translations } from '../../../translations';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

export async function getStaticPaths() {
  let allPosts = [];
  try {
    const maybePosts = await getCollection('blog');
    if (maybePosts) allPosts = maybePosts;
  } catch (e) {
    // Collection might be empty or missing during initial setup
    console.warn(`Blog collection empty or missing: ${e}`);
  }
  const languages = ['en', 'it', 'es', 'fr', 'de', 'pt', 'ru', 'ja', 'tr', 'ar'];

  return languages.map((lang) => {
    const langPosts = allPosts.filter((post) => {
      const postLang = post.data.lang || 'en';
      return postLang === lang;
    });

    return {
      params: { lang },
      props: { posts: langPosts, lang }  // Pass lang in props too!
    };
  });
}

const { posts, lang } = Astro.props;

const t = translations[lang] || translations.en;
const currentPath = lang === 'en' ? '' : `${lang}/`;
---

<Layout title={t.nav.blog} lang={lang}>
  <Header lang={lang} />

  <!-- LAYER 1: WRAPPER -->
  <main class="w-full min-h-screen py-12 lg:py-20 border-b border-stone-100 relative z-10">
    <!-- LAYER 2: CONSTRAINT -->
    <div class="w-[94%] lg:w-[90%] 2xl:w-[85%] max-w-[1800px] mx-auto">
      <!-- LAYER 3: BLOCK -->
      <h1 class="text-4xl md:text-5xl font-bold mb-12 text-center">{t.nav.blog}</h1>

      <!-- Blog Grid -->
      {posts.length === 0 ? (
        <div class="text-center py-12">
          <p class="text-gray-600">No blog posts yet. Check back soon!</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {posts.map((post) => (
            <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-200">
              <a href={`/${currentPath}blog/${post.slug}`} class="block">
                {post.data.image && (
                  <div class="relative aspect-[16/9] overflow-hidden bg-gray-100">
                    <img
                      src={post.data.image}
                      alt={post.title}
                      class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                )}

                <div class="p-6">
                  <div class="text-sm text-gray-500 mb-2">
                    {post.data.published && new Date(post.data.published).toLocaleDateString(lang, {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </div>

                  <h2 class="text-xl font-semibold text-gray-900 mb-3 line-clamp-2 hover:text-[#8B7355] transition-colors">
                    {post.title}
                  </h2>

                  {post.data.excerpt && (
                    <p class="text-gray-600 mb-4 line-clamp-3">
                      {post.data.excerpt}
                    </p>
                  )}

                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2">
                      {post.data.tags.slice(0, 3).map(tag => (
                        <span class="px-3 py-1 bg-stone-100 text-stone-600 text-xs rounded-full">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            </article>
          ))}
        </div>
      )}
    </div>
  </main>

  <Footer lang={lang} />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

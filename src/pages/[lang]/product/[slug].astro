---
/**
 * Product Detail Page
 * Enhanced version with all sections matching kssmi.com reference
 * Includes: Breadcrumb, Hero, Technical Specs, CTA, Inquiry Form, Related Products
 */

import { getCollection, render } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../../../layouts/Layout.astro';
import { translations } from '../../../translations';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import TechnicalSpecs from '../../../components/TechnicalSpecs.astro';
import InquiryForm from '../../../components/InquiryForm.astro';
import RelatedProducts from '../../../components/RelatedProducts.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products
    .filter(product => {
      // Extract lang from file ID (e.g., "ks001.en" -> "en")
      const parts = product.id.split('.');
      const lang = parts.length > 1 ? parts.pop() : 'en';
      // Skip English - it's handled by root /product/[slug].astro
      return lang !== 'en';
    })
    .map(product => {
      // Extract lang from file ID (e.g., "ks001.it" -> "it")
      const parts = product.id.split('.');
      const lang = parts.pop();
      // Use slug from frontmatter
      const slug = (product.data.slug || 'product').toLowerCase();

      return {
        params: { lang, slug },
        props: { product, lang },
      };
    });
}

const { product } = Astro.props;
const { lang: langParam, slug } = Astro.params;
const lang = langParam || 'en';

let { cover, gallery } = product.data;
const {
  title,
  videoId,
  materials,
  moq,
  categories,
  itemNo,
  colors,
  serviceMode,
  customizable,
  seoTitle,
  seoDescription,
  seoKeywords,
  size,
  frameMaterial,
  lensMaterial,
  designStyle,
  nosePads,
  hinge,
  electroplating,
  logo,
  carbonFiberFeature,
} = product.data;

// Dynamically load gallery images from the public directory
const imageSlug = product.data.slug?.replace(/\/$/, '') || 'product';
const publicDir = path.join(process.cwd(), 'public', 'media', 'products', imageSlug);

if (fs.existsSync(publicDir)) {
  const allImages = fs.readdirSync(publicDir)
    .filter(file => file.endsWith('.webp') || file.endsWith('.jpg') || file.endsWith('.png'))
    .sort((a, b) => {
      const numA = parseInt(a.match(/-(\d+)\.\w+$/)?.[1] || '0', 10);
      const numB = parseInt(b.match(/-(\d+)\.\w+$/)?.[1] || '0', 10);
      return numA - numB;
    })
    .map(file => `/media/products/${imageSlug}/${file}`);

  if (allImages.length > 0) {
    cover = allImages[0];
    gallery = allImages.slice(1);
  }
}

const cats = categories ? categories.split(',').map(s => s.trim()) : [];
// Render markdown body using render()
const { Content: ProductContent } = await render(product);

// Get translation data
const t = translations[lang as keyof typeof translations] || translations.en;
const pt = t.product || {};
const currentPath = lang === 'en' ? '' : `${lang}/`;
const isRTL = lang === 'ar';

// Dynamically find category translations without hardcoding
function getCategoryKey(cat: string): string | undefined {
  const normCat = cat.toLowerCase().trim();
  const enNav = translations.en.nav;
  return Object.keys(enNav).find(key => 
    enNav[key].toLowerCase() === normCat || 
    enNav[key].toLowerCase().replace(/\s+/g, '-') === normCat.replace(/\s+/g, '-')
  );
}

function getCategoryLabel(cat: string): string {
  const enKey = getCategoryKey(cat);
  if (enKey && (t.nav as any)[enKey]) return (t.nav as any)[enKey];
  return cat;
}

function getCategorySlug(cat: string): string {
  const enKey = getCategoryKey(cat);
  const enNav = translations.en.nav;
  if (enKey && (enNav as any)[enKey]) return (enNav as any)[enKey].toLowerCase().replace(/\s+/g, '-');
  return cat.toLowerCase().trim().replace(/\s+/g, '-');
}

// Build breadcrumb items
const breadcrumbItems = [
  { label: t.nav.home, href: `/${currentPath}` },
  { label: t.nav.products || 'Product', href: `/${currentPath}product` },
  ...(cats.length > 0
    ? [{
        label: getCategoryLabel(cats[0]),
        href: `/${currentPath}product/${getCategorySlug(cats[0])}`
      }]
    : []),
  ...(cats.length > 1
    ? [{
        label: getCategoryLabel(cats[1]),
        href: `/${currentPath}product/${getCategorySlug(cats[1])}`
      }]
    : [])
];

// Generate AdditionalProperties for Schema using localized labels
const schemaSpecs: any[] = [];
if (itemNo) schemaSpecs.push({ "@type": "PropertyValue", "name": pt.itemNo || "Item Number", "value": itemNo });
if (moq) schemaSpecs.push({ "@type": "PropertyValue", "name": pt.moq || "MOQ", "value": moq });
if (serviceMode) schemaSpecs.push({ "@type": "PropertyValue", "name": pt.service || "Service Mode", "value": serviceMode });
if (customizable) schemaSpecs.push({ "@type": "PropertyValue", "name": pt.customizable || "Customizable", "value": "Yes" });

const ignoreSchemaKeys = new Set([
  'title', 'slug', 'cover', 'gallery', 'videoId', 'itemNo', 'colors', 
  'price', 'customizable', 'materials', 'featured', 'categories', 'date', 
  'seoTitle', 'seoDescription', 'seoKeywords', 'serviceMode', 'moq'
]);

function formatSchemaKey(key: string): string {
  const camelKey = key.replace(/(?:^\w|[A-Z]|\b\w)/g, (w, i) => i === 0 ? w.toLowerCase() : w.toUpperCase()).replace(/\s+/g, '');
  
  if ((pt as any)[camelKey]) return (pt as any)[camelKey];
  if ((pt as any)[key]) return (pt as any)[key];

  // Fallback: title case camelCase (e.g. acetateFeature -> Acetate Feature)
  if (/^[a-z]+[A-Z][a-zA-Z]*$/.test(key)) {
    return key.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase()).trim();
  }
  return key;
}

for (const [k, v] of Object.entries(product.data)) {
  if (ignoreSchemaKeys.has(k)) continue;
  if (v === undefined || v === null || v === '') continue;

  const name = formatSchemaKey(k);
  const value = Array.isArray(v) ? v.join(', ') : String(v);
  schemaSpecs.push({ "@type": "PropertyValue", "name": name, "value": value });
}

// Generate Product Schema for SEO
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": title,
  "image": cover ? (cover.startsWith('http') ? cover : `${Astro.site?.href.replace(/\/$/, '') || ''}${cover}`) : "",
  "description": seoDescription || title,
  "sku": itemNo,
  "mpn": itemNo,
  "brand": {
    "@type": "Brand",
    "@id": `${Astro.site?.href.replace(/\/$/, '') || ''}/#organization`,
    "name": "Kssmi Eyewear"
  },
  "manufacturer": {
    "@type": "Organization",
    "@id": `${Astro.site?.href.replace(/\/$/, '') || ''}/#organization`,
    "name": "Kssmi Eyewear"
  },
  "material": materials,
  "color": colors,
  "category": cats.length > 0 ? cats[0] : undefined,
  "additionalProperty": schemaSpecs,
  "audience": {
    "@type": "Audience",
    "audienceType": "Retailers, Brands, Wholesale"
  },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "price": "0",
    "priceValidUntil": new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString().split('T')[0],
    "seller": {
      "@type": "Organization",
      "@id": `${Astro.site?.href.replace(/\/$/, '') || ''}/#organization`,
      "name": "Kssmi Eyewear"
    }
  }
};

// Generate VideoObject Schema if video exists
let videoSchema = null;
if (videoId) {
  videoSchema = {
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": title,
    "description": seoDescription || title,
    "thumbnailUrl": [cover],
    "uploadDate": product.data.date || new Date().toISOString(),
    "contentUrl": `https://play.gumlet.io/embed/${videoId}`,
    "embedUrl": `https://play.gumlet.io/embed/${videoId}`
  };
}

// Parse 'customizable' dynamically; default to English fallback if translator didn't provide one
const badgeLabel = pt.customizableBadge || pt.customizable || (typeof customizable === 'string' ? customizable : 'Customizable');

// Helper to generate alt text from image URL
function getAltText(url: string | undefined, fallback: string): string {
  if (!url) return fallback;
  const filename = url.split('/').pop() || '';
  const withoutExt = filename.replace(/\.[^/.]+$/, '');
  if (!withoutExt) return fallback;
  return withoutExt.replace(/-/g, ' ');
}
---

<Layout
  title={seoTitle || title}
  description={seoDescription}
  keywords={seoKeywords}
  lang={lang}
  image={cover}
>
  <!-- Schema for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  {videoSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(videoSchema)} />
  )}

  {/* Pagefind metadata for better search indexing */}
  <div class="sr-only" data-pagefind-meta="title">{title}</div>
  {itemNo && <div class="sr-only" data-pagefind-meta="itemNo">{itemNo}</div>}
  {itemNo && <div class="sr-only" data-pagefind-weight="10">{itemNo}</div>}
  {materials && <div class="sr-only" data-pagefind-meta="materials">{materials}</div>}
  {colors && <div class="sr-only" data-pagefind-meta="colors">{colors}</div>}
  {categories && <div class="sr-only" data-pagefind-meta="category">{categories}</div>}
  {cover && <img src={cover} alt={title} data-pagefind-meta="image" class="sr-only" />}

  <Header lang={lang} />

  <main id="main-content" tabindex="-1" data-pagefind-body="true" class="focus:outline-none">
    {/* Pagefind anchor for better excerpt */}
    <div id="pagefind-content" class="contents">
    <!-- SECTION 1: Breadcrumb Navigation -->
    <Breadcrumb items={breadcrumbItems} lang={lang} />

    <!-- SECTION 2: Product Hero -->
    <section class="py-12 lg:py-16 bg-stone-50">
      <div class="w-[94%] lg:w-[90%] 2xl:w-[85%] max-w-[1800px] mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">

          <!-- Image Gallery Column - Centered -->
          <div class="space-y-4 flex flex-col items-center">
            <!-- Main Image with Magnifier Zoom Effect -->
            <div class="relative aspect-square bg-gray-50 rounded-xl overflow-hidden shadow-lg w-full max-w-[500px]">
              {cover ? (
                <div
                  id="image-zoom-container"
                  class="w-full h-full cursor-zoom-in"
                >
                  <img
                    id="main-image"
                    src={cover}
                    alt={getAltText(cover, title)}
                    class="w-full h-full object-cover"
                    decoding="async"
                  />
                </div>
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <svg class="w-24 h-24 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              )}

              <!-- Badge - Customizable -->
              {customizable && (
                <div class="absolute top-4 start-4 z-10">
                  <span class="bg-[#8B7355] text-white text-xs font-semibold px-3 py-1 rounded-full shadow-md">
                    {badgeLabel}
                  </span>
                </div>
              )}
            </div>

            <!-- Gallery Thumbnails – all devices, every row centered -->
            <!-- max-w-[640px] = 9 × 64px + 8 × 8px gap = 640px; wider than the 500px main image -->
            <!-- Rows/device: phone ~4, tablet ~8, laptop ~8, desktop ~9 -->
            <div class="flex flex-wrap justify-center gap-2 w-full max-w-[640px] mx-auto">
              {cover && (
                <button
                  class="thumb flex-none w-16 h-16 rounded-lg overflow-hidden border-2 border-[#8B7355] shadow-sm hover:shadow-md transition-shadow"
                  aria-label={getAltText(cover, "View main image")}
                >
                  <img src={cover} alt={getAltText(cover, "Main")} class="w-full h-full object-cover" decoding="async" />
                </button>
              )}
              {gallery?.map((img, index) => (
                <button
                  class="thumb flex-none w-16 h-16 rounded-lg overflow-hidden border-2 border-transparent hover:border-[#8B7355] shadow-sm hover:shadow-md transition-all"
                  aria-label={getAltText(img, `View gallery image ${index + 1}`)}
                >
                  <img src={img} alt={getAltText(img, `Gallery ${index + 1}`)} loading="lazy" class="w-full h-full object-cover" decoding="async" />
                </button>
              ))}
            </div>

            <!-- Video Embed (if available) -->
            {videoId && (
              <div class="aspect-video bg-gray-900 rounded-xl overflow-hidden shadow-lg w-full max-w-[500px]">
                <iframe
                  src={`https://play.gumlet.io/embed/${videoId}`}
                  title={`${title} - Product Video`}
                  class="w-full h-full"
                  allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture"
                  allowfullscreen
                ></iframe>
              </div>
            )}
          </div>

          <!-- Product Info Column -->
          <div class="lg:py-4" dir={isRTL ? 'rtl' : 'ltr'}>
            <!-- Collection Label -->
            {categories && (
              <p class="text-sm text-[#8B7355] font-medium uppercase tracking-wider mb-2">
                - Kssmi Collection
              </p>
            )}

            <!-- Product Title - Smaller (2/3 size) -->
            <h1 class="text-2xl lg:text-3xl font-bold mb-6 text-gray-900">
              {title}
            </h1>

            <!-- Quick Specs - Left Aligned -->
            <div class="border-y border-gray-200 py-6 mb-6 space-y-3">
              {itemNo && (
                <div class="flex items-start gap-2">
                  <span class="text-sm text-gray-500 min-w-[160px]">{pt.itemNo || 'Item No'}:</span>
                  <span class="text-sm font-medium text-gray-900">{itemNo}</span>
                </div>
              )}

              {colors && (
                <div class="flex items-start gap-2">
                  <span class="text-sm text-gray-500 min-w-[160px]">{pt.color || 'Color'}:</span>
                  <span class="text-sm font-medium text-gray-900">{colors}</span>
                </div>
              )}

              {materials && (
                <div class="flex items-start gap-2">
                  <span class="text-sm text-gray-500 min-w-[160px]">{pt.materials || 'Materials'}:</span>
                  <span class="text-sm font-medium text-gray-900">{materials}</span>
                </div>
              )}

              <div class="flex items-start gap-2">
                <span class="text-sm text-gray-500 min-w-[160px]">{pt.serviceMode || 'Service Mode'}:</span>
                <span class="text-sm font-medium text-gray-900">
                  {serviceMode || 'OEM & ODM'}
                </span>
              </div>

              <div class="flex items-start gap-2">
                <span class="text-sm text-gray-500 min-w-[160px]">{pt.moq || 'MOQ'}:</span>
                <span class="text-sm font-medium text-gray-900">{moq || '100 PCS/Model'}</span>
              </div>

            </div>



            <!-- CTA Buttons -->
            <div class="flex flex-wrap gap-4 mb-8">
              <a
                href={`/${currentPath}quote`}
                class="flex-1 min-w-[200px] bg-[#8B7355] text-white px-6 py-4 rounded-lg font-semibold
                       hover:bg-[#5D4E37] active:bg-[#4a4030] transition-colors duration-200
                       text-center flex items-center justify-center gap-2"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                {t.cta.quote}
              </a>
              <a
                href={`/${currentPath}product`}
                class="flex-1 min-w-[200px] border-2 border-[#8B7355] text-[#8B7355] px-6 py-4 rounded-lg font-semibold
                       hover:bg-[#8B7355] hover:text-white transition-colors duration-200
                       text-center flex items-center justify-center gap-2"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                {pt.backToCatalog}
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 3: Technical Specifications with Highlights -->
    <TechnicalSpecs product={product} lang={lang}>
      <ProductContent slot="highlights" />
    </TechnicalSpecs>

    <!-- SECTION 4: CTA Banner -->
    <section class="py-16 lg:py-20 bg-gradient-to-r from-[#8B7355] to-[#5D4E37] text-white">
      <div class="w-[94%] lg:w-[90%] 2xl:w-[85%] max-w-[1800px] mx-auto px-4">
        <div class="text-center mb-10">
          <h2 class="text-2xl lg:text-3xl font-bold mb-4">
            {pt.partnerTitle}
          </h2>
          <p class="text-lg text-white/90 max-w-3xl mx-auto">
            {pt.partnerDesc}
          </p>
        </div>

        <!-- Benefits Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          <div class="flex items-start gap-3 bg-white/10 backdrop-blur-sm rounded-lg p-4 transition-all duration-300 hover:-translate-y-1 hover:bg-white/20 hover:shadow-lg hover:shadow-black/20 cursor-default group">
            <svg class="w-5 h-5 mt-0.5 text-amber-300 shrink-0 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm text-white/95">{pt.benefit1}</span>
          </div>
          <div class="flex items-start gap-3 bg-white/10 backdrop-blur-sm rounded-lg p-4 transition-all duration-300 hover:-translate-y-1 hover:bg-white/20 hover:shadow-lg hover:shadow-black/20 cursor-default group">
            <svg class="w-5 h-5 mt-0.5 text-amber-300 shrink-0 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm text-white/95">{pt.benefit2}</span>
          </div>
          <div class="flex items-start gap-3 bg-white/10 backdrop-blur-sm rounded-lg p-4 transition-all duration-300 hover:-translate-y-1 hover:bg-white/20 hover:shadow-lg hover:shadow-black/20 cursor-default group">
            <svg class="w-5 h-5 mt-0.5 text-amber-300 shrink-0 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm text-white/95">{pt.benefit3}</span>
          </div>
          <div class="flex items-start gap-3 bg-white/10 backdrop-blur-sm rounded-lg p-4 transition-all duration-300 hover:-translate-y-1 hover:bg-white/20 hover:shadow-lg hover:shadow-black/20 cursor-default group">
            <svg class="w-5 h-5 mt-0.5 text-amber-300 shrink-0 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm text-white/95">{pt.benefit4}</span>
          </div>
          <div class="flex items-start gap-3 bg-white/10 backdrop-blur-sm rounded-lg p-4 transition-all duration-300 hover:-translate-y-1 hover:bg-white/20 hover:shadow-lg hover:shadow-black/20 cursor-default group">
            <svg class="w-5 h-5 mt-0.5 text-amber-300 shrink-0 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm text-white/95">{pt.benefit5}</span>
          </div>
          <div class="flex items-start gap-3 bg-white/10 backdrop-blur-sm rounded-lg p-4 transition-all duration-300 hover:-translate-y-1 hover:bg-white/20 hover:shadow-lg hover:shadow-black/20 cursor-default group">
            <svg class="w-5 h-5 mt-0.5 text-amber-300 shrink-0 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm text-white/95">{pt.benefit6}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 5: Inquiry Form -->
    <InquiryForm lang={lang} productName={title} />

    <!-- SECTION 6: Related Products -->
    <RelatedProducts
      currentProductId={product.id}
      lang={lang}
      limit={4}
    />
    </div>{/* End data-pagefind-body */}
  </main>

  <Footer lang={lang} />
</Layout>

<script>
  function initGallery() {
    const mainImage = document.getElementById('main-image') as HTMLImageElement;
    const zoomContainer = document.getElementById('image-zoom-container');

    if (!mainImage) return;

    // Use event delegation for thumbnail clicks - attach to parent container
    const thumbsParent = document.querySelector('.space-y-4.flex.flex-col.items-center');
    if (thumbsParent) {
      thumbsParent.addEventListener('click', (e: Event) => {
        const target = e.target as HTMLElement;
        const thumb = target.closest('.thumb') as HTMLElement;

        if (thumb) {
          const thumbImg = thumb.querySelector('img') as HTMLImageElement;
          if (thumbImg && mainImage) {
            mainImage.src = thumbImg.src;
            mainImage.srcset = thumbImg.srcset || '';
            mainImage.sizes = thumbImg.sizes || '';
            mainImage.style.transform = 'scale(1)';

            // Update active state
            document.querySelectorAll('.thumb').forEach(t => {
              t.classList.remove('border-[#8B7355]');
              t.classList.add('border-transparent');
            });
            thumb.classList.remove('border-transparent');
            thumb.classList.add('border-[#8B7355]');
          }
        }
      });
    }

    // Magnifier zoom effect
    if (zoomContainer) {
      zoomContainer.addEventListener('mouseenter', () => {
        mainImage.style.transform = 'scale(2)';
        mainImage.style.transition = 'transform 0.1s ease-out';
        mainImage.style.transformOrigin = 'center center';
      });

      zoomContainer.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = zoomContainer.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        mainImage.style.transformOrigin = `${x}% ${y}%`;
      });

      zoomContainer.addEventListener('mouseleave', () => {
        mainImage.style.transform = 'scale(1)';
      });
    }
  }

  // Run on initial load
  initGallery();

  // Run after View Transitions navigation
  document.addEventListener('astro:page-load', initGallery);
</script>

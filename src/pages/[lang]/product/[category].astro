---
/**
 * Category Page (Multilingual)
 * Displays products filtered by a specific category
 * URL format: /[lang]/product/[category-slug] (e.g., /ko/product/luxury-glasses)
 *
 * IMPORTANT: All category URLs use English slugs for consistency across languages.
 * Products may have translated category names, but they map to English slugs.
 */

import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import ProductCard from '../../../components/ProductCard.astro';
import { translations } from '../../../translations';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

export async function getStaticPaths() {
  // Canonical English category slugs - these are the URL slugs used across ALL languages
  const CANONICAL_CATEGORIES = [
    'luxury-customized',
    'luxury-glasses',
    'luxury-sunglasses',
    'high-couture-series',
    'high-couture-sunglasses',
    'high-couture-glasses',
    'classics-series',
    'classics-sunglasses',
    'classics-glasses',
    'fashion-series',
    'acetate-sunglasses',
    'metal-sunglasses',
    'metal-glasses',
    'titanium-sunglasses',
    'titanium-glasses',
    'optical-frames',
    'sunglasses',
    'metal',
    'acetate',
    'titanium',
    'luxury',
    'fashion',
  ];

  // Category translation mapping: maps translated category names to English slugs
  // These MUST match the exact translations used in the product markdown files
  const CATEGORY_MAP: Record<string, string> = {
    // English
    'luxury customized': 'luxury-customized',
    'luxury glasses': 'luxury-glasses',
    // Italian
    'lusso personalizzato': 'luxury-customized',
    'occhiali di lusso': 'luxury-glasses',
    // Spanish
    'lujo personalizado': 'luxury-customized',
    'gafas de lujo': 'luxury-glasses',
    // French
    'luxe personnalisé': 'luxury-customized',
    'lunettes de luxe': 'luxury-glasses',
    // German
    'luxus maßgeschneidert': 'luxury-customized',
    'luxusbrillen': 'luxury-glasses',
    // Portuguese
    'luxo personalizado': 'luxury-customized',
    'óculos de luxo': 'luxury-glasses',
    // Russian
    'индивидуальная роскошь': 'luxury-customized',
    'роскошные очки': 'luxury-glasses',
    // Japanese
    '高級カスタマイズ': 'luxury-customized',
    '高級メガネ': 'luxury-glasses',
    // Turkish
    'özel lüks': 'luxury-customized',
    'lüks gözlükler': 'luxury-glasses',
    // Arabic
    'فخامة مخصصة': 'luxury-customized',
    'نظارات فاخرة': 'luxury-glasses',
    // Korean
    '럭셔리 맞춤형': 'luxury-customized',
    '럭셔리 안경': 'luxury-glasses',
    // Chinese
    '奢华定制': 'luxury-customized',
    '奢华光学镜': 'luxury-glasses',
    // Hindi
    'लक्ज़री कस्टमाइज़्ड': 'luxury-customized',
    'लक्ज़री चश्मा': 'luxury-glasses',
    // Vietnamese
    'sang trọng tùy chỉnh': 'luxury-customized',
    'kính quang học sang trọng': 'luxury-glasses',
    // Javanese
    'klasik mewah': 'luxury-customized',
    'kacamata kelas mewah': 'luxury-glasses',
    // Malay
    'tersuai mewah': 'luxury-customized',
    'cermin mata mewah': 'luxury-glasses',
    // Tajik
    'боҳашамати фармоишӣ': 'luxury-customized',
    'айнаки боҳашамат': 'luxury-glasses',
  };

  // Function to get canonical slug from any category name
  function getCanonicalSlug(categoryName: string): string {
    const normalized = categoryName.toLowerCase().trim();
    return CATEGORY_MAP[normalized] || normalized.replace(/\s+/g, '-');
  }

  const allProducts = await getCollection('products');
  const languages = ['en', 'it', 'es', 'fr', 'de', 'pt', 'ru', 'ja', 'tr', 'ar', 'ko', 'zh', 'hi', 'vi', 'jv', 'ms', 'tg'];

  const paths = [];

  // For each language, create pages for all canonical categories
  for (const lang of languages) {
    // Get all products in this language
    const langProducts = allProducts.filter(p => {
      const parts = p.id.split('.');
      const pLang = parts.length > 1 ? parts.pop() : 'en';
      return pLang === lang;
    });

    // For each canonical category, find matching products
    for (const canonicalSlug of CANONICAL_CATEGORIES) {
      // Find products that map to this canonical category
      const categoryProducts = langProducts.filter(p => {
        return p.data.categories?.some(cat => {
          const slug = getCanonicalSlug(cat);
          return slug === canonicalSlug;
        });
      });

      // Create page if there are products
      if (categoryProducts.length > 0) {
        paths.push({
          params: { lang, category: canonicalSlug },
          props: { products: categoryProducts, categorySlug: canonicalSlug, lang }
        });
      }
    }
  }

  return paths;
}

const { products, categorySlug, lang } = Astro.props;
const t = translations[lang] || translations.en;
const currentPath = `${lang}/`;
const isRTL = lang === 'ar';

// Format category name for display (convert slug back to title case)
const categoryTitle = categorySlug
  .split('-')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ');

// Get product translations
const pt = t.product || {
  viewAllCollections: "View All Collections",
  productsInCategory: "products in this category",
  allProducts: "All Products",
};

// Get all products for count
const allProducts = await getCollection('products');
const langProducts = allProducts.filter((product) => {
  const parts = product.id.split('.');
  const productLang = parts.length > 1 ? parts.pop() : 'en';
  return productLang === lang;
});

// Sidebar Categories - Matches Header Mega Menu Structure
const sidebarCategories = [
  {
    label: t.nav.luxury,
    href: `/${currentPath}product/luxury-customized`,
    items: [
      { label: t.nav.luxury_sunglasses, href: `/${currentPath}product/luxury-sunglasses` },
      { label: t.nav.luxury_glasses, href: `/${currentPath}product/luxury-glasses` }
    ]
  },
  {
    label: t.nav.couture,
    href: `/${currentPath}product/high-couture-series`,
    items: [
      { label: t.nav.couture_sunglasses, href: `/${currentPath}product/high-couture-sunglasses` },
      { label: t.nav.couture_glasses, href: `/${currentPath}product/high-couture-glasses` }
    ]
  },
  {
    label: t.nav.classics,
    href: `/${currentPath}product/classics-series`,
    items: [
      { label: t.nav.classics_sunglasses, href: `/${currentPath}product/classics-sunglasses` },
      { label: t.nav.classics_glasses, href: `/${currentPath}product/classics-glasses` }
    ]
  },
  {
    label: t.nav.fashion,
    href: `/${currentPath}product/fashion-series`,
    items: [
      { label: t.nav.acetate_sun, href: `/${currentPath}product/acetate-sunglasses` },
      { label: t.nav.metal_sun, href: `/${currentPath}product/metal-sunglasses` },
      { label: t.nav.metal_glass, href: `/${currentPath}product/metal-glasses` },
      { label: t.nav.titanium_sun, href: `/${currentPath}product/titanium-sunglasses` },
      { label: t.nav.titanium_glass, href: `/${currentPath}product/titanium-glasses` }
    ]
  },
  {
    label: t.nav.rimless,
    href: `/${currentPath}product/rimless-series`,
    items: [
      { label: t.nav.rimless_sun, href: `/${currentPath}product/rimless-sunglasses` },
      { label: t.nav.rimless_glass, href: `/${currentPath}product/rimless-glasses` }
    ]
  },
  {
    label: t.nav.carbon,
    href: `/${currentPath}product/carbon-series`,
    items: [
      { label: t.nav.carbon_sun, href: `/${currentPath}product/carbon-sunglasses` },
      { label: t.nav.carbon_glass, href: `/${currentPath}product/carbon-glasses` }
    ]
  }
];

// Sort products: featured first, then by date
const sortedProducts = products.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
  const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
  return dateB - dateA;
});

// Check if current category matches any in sidebar
function isActiveCategory(href: string): boolean {
  const hrefSlug = href.replace(`/${currentPath}product/`, '');
  return hrefSlug === categorySlug;
}
---

<Layout title={`${categoryTitle} - ${t.nav.products}`} lang={lang}>
  <Header lang={lang} />

  <main class="w-full min-h-screen py-12 lg:py-16 bg-gray-50">
    <div class="w-[94%] lg:w-[90%] 2xl:w-[85%] max-w-[1800px] mx-auto px-4">
      <!-- Breadcrumb -->
      <nav class="mb-8 text-sm" dir={isRTL ? 'rtl' : 'ltr'}>
        <ol class="flex items-center flex-wrap gap-1">
          <li>
            <a href={`/${currentPath}`} class="text-gray-500 hover:text-[#8B7355] transition-colors">
              {t.nav.home}
            </a>
          </li>
          <li class="text-gray-300 mx-2">/</li>
          <li>
            <a href={`/${currentPath}product`} class="text-gray-500 hover:text-[#8B7355] transition-colors">
              {t.nav.products}
            </a>
          </li>
          {sidebarCategories.map(cat => {
            const currentSub = cat.items.find(sub => isActiveCategory(sub.href));
            if (isActiveCategory(cat.href) || currentSub) {
              return (
                <>
                  <li class="text-gray-300 mx-2">/</li>
                  <li>
                    {currentSub ? (
                      <a href={cat.href} class="text-gray-500 hover:text-[#8B7355] transition-colors">
                        {cat.label}
                      </a>
                    ) : (
                      <span class="text-[#8B7355] font-medium">{cat.label}</span>
                    )}
                  </li>
                  {currentSub && (
                    <>
                      <li class="text-gray-300 mx-2">/</li>
                      <li class="text-[#8B7355] font-medium">
                        {currentSub.label}
                      </li>
                    </>
                  )}
                </>
              );
            }
            return null;
          })}
        </ol>
      </nav>

      <!-- Page Header -->
      <div class="mb-10">
        <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-2">
          {categoryTitle}
        </h1>
        <p class="text-gray-600">
          {sortedProducts.length} {pt.productsInCategory || 'products in this category'}
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Sidebar: Category Filter (Hidden on mobile/tablet) -->
        <aside class="hidden lg:block lg:col-span-1">
          <div class="sticky top-24 space-y-6">
            <!-- Categories Card -->
            <div class="bg-gradient-to-br from-white to-[#faf8f5] rounded-xl shadow-sm p-6 border border-stone-200/50">
              <!-- All Products Link -->
              <a
                href={`/${currentPath}product`}
                class={`flex justify-between items-center py-2 px-3 rounded-lg mb-3 transition-colors ${
                  categorySlug === ''
                    ? 'bg-[#8B7355] text-white'
                    : 'text-gray-600 hover:bg-stone-50 hover:text-[#8B7355]'
                }`}
              >
                <span class="font-medium">{pt.allProducts || 'All Products'}</span>
                <span class={`text-xs px-2 py-1 rounded-full ${
                  categorySlug === '' ? 'bg-white/20' : 'bg-gray-100'
                }`}>
                  {langProducts.length}
                </span>
              </a>

              <!-- Category Groups with Sub-categories -->
              <div class="space-y-3">
                {sidebarCategories.map((cat) => (
                  <div class="border-b border-gray-100 pb-3 last:border-0 last:pb-0">
                    <!-- Main Category -->
                    <a
                      href={cat.href}
                      class={`flex items-center justify-between py-2 px-2 text-sm font-bold rounded-lg transition-colors ${
                        isActiveCategory(cat.href)
                          ? 'bg-[#8B7355] text-white'
                          : 'text-[#8B7355] hover:bg-stone-50'
                      }`}
                    >
                      <span>{cat.label}</span>
                      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                    <!-- Sub-categories -->
                    <ul class="ms-3 mt-1 space-y-1">
                      {cat.items.map((sub) => (
                        <li>
                          <a
                            href={sub.href}
                            class={`block py-1.5 px-2 text-sm rounded transition-colors ${
                              isActiveCategory(sub.href)
                                ? 'bg-[#8B7355] text-white'
                                : 'text-gray-600 hover:text-[#8B7355] hover:bg-stone-50'
                            }`}
                          >
                            {sub.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </div>

            <!-- CTA Card - Always visible below categories -->
            <div class="bg-[#8B7355] rounded-xl p-6 text-white">
              <h4 class="font-bold mb-2">{pt.needCustomEyewear || 'Need Custom Eyewear?'}</h4>
              <p class="text-sm text-white/80 mb-4">
                {pt.oemServices || 'We offer full OEM & ODM services for your brand.'}
              </p>
              <a
                href={`/${currentPath}quote`}
                class="inline-block bg-white text-[#8B7355] px-4 py-2 rounded-lg text-sm font-semibold hover:bg-gray-100 transition-colors"
              >
                {t.cta.quote || 'Get Quote'}
              </a>
            </div>
          </div>
        </aside>

        <!-- Product Grid -->
        <div class="col-span-1 lg:col-span-3">
          {sortedProducts.length === 0 ? (
            <div class="text-center py-16 bg-white rounded-xl shadow-sm">
              <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
              <p class="text-gray-500 mb-4">No products in this category.</p>
              <a
                href={`/${currentPath}product`}
                class="text-[#8B7355] hover:underline"
              >
                View All Products
              </a>
            </div>
          ) : (
            <>
              <!-- Products Grid -->
              <div class="grid grid-cols-2 xl:grid-cols-3 gap-4 xl:gap-6">
                {sortedProducts.map((product) => (
                  <ProductCard product={product} lang={lang} />
                ))}
              </div>
            </>
          )}
        </div>
      </div>

      <!-- Back to All Products -->
      <div class="mt-12 text-center">
        <a
          href={`/${currentPath}product`}
          class="inline-flex items-center gap-2 text-[#8B7355] hover:text-[#5D4E37] font-medium transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          {pt.viewAllCollections}
        </a>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>

---
/**
 * Products Listing Page
 * Displays all products with pagination (12 per page)
 * Includes category filter sidebar
 */

import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import ProductCard from '../../../components/ProductCard.astro';
import { translations } from '../../../translations';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import type { Page } from 'astro';
import { isCategoryMatch, getSlug } from '../../../utils/categoryMatching';

// Category translation mapping: maps translated category names to English slugs
// Function to get canonical slug from any category name
function getCanonicalSlug(categoryName: string): string {
  return getSlug(categoryName);
}

export async function getStaticPaths({ paginate }: { paginate: (data: any[], options: any) => any[] }) {
  const PAGE_SIZE = 12;
  const allProducts = await getCollection('products');
  // English is handled at root level, so exclude from [lang] routes
  const languages = Object.keys(translations).filter(lang => lang !== 'en');

  // Generate paginated pages for EACH language separately
  return languages.flatMap((lang) => {
    // Filter products for this specific language
    // ID format: "kso-001.en" -> extract "en" by splitting on "."
    const langProducts = allProducts.filter((product) => {
      const parts = product.id.split('.');
      const productLang = parts.length > 1 ? parts.pop() : 'en';
      return productLang === lang;
    });

    // Sort by featured and then by filename (ID) descending
    const sortedProducts = langProducts.sort((a, b) => {
      if (a.data.featured && !b.data.featured) return -1;
      if (!a.data.featured && b.data.featured) return 1;
      const dateA = (a.data as any).date ? new Date((a.data as any).date).getTime() : 0;
      const dateB = (b.data as any).date ? new Date((b.data as any).date).getTime() : 0;
      if (dateA !== dateB) return dateB - dateA;
      // Fallback to alphabetical sorting by ID in descending order (newer products have higher numbers)
      return b.id.localeCompare(a.id);
    });

    // Paginate ONLY this language's products
    return paginate(sortedProducts, {
      params: { lang },
      pageSize: PAGE_SIZE,
      props: { lang }
    });
  });
}

interface Props {
  page: Page<{
    id: string;
    data: {
      title: string;
      slug?: string;
      cover?: string;
      itemNo?: string;
      categories?: string | string[];
      featured?: boolean;
      [key: string]: any;
    };
  }>;
  lang: string;
}

const { page, lang } = Astro.props as Props;
const products = page.data;

const t = translations[lang as keyof typeof translations] || translations.en;
const currentPath = `${lang}/`;
const isRTL = lang === 'ar';

// Get all products for count
const allProducts = await getCollection('products');
const langProducts = allProducts.filter((product) => {
  const parts = product.id.split('.');
  const productLang = parts.length > 1 ? parts.pop() : 'en';
  return productLang === lang;
});

// Helper for category counts
function getCategoryCount(href: string): number {
  const targetSlug = href.split('/').pop() || '';
  return langProducts.filter(p => {
    const cats = p.data.series || '';
    return isCategoryMatch(cats, targetSlug);
  }).length;
}

// Primary Categories (Hierarchical) - matches English product/index.astro
const primaryCategories = [
  {
    label: t.sidebar.sunglasses,
    href: `/${currentPath}product/sunglasses`,
    items: [
      { label: t.sidebar.acetate_sunglasses, href: `/${currentPath}product/acetate-sunglasses` },
      { label: t.sidebar.metal_sunglasses, href: `/${currentPath}product/metal-sunglasses` },
      { label: t.sidebar.titanium_sunglasses, href: `/${currentPath}product/titanium-sunglasses` },
      { label: t.sidebar.carbon_fiber_sunglasses, href: `/${currentPath}product/carbon-fiber-sunglasses` },
      { label: t.sidebar.rimless_sunglasses, href: `/${currentPath}product/rimless-sunglasses` }
    ]
  },
  {
    label: t.sidebar.optical_frames,
    href: `/${currentPath}product/optical-frames`,
    items: [
      { label: t.sidebar.acetate_glasses, href: `/${currentPath}product/acetate-optical-frames` },
      { label: t.sidebar.metal_glasses, href: `/${currentPath}product/metal-optical-frames` },
      { label: t.sidebar.titanium_glasses, href: `/${currentPath}product/titanium-optical-frames` },
      { label: t.sidebar.carbon_glasses, href: `/${currentPath}product/carbon-fiber-optical-frames` },
      { label: t.sidebar.rimless_glasses, href: `/${currentPath}product/rimless-optical-frames` }
    ]
  }
];

// Tags / Filters (Flat Groups) - matches English product/index.astro
const sidebarTags = [
  {
    label: t.sidebar.fashion,
    href: `/${currentPath}product/fashion-eyewear`,
    items: [
      { label: t.sidebar.fashion_acetate_sunglasses, href: `/${currentPath}product/fashion-acetate-sunglasses` },
      { label: t.sidebar.fashion_metal_sunglasses, href: `/${currentPath}product/fashion-metal-sunglasses` },
      { label: t.sidebar.fashion_acetate_glasses, href: `/${currentPath}product/fashion-acetate-optical-frames` },
      { label: t.sidebar.fashion_metal_glasses, href: `/${currentPath}product/fashion-metal-optical-frames` }
    ]
  },
  {
    label: t.sidebar.luxury,
    href: `/${currentPath}product/luxury-eyewear`,
    items: [
      { label: t.sidebar.luxury_acetate_sunglasses, href: `/${currentPath}product/luxury-acetate-sunglasses` },
      { label: t.sidebar.luxury_titanium_sunglasses, href: `/${currentPath}product/luxury-titanium-sunglasses` },
      { label: t.sidebar.luxury_acetate_glasses, href: `/${currentPath}product/luxury-acetate-optical-frames` },
      { label: t.sidebar.luxury_titanium_glasses, href: `/${currentPath}product/luxury-titanium-optical-frames` }
    ]
  },
  {
    label: t.sidebar.carbon_fiber,
    href: `/${currentPath}product/carbon-fiber-eyewear`,
    items: [
      { label: t.sidebar.carbon_fiber_sunglasses, href: `/${currentPath}product/carbon-fiber-sunglasses` },
      { label: t.sidebar.carbon_glasses, href: `/${currentPath}product/carbon-fiber-optical-frames` }
    ]
  },
  {
    label: t.sidebar.rimless,
    href: `/${currentPath}product/rimless-eyewear`,
    items: [
      { label: t.sidebar.rimless_sunglasses, href: `/${currentPath}product/rimless-sunglasses` },
      { label: t.sidebar.rimless_glasses, href: `/${currentPath}product/rimless-optical-frames` }
    ]
  }
];

// Get product translations
const pt = t.product || {
  viewAllCollections: "View All Collections",
  allProducts: "All Products",
};
---

<Layout title={t.nav.products} lang={lang}>
  <Header lang={lang} />

  <main class="w-full min-h-screen py-12 lg:py-16 bg-stone-50">
    <div class="w-[94%] lg:w-[90%] 2xl:w-[85%] max-w-[1800px] mx-auto px-4">
      <!-- Page Header -->
      <div class="mb-10">
        <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-2">
          {t.nav.products}
        </h1>
        <p class="text-gray-600">
          {langProducts.length} {langProducts.length === 1 ? 'product' : 'products'} available
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Sidebar: Category Filter (Hidden on mobile/tablet) -->
        <aside class="hidden lg:block lg:col-span-1">
          <div class="sticky top-24 space-y-6">
            <!-- Categories Card -->
            <div class="bg-gradient-to-br from-white to-[#faf8f5] rounded-xl shadow-sm p-6 border border-stone-200/50">
              <!-- All Products Link -->
              <a
                href={`/${currentPath}product`}
                class="flex justify-between items-center py-2 px-3 rounded-lg bg-[#8B7355] text-white mb-3"
              >
                <span class="font-medium">{t.sidebar.all_products}</span>
                <span class="text-xs bg-white/20 px-2 py-1 rounded-full">
                  {langProducts.length}
                </span>
              </a>

              <!-- Category Groups with Sub-categories -->
              <div class="space-y-3">
                {primaryCategories.map((cat) => (
                  <div class="border-b border-gray-100 pb-3 last:border-0 last:pb-0">
                    <!-- Main Category -->
                    <a
                      href={cat.href}
                      class="flex items-center justify-between py-2 px-2 text-sm font-bold text-[#8B7355] hover:bg-stone-50 rounded-lg transition-colors"
                    >
                      <span class="flex items-center gap-2">
                        {cat.label}
                        <span class="text-xs font-normal text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full">{getCategoryCount(cat.href)}</span>
                      </span>
                      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                    <!-- Sub-categories -->
                    <ul class="ms-3 mt-1 space-y-1">
                      {cat.items.map((sub) => (
                        <li>
                          <a
                            href={sub.href}
                            class="flex items-center justify-between py-1.5 px-2 text-sm text-gray-600 hover:text-[#8B7355] hover:bg-stone-50 rounded transition-colors"
                          >
                            <span>{sub.label}</span>
                            <span class="text-xs text-gray-400">{getCategoryCount(sub.href)}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>

              <!-- Tags & Filters -->
              <div class="mt-8 pt-6 border-t border-gray-100">
                <h4 class="text-xs font-bold text-gray-900 uppercase tracking-wider mb-4">{t.sidebar.tags_filters}</h4>
                <div class="space-y-6">
                  {sidebarTags.map((group) => (
                    <div>
                      <a href={group.href} class="text-sm font-bold text-gray-900 mb-2.5 flex items-center hover:text-[#8B7355] transition-colors">
                        <span class="text-[#8B7355] mr-1">#</span> {group.label}
                      </a>
                      <div class="flex flex-col gap-1.5">
                        {group.items.map((tag) => (
                          <a
                            href={tag.href}
                            class="px-3 py-1.5 text-[11px] font-bold rounded-md border bg-stone-50 text-stone-600 border-stone-200 hover:border-[#8B7355] hover:text-[#8B7355] hover:bg-stone-100 transition-all duration-200 w-full"
                          >
                            {tag.label}
                          </a>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>

          <!-- CTA Card -->
          <div class="mt-6 bg-[#8B7355] rounded-xl p-6 text-white">
            <h4 class="font-bold mb-2">{pt.needCustomEyewear || 'Need Custom Eyewear?'}</h4>
            <p class="text-sm text-white/80 mb-4">
              {pt.oemServices || 'We offer full OEM & ODM services for your brand.'}
            </p>
            <a
              href={`/${currentPath}quote`}
              class="inline-block bg-white text-[#8B7355] px-4 py-2 rounded-lg text-sm font-semibold hover:bg-gray-100 transition-colors"
            >
              {t.cta.quote || 'Get Quote'}
            </a>
          </div>
        </aside>

        <!-- Product Grid -->
        <div class="lg:col-span-3">
          {products.length === 0 ? (
            <div class="text-center py-16 bg-white rounded-xl shadow-sm">
              <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
              <p class="text-gray-500 mb-4">No products available yet.</p>
              <a
                href={`/${currentPath}`}
                class="text-[#8B7355] hover:underline"
              >
                Return to Homepage
              </a>
            </div>
          ) : (
            <>
              <!-- Results Info -->
              <div class="flex justify-between items-center mb-6 text-sm text-gray-500">
                <span>
                  Showing {page.start + 1}-{Math.min(page.end, page.total)} of {page.total} products
                </span>
              </div>

              <!-- Products Grid -->
              <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6">
                {products.map((product) => (
                  <ProductCard product={product} lang={lang} />
                ))}
              </div>

              <!-- Pagination -->
              {page.lastPage > 1 && (
                <nav class="mt-12 flex justify-center items-center gap-2" dir={isRTL ? 'rtl' : 'ltr'}>
                  <!-- Previous Button -->
                  {page.url.prev ? (
                    <a
                      href={page.url.prev}
                      class="flex items-center gap-1 px-4 py-2 border border-gray-200 rounded-lg text-gray-600 hover:bg-gray-50 hover:border-[#8B7355] hover:text-[#8B7355] transition-colors"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                      </svg>
                      <span class="hidden sm:inline">{pt.previousPage || 'Previous'}</span>
                    </a>
                  ) : (
                    <span class="flex items-center gap-1 px-4 py-2 border border-gray-100 rounded-lg text-gray-300 cursor-not-allowed">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                      </svg>
                      <span class="hidden sm:inline">{pt.previousPage || 'Previous'}</span>
                    </span>
                  )}

                  <!-- Page Numbers -->
                  <div class="flex items-center gap-1">
                    {/* First page */}
                    <a
                      href={`/${currentPath}product`}
                      class={`w-10 h-10 flex items-center justify-center rounded-lg text-sm font-medium transition-colors ${
                        page.currentPage === 1
                          ? 'bg-[#8B7355] text-white'
                          : 'border border-gray-200 text-gray-600 hover:bg-gray-50 hover:border-[#8B7355] hover:text-[#8B7355]'
                      }`}
                    >
                      1
                    </a>

                    {/* Ellipsis before current */}
                    {page.currentPage > 3 && (
                      <span class="px-2 text-gray-400">...</span>
                    )}

                    {/* Pages around current */}
                    {Array.from({ length: page.lastPage }, (_, i) => i + 1)
                      .filter(p => p > 1 && p < page.lastPage && Math.abs(p - page.currentPage) <= 1)
                      .map(p => (
                        <a
                          href={`/${currentPath}product/${p}`}
                          class={`w-10 h-10 flex items-center justify-center rounded-lg text-sm font-medium transition-colors ${
                            p === page.currentPage
                              ? 'bg-[#8B7355] text-white'
                              : 'border border-gray-200 text-gray-600 hover:bg-gray-50 hover:border-[#8B7355] hover:text-[#8B7355]'
                          }`}
                        >
                          {p}
                        </a>
                      ))}

                    {/* Ellipsis after current */}
                    {page.currentPage < page.lastPage - 2 && (
                      <span class="px-2 text-gray-400">...</span>
                    )}

                    {/* Last page */}
                    {page.lastPage > 1 && (
                      <a
                        href={`/${currentPath}product/${page.lastPage}`}
                        class={`w-10 h-10 flex items-center justify-center rounded-lg text-sm font-medium transition-colors ${
                          page.currentPage === page.lastPage
                            ? 'bg-[#8B7355] text-white'
                            : 'border border-gray-200 text-gray-600 hover:bg-gray-50 hover:border-[#8B7355] hover:text-[#8B7355]'
                        }`}
                      >
                        {page.lastPage}
                      </a>
                    )}
                  </div>

                  <!-- Next Button -->
                  {page.url.next ? (
                    <a
                      href={page.url.next}
                      class="flex items-center gap-1 px-4 py-2 border border-gray-200 rounded-lg text-gray-600 hover:bg-gray-50 hover:border-[#8B7355] hover:text-[#8B7355] transition-colors"
                    >
                      <span class="hidden sm:inline">{pt.nextPage || 'Next'}</span>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                  ) : (
                    <span class="flex items-center gap-1 px-4 py-2 border border-gray-100 rounded-lg text-gray-300 cursor-not-allowed">
                      <span class="hidden sm:inline">{pt.nextPage || 'Next'}</span>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </span>
                  )}
                </nav>
              )}
            </>
          )}
        </div>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>

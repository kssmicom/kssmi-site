---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { translations } from '../translations';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const lang = 'en';
const t = translations[lang] || translations.en;

// Get content entry
const entry = await getEntry('collection', 'home/home.en');

const title = entry?.data?.seoTitle || "Kssmi - Premium Eyewear & Sunglasses Manufacturer";
const description = entry?.data?.seoDescription || "Since 2003, Kssmi has been a leading ODM & OEM eyewear manufacturer in Shenzhen, China.";
---

<Layout title={title} description={description} lang={lang}>
  <Header lang={lang} />

  <main>
    <!-- Homepage content will be added here -->
  </main>

  <Footer lang={lang} />
</Layout>

---
// English search page (default locale)
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { translations } from '../translations';
import { Image } from 'astro:assets';

const t = translations.en;
const lang = 'en';

// Get search query from URL
const url = new URL(Astro.request.url);
const query = url.searchParams.get('q') || '';

// Translations
const searchText = {
  en: "Search",
  it: "Cerca",
  es: "Buscar",
  fr: "Recherche",
  de: "Suche",
  pt: "Buscar",
  ru: "Поиск",
  ja: "検索",
  tr: "Ara",
  ar: "بحث"
};

const foundMatchesText = {
  en: "Found matches for",
  it: "Trovate corrispondenze per",
  es: "Se encontraron coincidencias para",
  fr: "Correspondances trouvées pour",
  de: "Treffer gefunden für",
  pt: "Correspondências encontradas para",
  ru: "Найдены совпадения для",
  ja: "の検索結果",
  tr: "için eşleşmeler bulundu",
  ar: "تم العثور على تطابقات لـ"
};

const resultsFoundText = {
  en: "Results Found",
  it: "Risultati trovati",
  es: "Resultados encontrados",
  fr: "Résultats trouvés",
  de: "Ergebnisse gefunden",
  pt: "Resultados encontrados",
  ru: "Результатов найдено",
  ja: "件の結果",
  tr: "Sonuç bulundu",
  ar: "نتائج وجدت"
};

const noResultsText = {
  en: "No results found for",
  it: "Nessun risultato per",
  es: "Sin resultados para",
  fr: "Aucun résultat pour",
  de: "Keine Ergebnisse für",
  pt: "Sem resultados para",
  ru: "Нет результатов для",
  ja: "の結果はありません",
  tr: "için sonuç bulunamadı",
  ar: "لا توجد نتائج لـ"
};

const tryDifferentText = {
  en: "Try different keywords or check your spelling",
  it: "Prova parole chiave diverse",
  es: "Intenta con diferentes palabras clave",
  fr: "Essayez d'autres mots-clés",
  de: "Versuchen Sie andere Suchbegriffe",
  pt: "Tente palavras-chave diferentes",
  ru: "Попробуйте другие ключевые слова",
  ja: "別のキーワードを試してください",
  tr: "Farklı anahtar kelimeler deneyin",
  ar: "جرب كلمات مفتاحية مختلفة"
};

const viewDetailsText = {
  en: "View Details",
  it: "Vedi dettagli",
  es: "Ver detalles",
  fr: "Voir détails",
  de: "Details ansehen",
  pt: "Ver detalhes",
  ru: "Подробнее",
  ja: "詳細を見る",
  tr: "Detayları görüntüle",
  ar: "عرض التفاصيل"
};

const searchPlaceholder = "Search products, pages, articles...";
---

<Layout title={`${searchText.en}${query ? ` - "${query}"` : ''} | KSSMI`} lang="en">
  <Header lang={lang} />

  <main class="min-h-screen bg-stone-50">
    <!-- Search Header -->
    <div class="bg-white border-b border-stone-200">
      <div class="max-w-7xl mx-auto px-4 py-8">
        <!-- Search Form -->
        <form action="/search" method="GET" class="max-w-2xl mx-auto">
          <div class="flex items-center border-2 border-stone-300 rounded-lg overflow-hidden focus-within:border-[#8B7355] transition-colors bg-white shadow-sm">
            <input
              type="search"
              name="q"
              value={query}
              placeholder={searchPlaceholder}
              class="flex-grow py-4 px-6 text-lg outline-none"
              autocomplete="off"
            />
            <button type="submit" class="px-6 py-4 bg-[#8B7355] text-white hover:bg-[#5D4E37] transition-colors">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </button>
          </div>
        </form>

        <!-- Search Info -->
        {query && (
          <div id="search-info" class="text-center mt-6">
            <h1 class="text-2xl font-bold text-stone-900">
              {foundMatchesText.en} "<span class="text-[#8B7355]">{query}</span>"
            </h1>
            <p id="results-count" class="text-stone-600 mt-2">
              <span id="count-number">0</span> {resultsFoundText.en}
            </p>
          </div>
        )}
      </div>
    </div>

    <!-- Search Results Container -->
    <div class="max-w-7xl mx-auto px-4 py-8">
      {query ? (
        <div id="search-results" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          <!-- Results will be loaded here by JavaScript -->
          <div class="col-span-full text-center py-8 text-stone-500">
            <svg class="w-8 h-8 mx-auto animate-spin text-[#8B7355]" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <p class="mt-4">Searching...</p>
          </div>
        </div>
      ) : (
        <div class="text-center py-16">
          <svg class="w-24 h-24 mx-auto text-stone-300 mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <h2 class="text-2xl font-semibold text-stone-700 mb-2">Search KSSMI</h2>
          <p class="text-stone-500 max-w-md mx-auto">Find products, articles, and more. Enter a search term above.</p>
        </div>
      )}

      <!-- No Results Template (hidden) -->
      <div id="no-results-template" class="hidden col-span-full text-center py-16">
        <svg class="w-24 h-24 mx-auto text-stone-300 mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h2 class="text-2xl font-semibold text-stone-700 mb-2">{noResultsText.en} "<span class="query-text"></span>"</h2>
        <p class="text-stone-500">{tryDifferentText.en}</p>
      </div>
    </div>

    <!-- Pagination -->
    <div id="pagination" class="hidden max-w-7xl mx-auto px-4 pb-12">
      <div class="flex justify-center items-center gap-2">
        <!-- Pagination buttons will be added by JavaScript -->
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</Layout>

<style>
  .search-result-card {
    @apply bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-all duration-300 group;
  }
  .search-result-card:hover {
    @apply -translate-y-1;
  }
  .result-type-badge {
    @apply absolute top-3 left-3 bg-[#8B7355] text-white text-xs font-semibold px-2 py-1 rounded uppercase tracking-wide;
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script define:vars={{ query, lang, viewDetailsText, resultsFoundText }}>
  const resultsContainer = document.getElementById('search-results');
  const countNumber = document.getElementById('count-number');
  const pagination = document.getElementById('pagination');
  const noResultsTemplate = document.getElementById('no-results-template');

  const RESULTS_PER_PAGE = 12;
  let currentPage = 1;
  let allResults = [];

  async function performSearch(searchQuery) {
    if (!searchQuery) return;

    try {
      const pagefindPath = '/pagefind/pagefind.js';
      const pagefind = await import(/* @vite-ignore */ pagefindPath);

      // Initialize Pagefind with English language
      await pagefind.init({ language: 'en' });

      const searchResults = await pagefind.search(searchQuery);

      if (searchResults.results.length === 0) {
        showNoResults(searchQuery);
        return;
      }

      // Fetch all result data
      allResults = await Promise.all(
        searchResults.results.map(result => result.data())
      );

      // Update count
      if (countNumber) {
        countNumber.textContent = allResults.length;
      }

      // Render first page
      renderPage(1);

    } catch (error) {
      console.error('Search error:', error);
      resultsContainer.innerHTML = `
        <div class="col-span-full text-center py-16">
          <p class="text-red-600">Search is not available. Please run <code class="bg-stone-100 px-2 py-1 rounded">npm run build</code> first.</p>
        </div>
      `;
    }
  }

  function showNoResults(searchQuery) {
    resultsContainer.innerHTML = `
      <div class="col-span-full text-center py-16">
        <svg class="w-24 h-24 mx-auto text-stone-300 mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h2 class="text-2xl font-semibold text-stone-700 mb-2">No results found for "${searchQuery}"</h2>
        <p class="text-stone-500">Try different keywords or check your spelling</p>
      </div>
    `;
    if (countNumber) countNumber.textContent = '0';
  }

  function renderPage(page) {
    currentPage = page;
    const startIndex = (page - 1) * RESULTS_PER_PAGE;
    const endIndex = startIndex + RESULTS_PER_PAGE;
    const pageResults = allResults.slice(startIndex, endIndex);

    resultsContainer.innerHTML = pageResults.map(data => createResultCard(data)).join('');
    renderPagination();
  }

  function createResultCard(data) {
    const url = data.url || '#';
    const title = data.meta?.title || 'Untitled';
    const excerpt = data.meta?.excerpt || data.raw_content?.slice(0, 150) || '';
    const image = data.meta?.image || null;

    // Determine result type from URL
    let resultType = 'Page';
    if (url.includes('/product/')) {
      resultType = 'Product';
    } else if (url.includes('/blog/')) {
      resultType = 'Article';
    } else if (url.includes('/collection/')) {
      resultType = 'Collection';
    }

    return `
      <a href="${url}" class="search-result-card block">
        <div class="relative aspect-[4/3] overflow-hidden bg-gray-100">
          ${image ? `
            <img src="${image}" alt="${title}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          ` : `
            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-stone-100 to-stone-200">
              <svg class="w-16 h-16 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
          `}
          <span class="result-type-badge">${resultType}</span>

          <!-- Hover Overlay -->
          <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <span class="bg-white text-[#8B7355] px-4 py-2 rounded-lg font-semibold text-sm flex items-center gap-2 transform translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
              ${viewDetailsText.en || 'View Details'}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </div>

        <div class="p-4">
          <h3 class="text-sm font-semibold text-gray-900 line-clamp-2 group-hover:text-[#8B7355] transition-colors mb-2">
            ${title}
          </h3>
          <p class="text-xs text-stone-500 line-clamp-3">
            ${excerpt}
          </p>
        </div>
      </a>
    `;
  }

  function renderPagination() {
    const totalPages = Math.ceil(allResults.length / RESULTS_PER_PAGE);

    if (totalPages <= 1) {
      pagination.classList.add('hidden');
      return;
    }

    pagination.classList.remove('hidden');
    const paginationContainer = pagination.querySelector('div');

    let paginationHTML = '';

    // Previous button
    if (currentPage > 1) {
      paginationHTML += `
        <button class="px-4 py-2 rounded-lg border border-stone-300 bg-white text-stone-700 hover:bg-stone-50 transition-colors" data-page="${currentPage - 1}">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
      `;
    }

    // Page numbers
    for (let i = 1; i <= totalPages; i++) {
      if (i === currentPage) {
        paginationHTML += `
          <button class="px-4 py-2 rounded-lg bg-[#8B7355] text-white font-semibold" data-page="${i}">${i}</button>
        `;
      } else if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
        paginationHTML += `
          <button class="px-4 py-2 rounded-lg border border-stone-300 bg-white text-stone-700 hover:bg-stone-50 transition-colors" data-page="${i}">${i}</button>
        `;
      } else if (i === currentPage - 2 || i === currentPage + 2) {
        paginationHTML += `<span class="px-2 text-stone-400">...</span>`;
      }
    }

    // Next button
    if (currentPage < totalPages) {
      paginationHTML += `
        <button class="px-4 py-2 rounded-lg border border-stone-300 bg-white text-stone-700 hover:bg-stone-50 transition-colors" data-page="${currentPage + 1}">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      `;
    }

    paginationContainer.innerHTML = paginationHTML;

    // Add click handlers
    paginationContainer.querySelectorAll('button[data-page]').forEach(btn => {
      btn.addEventListener('click', () => {
        const page = parseInt(btn.dataset.page);
        renderPage(page);
        // Scroll to top of results
        resultsContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  }

  // Run search on page load if query exists
  if (query) {
    performSearch(query);
  }
</script>

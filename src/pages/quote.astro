---
/**
 * Quote Request Page - English
 * URL: /quote/
 *
 * Uses the same InquiryForm component as product detail pages
 */

import Layout from '../layouts/Layout.astro';
import { translations } from '../translations';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import InquiryForm from '../components/InquiryForm.astro';

const lang = 'en';
const t = translations.en;
const isRTL = false;

const breadcrumbItems = [
  { label: t.nav.home, href: '/' },
  { label: 'Request Quote', href: '/quote' },
];
---

<Layout title="Request a Quote - Yeetian" lang={lang}>
  <Header lang={lang} />

  <main>
    <!-- Breadcrumb Navigation -->
    <Breadcrumb items={breadcrumbItems} lang={lang} />

    <!-- Hero Section -->
    <section class="py-12 lg:py-16 bg-gradient-to-b from-stone-50 to-white">
      <div class="w-[94%] lg:w-[90%] 2xl:w-[85%] max-w-[1200px] mx-auto px-4">
        <div class="text-center mb-8">
          <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
            Request a Custom Quote
          </h1>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            Tell us about your eyewear project and we'll provide a detailed quote within 24 hours.
            From design to delivery, we're your trusted manufacturing partner.
          </p>
        </div>

        <!-- Key Benefits -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
          <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-100 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-[#8B7355]/30 cursor-default group">
            <div class="w-12 h-12 bg-[#8B7355]/10 rounded-full flex items-center justify-center mx-auto mb-4 transition-colors duration-300 group-hover:bg-[#8B7355]/20">
              <svg class="w-6 h-6 text-[#8B7355] transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-2">Fast Response</h3>
            <p class="text-sm text-gray-500">Get a detailed quote within 24 hours</p>
          </div>
          <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-100 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-[#8B7355]/30 cursor-default group">
            <div class="w-12 h-12 bg-[#8B7355]/10 rounded-full flex items-center justify-center mx-auto mb-4 transition-colors duration-300 group-hover:bg-[#8B7355]/20">
              <svg class="w-6 h-6 text-[#8B7355] transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-2">Quality Guaranteed</h3>
            <p class="text-sm text-gray-500">ISO certified manufacturing processes</p>
          </div>
          <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-100 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-[#8B7355]/30 cursor-default group">
            <div class="w-12 h-12 bg-[#8B7355]/10 rounded-full flex items-center justify-center mx-auto mb-4 transition-colors duration-300 group-hover:bg-[#8B7355]/20">
              <svg class="w-6 h-6 text-[#8B7355] transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-2">Global Shipping</h3>
            <p class="text-sm text-gray-500">We ship to 50+ countries worldwide</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Inquiry Form -->
    <InquiryForm lang={lang} productName="General Inquiry" />
  </main>

  <Footer lang={lang} />
</Layout>

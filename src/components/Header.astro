---
// Language-aware navigation with Enhanced Mega Menu
interface Props {
  lang?: string;
}

const lang = Astro.props.lang || 'en';
const isRTL = lang === 'ar';

// Get translation file for UI text
import { translations } from '../translations';
const t = translations[lang] || translations.en;

// Current path for building URLs (includes language prefix for non-English)
const currentPath = lang === 'en' ? '' : `${lang}/`;

// About and Contact URLs: Using flat URLs
const aboutUrl = lang === 'en' ? '/about-us' : `/${lang}/about-us`;
const contactUrl = lang === 'en' ? '/contact' : `/${lang}/contact`;

// Get the page path WITHOUT language prefix for language switcher
const urlPath = Astro.url.pathname;
const languages = ['en', 'it', 'es', 'fr', 'de', 'pt', 'ru', 'ja', 'tr', 'ar', 'ko', 'zh', 'hi', 'vi', 'jv', 'ms', 'tg'];
let pagePath = urlPath;
// Strip language prefix if present
for (const l of languages) {
  if (urlPath.startsWith(`/${l}/`) || urlPath === `/${l}`) {
    pagePath = urlPath.slice(l.length + 1) || '/';
    break;
  }
}

// "Eyewear" translations for all 17 languages
const eyewearLabels = {
  en: 'Eyewear Mfg.', it: 'Manifattura Occhiali', es: 'Fabricante de Gafas', fr: 'Fabricant de Lunettes',
  de: 'Brillenmanufaktur', pt: 'Fabricante de Óculos', ru: 'Производство очков', ja: '眼鏡製造',
  tr: 'Gözlük Üreticisi', ar: 'تصنيع النظارات', ko: '안경 제조업체', zh: '眼镜制造商', hi: 'चश्मा निर्माता', vi: 'Nhà Sản Xuất Kính',
  jv: 'Pabrik Kacamata', ms: 'Pengilang Cermin Mata', tg: 'Истеҳсоли Айнак'
};

// "Quote" translations
const quoteLabels = {
  en: 'Get Quote', it: 'Preventivo', es: 'Presupuesto', fr: 'Devis',
  de: 'Angebot', pt: 'Orçamento', ru: 'Расценка', ja: '見積もり',
  tr: 'Teklif', ar: 'عرض سعر', ko: '견적 받기', zh: '获取报价', hi: 'उद्धरण प्राप्त करें', vi: 'Nhận báo giá',
  jv: 'Njaluk Kutipan', ms: 'Dapatkan Sebut Harga', tg: 'Гирифтани Нарх'
};

// "Search" single-word placeholder for the compact header input
const searchLabels = {
  en: 'Search', it: 'Cerca', es: 'Buscar', fr: 'Rechercher',
  de: 'Suchen', pt: 'Pesquisar', ru: 'Поиск', ja: '検索',
  tr: 'Ara', ar: 'بحث', ko: '검색', zh: '搜索', hi: 'खोजें', vi: 'Tìm kiếm',
  jv: 'Nggoleki', ms: 'Cari', tg: 'Ҷустуҷӯ'
};

const eyewearText = eyewearLabels[lang as keyof typeof eyewearLabels] || 'Eyewear';
const quoteText = quoteLabels[lang as keyof typeof quoteLabels] || 'Get Quote';
const searchText = searchLabels[lang as keyof typeof searchLabels] || 'Search';
const currentLangUpper = lang.toUpperCase();

// Enhanced Menu Structure (WordPress-style mega menu)
// Products use flat URL architecture; Collections use dynamic filter shortcuts
const menuStructure = [
  { label: t.nav.home, href: `/${currentPath}` },
  {
    label: t.nav.products,
    href: `/${currentPath}product`,
    menuKey: 'products',
    hasDropdown: true,
    children: [
      {
        label: t.sidebar.sunglasses,
        href: `/${currentPath}product/sunglasses`,
        items: [
          { label: t.sidebar.acetate_sunglasses,      href: `/${currentPath}product/acetate-sunglasses` },
          { label: t.sidebar.metal_sunglasses,         href: `/${currentPath}product/metal-sunglasses` },
          { label: t.sidebar.titanium_sunglasses,      href: `/${currentPath}product/titanium-sunglasses` },
          { label: t.sidebar.carbon_fiber_sunglasses,  href: `/${currentPath}product/carbon-fiber-sunglasses` },
          { label: t.sidebar.rimless_sunglasses,       href: `/${currentPath}product/rimless-sunglasses` }
        ]
      },
      {
        label: t.sidebar.optical_frames,
        href: `/${currentPath}product/optical-frames`,
        items: [
          { label: t.sidebar.acetate_glasses,     href: `/${currentPath}product/acetate-optical-frames` },
          { label: t.sidebar.metal_glasses,        href: `/${currentPath}product/metal-optical-frames` },
          { label: t.sidebar.titanium_glasses,     href: `/${currentPath}product/titanium-optical-frames` },
          { label: t.sidebar.carbon_glasses, href: `/${currentPath}product/carbon-fiber-optical-frames` },
          { label: t.sidebar.rimless_glasses,      href: `/${currentPath}product/rimless-optical-frames` }
        ]
      },
      {
        label: t.sidebar.fashion,
        href: `/${currentPath}product/fashion-eyewear`,
        items: [
          { label: t.sidebar.fashion_acetate_sunglasses, href: `/${currentPath}product/fashion-acetate-sunglasses` },
          { label: t.sidebar.fashion_metal_sunglasses,   href: `/${currentPath}product/fashion-metal-sunglasses` },
          { label: t.sidebar.fashion_acetate_glasses,     href: `/${currentPath}product/fashion-acetate-optical-frames` },
          { label: t.sidebar.fashion_metal_glasses,       href: `/${currentPath}product/fashion-metal-optical-frames` }
        ]
      },
      {
        label: t.sidebar.luxury,
        href: `/${currentPath}product/luxury-eyewear`,
        items: [
          { label: t.sidebar.luxury_acetate_sunglasses,  href: `/${currentPath}product/luxury-acetate-sunglasses` },
          { label: t.sidebar.luxury_titanium_sunglasses, href: `/${currentPath}product/luxury-titanium-sunglasses` },
          { label: t.sidebar.luxury_acetate_glasses,      href: `/${currentPath}product/luxury-acetate-optical-frames` },
          { label: t.sidebar.luxury_titanium_glasses,    href: `/${currentPath}product/luxury-titanium-optical-frames` }
        ]
      },
      {
        label: t.sidebar.carbon_fiber,
        href: `/${currentPath}product/carbon-fiber-eyewear`,
        items: [
          { label: t.sidebar.carbon_fiber_sunglasses, href: `/${currentPath}product/carbon-fiber-sunglasses` },
          { label: t.sidebar.carbon_glasses,     href: `/${currentPath}product/carbon-fiber-optical-frames` }
        ]
      },
      {
        label: t.sidebar.rimless,
        href: `/${currentPath}product/rimless-eyewear`,
        items: [
          { label: t.sidebar.rimless_sunglasses, href: `/${currentPath}product/rimless-sunglasses` },
          { label: t.sidebar.rimless_glasses,     href: `/${currentPath}product/rimless-optical-frames` }
        ]
      }
    ]
  },
  {
    label: 'Featured',
    href: `/${currentPath}featured`,
    menuKey: 'featured',
    hasDropdown: true,
    children: [
      {
        label: 'Market & Design Trends',
        href: `/${currentPath}trends`,
        items: [
          { label: '2026 Luxury Frameworks',   href: `/${currentPath}luxury-frameworks` },
          { label: 'Acetate Color Forecast',   href: `/${currentPath}acetate-colors` },
          { label: 'Classic Silhouettes',      href: `/${currentPath}classic-silhouettes` }
        ]
      },
      {
        label: 'Premium Materials',
        href: `/${currentPath}materials`,
        items: [
          { label: 'Aerospace Carbon Fiber',  href: `/${currentPath}carbon-fiber` },
          { label: 'Eco-Friendly Acetate',    href: `/${currentPath}eco-acetate` },
          { label: 'Hypoallergenic Titanium', href: `/${currentPath}titanium` }
        ]
      },
      {
        label: 'Craftsmanship & Engineering',
        href: `/${currentPath}engineering`,
        items: [
          { label: 'Precision CNC Machining',    href: `/${currentPath}cnc-machining` },
          { label: 'Custom Hinge Architecture', href: `/${currentPath}hinge-architecture` },
          { label: 'Hand-Polishing Techniques',  href: `/${currentPath}hand-polishing` }
        ]
      },
      {
        label: 'Optics & Lens Science',
        href: `/${currentPath}optics`,
        items: [
          { label: 'Tenacious Nylon Lenses',   href: `/${currentPath}nylon-lenses` },
          { label: 'Premium CR-39 Guide',    href: `/${currentPath}cr39-lenses` },
          { label: 'Custom Tints & Coatings', href: `/${currentPath}tints-coatings` }
        ]
      },
      {
        label: 'Quality & Compliance',
        href: `/${currentPath}compliance`,
        items: [
          { label: 'FDA & CE Certification',  href: `/${currentPath}fda-ce-certification` },
          { label: 'Drop-Ball Testing',       href: `/${currentPath}drop-ball-testing` },
          { label: 'ISO 9001 Production',    href: `/${currentPath}iso-9001` }
        ]
      },
      {
        label: 'Private Label Strategies',
        href: `/${currentPath}strategies`,
        items: [
          { label: 'OEM Customization Process', href: `/${currentPath}oem-process` },
          { label: 'Scaling with 300 MOQ',     href: `/${currentPath}moq-scaling` },
          { label: 'Bespoke Packaging Design',  href: `/${currentPath}bespoke-packaging` }
        ]
      }
    ]
  },
  { label: t.nav.about, href: aboutUrl },
  { label: t.nav.contact, href: contactUrl },
];

// Language names for dropdown
const languageNames = {
  en: 'English', it: 'Italiano', es: 'Español', fr: 'Français',
  de: 'Deutsch', pt: 'Português', ru: 'Русский', ja: '日本語',
  tr: 'Türkçe', ar: 'العربية', ko: '한국어', zh: '中文', hi: 'हिन्दी', vi: 'Tiếng Việt',
  jv: 'ꦧꦱꦗꦮ', ms: 'Bahasa Melayu', tg: 'Тоҷикӣ'
};

// Get Products menu data
const productsMenu = menuStructure.find(item => item.menuKey === 'products');
const featuredMenu = menuStructure.find(item => item.menuKey === 'featured');
---

<header id="site-header" class="w-full bg-white shadow-sm border-b border-stone-200 sticky top-0 z-50 transition-shadow duration-300">
  <div class="w-full max-w-[1860px] mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href={`/${currentPath}`} class="flex flex-col group min-w-max z-50 relative flex-shrink-0">
        <span class="text-2xl md:text-3xl font-bold text-[#503629] leading-none group-hover:opacity-80 transition-opacity duration-300">
          KSSMI
        </span>
        <div class="flex items-center gap-2 mt-1.5">
          <span class="h-[2px] w-4 bg-[#503629] group-hover:bg-[#b45309] transition-colors duration-300"></span>
          <span class="text-[9px] font-bold uppercase tracking-[0.2em] text-[#503629] group-hover:text-[#b45309] transition-colors duration-300">
            {eyewearText}
          </span>
        </div>
      </a>

      <!-- Navigation - Left aligned after logo -->
      <nav class="hidden lg:block h-full ms-8 xl:ms-12 z-30">
        <ul class="flex items-center h-full m-0 p-0 list-none gap-4 xl:gap-6">
          {menuStructure.map((item) => (
            <li class="h-full flex items-center">
              <a href={item.href}
                 class="nav-link relative inline-block text-gray-700 hover:text-[#8B7355] font-['Manrope'] font-bold text-xs md:text-sm uppercase tracking-wider transition-colors duration-300 px-2 xl:px-3 py-2"
                 data-mega-trigger={item.hasDropdown ? item.menuKey : undefined}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Spacer -->
      <div class="flex-grow min-w-0"></div>

      <!-- Right Actions -->
      <div class="flex items-center gap-3 xl:gap-4 flex-shrink-0">
        <div class="hidden sm:flex items-center gap-3">
          <!-- Search with icon buttons -->
          <form id="header-search" action={lang === 'en' ? '/search' : `/${lang}/search`} method="GET" class="relative">
            <div class="flex items-center border border-stone-200 bg-stone-50 rounded-sm overflow-hidden transition-colors duration-300 focus-within:border-[#8B7355] focus-within:bg-white">
              <input type="search" id="header-search-input" name="q" placeholder={searchText} class="w-28 xl:w-40 py-2 px-3 bg-transparent border-none outline-none text-sm md:text-base font-bold text-stone-900 placeholder:text-stone-400 focus:ring-0" />
              <!-- Clear button (hidden by default) -->
              <button type="button" id="header-search-clear" class="hidden px-2 text-stone-400 hover:text-stone-600 transition-colors" aria-label="Clear search">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
              </button>
              <!-- Search button -->
              <button type="submit" id="header-search-btn" class="px-2 text-stone-700 hover:text-[#8B7355] transition-colors" aria-label="Search">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
              </button>
            </div>
          </form>
          <div class="lang-dropdown-container relative group">
            <button class="lang-btn text-[11px] font-bold uppercase tracking-widest text-stone-900 flex items-center gap-2 hover:text-[#8B7355] transition-colors py-2 z-50 relative">
              {currentLangUpper}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="3" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="lang-dropdown-wrapper absolute top-full right-0 mt-2 w-40 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-[60] shadow-[0_10px_30px_rgba(0,0,0,0.25)] rounded-lg bg-[#2d2926] pointer-events-none group-hover:pointer-events-auto">
              <!-- Invisible bridge to keep hover active -->
              <div class="absolute -top-3 left-0 w-full h-3"></div>
              <div class="lang-dropdown-menu max-h-[calc(100vh-5rem)] overflow-y-auto p-2 pb-6 flex flex-col rounded-lg">
                {Object.entries(languageNames).map(([langCode, displayName]) => {
                  const isActive = langCode === lang;
                  // Build correct URL: /en/path or /fr/path (not /frit/path)
                  const langUrl = langCode === 'en' ? (pagePath === '/' ? '/' : pagePath) : `/${langCode}${pagePath === '/' ? '' : pagePath}`;
                  return (
                    <a href={langUrl} class:list={['block py-2.5 px-4 text-sm font-medium transition-all duration-200 rounded', isActive ? 'text-[#c9a66b] font-bold' : 'text-white/90 hover:bg-white/10 hover:text-[#c9a66b] hover:pl-6 whitespace-nowrap']}>
                      {displayName}
                    </a>
                  );
                })}
              </div>
              <div class="scroll-hint absolute bottom-0 left-0 w-full h-8 bg-gradient-to-t from-[#2d2926] to-transparent pointer-events-none transition-opacity duration-300 flex items-end justify-center pb-1.5 rounded-b-lg opacity-0">
                <svg class="w-4 h-4 text-[#c9a66b] animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg>
              </div>
            </div>
          </div>
        </div>
        <a href={`/${currentPath}quote`} class="hidden sm:block px-5 xl:px-6 py-2.5 bg-[#5D4E37] text-white text-xs xl:text-sm font-['Manrope'] font-bold uppercase tracking-[0.15em] hover:bg-[#8B7355] active:scale-95 transition-all duration-300 rounded-sm shadow-lg">
          {quoteText}
        </a>

        <!-- Mobile Menu Button -->
        <div class="lg:hidden flex items-center gap-3">
          <div class="lang-dropdown-container relative group">
            <button class="lang-btn text-[11px] font-bold uppercase tracking-widest text-stone-900 flex items-center gap-2 hover:text-[#8B7355] transition-colors py-2 z-50 relative">
              {currentLangUpper}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="3" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="lang-dropdown-wrapper absolute top-full right-0 mt-2 w-40 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-[60] shadow-[0_10px_30px_rgba(0,0,0,0.25)] rounded-lg bg-[#2d2926] pointer-events-none group-hover:pointer-events-auto">
              <!-- Invisible bridge to keep hover active -->
              <div class="absolute -top-3 left-0 w-full h-3"></div>
              <div class="lang-dropdown-menu max-h-[calc(100vh-5rem)] overflow-y-auto p-2 pb-6 flex flex-col rounded-lg">
                {Object.entries(languageNames).map(([langCode, displayName]) => {
                  const isActive = langCode === lang;
                  // Build correct URL: /en/path or /fr/path (not /frit/path)
                  const langUrl = langCode === 'en' ? (pagePath === '/' ? '/' : pagePath) : `/${langCode}${pagePath === '/' ? '' : pagePath}`;
                  return (
                    <a href={langUrl} class:list={['block py-2.5 px-4 text-sm font-medium transition-all duration-200 rounded', isActive ? 'text-[#c9a66b] font-bold' : 'text-white/90 hover:bg-white/10 hover:text-[#c9a66b] hover:pl-6 whitespace-nowrap']}>
                      {displayName}
                    </a>
                  );
                })}
              </div>
              <div class="scroll-hint absolute bottom-0 left-0 w-full h-8 bg-gradient-to-t from-[#2d2926] to-transparent pointer-events-none transition-opacity duration-300 flex items-end justify-center pb-1.5 rounded-b-lg opacity-0">
                <svg class="w-4 h-4 text-[#c9a66b] animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" /></svg>
              </div>
            </div>
          </div>
          <button id="mobile-menu-button" class="p-2 text-stone-700 hover:text-[#8B7355] focus:outline-none transition-colors relative z-[70] cursor-pointer">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.5" d="M4 8h16M4 16h16" /></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mega Menu Panel (inside header container for proper width constraint) -->
    <div id="mega-menu-panel" class="absolute top-full left-0 right-0 bg-white border-t-4 border-[#8B7355] shadow-[0_25px_50px_-12px_rgba(0,0,0,0.15)] rounded-b-2xl opacity-0 invisible transition-all duration-300 z-[55] pointer-events-none" data-active-menu="">
      <!-- Products Menu Content -->
      <div class="mega-menu-content hidden py-8 px-4" data-menu="products">
        <div class="grid grid-cols-6 gap-4 xl:gap-6">
          {productsMenu?.children?.map((group) => (
            <div class="flex flex-col">
              <a href={group.href} class="font-['Manrope'] font-bold text-xs uppercase tracking-wider text-[#8B7355] mb-4 whitespace-nowrap hover:text-[#5D4E37] transition-colors">
                {group.label}
              </a>
              <div class="flex flex-col space-y-1">
                {group.items.map((subItem) => (
                  <a href={subItem.href} class="font-['Plus_Jakarta_Sans'] text-sm font-medium text-stone-600 py-1.5 transition-all duration-200 hover:text-[#8B7355] hover:pl-1 whitespace-nowrap">
                    {subItem.label}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Featured Menu Content -->
      <div class="mega-menu-content hidden py-8 px-4" data-menu="featured">
        <div class="grid grid-cols-6 gap-4 xl:gap-6">
          {featuredMenu?.children?.map((group) => (
            <div class="flex flex-col">
              <a href={group.href} class="font-['Manrope'] font-bold text-xs uppercase tracking-wider text-[#8B7355] mb-4 whitespace-nowrap hover:text-[#5D4E37] transition-colors">
                {group.label}
              </a>
              <div class="flex flex-col space-y-1">
                {group.items.map((subItem) => (
                  <a href={subItem.href} class="font-['Plus_Jakarta_Sans'] text-sm font-medium text-stone-600 py-1.5 transition-all duration-200 hover:text-[#8B7355] hover:pl-1 whitespace-nowrap">
                    {subItem.label}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu -->
<div id="mobile-menu" class="hidden fixed inset-0 bg-white z-[10000] p-6 overflow-y-auto">
  <div class="flex justify-between items-center mb-8 sticky top-0 bg-white z-10 py-4 border-b border-gray-50">
    <span class="text-2xl font-['Manrope'] font-bold text-[#503629]">Menu</span>
    <button id="mobile-menu-close" class="p-3 bg-stone-100 rounded-full text-stone-700 hover:text-[#8B7355] hover:bg-stone-200 transition-colors shadow-sm" aria-label="Close menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
  </div>
  <div class="relative mb-8">
    <form id="mobile-search" action={lang === 'en' ? '/search' : `/${lang}/search`} method="GET" class="flex items-center bg-stone-50 border border-stone-200 rounded-md focus-within:border-[#8B7355] focus-within:bg-white transition-colors">
      <input type="search" id="mobile-search-input" name="q" placeholder={searchText} class="flex-grow py-4 px-4 bg-transparent border-none outline-none text-sm font-bold text-stone-900 focus:ring-0" />
      <button type="button" id="mobile-search-clear" class="hidden px-3 text-stone-400 hover:text-stone-600 transition-colors" aria-label="Clear search">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
      <button type="submit" id="mobile-search-btn" class="px-4 text-stone-700 hover:text-[#8B7355] transition-colors" aria-label="Search">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
      </button>
    </form>
  </div>
  <div id="mobile-menu-container" class="flex flex-col space-y-2 pb-20">
    {menuStructure.map((item) => (
      <div class="mobile-menu-item relative border-b border-stone-100 last:border-0">
        <div class="flex items-center justify-between w-full pr-4">
          {item.hasDropdown ? (
            <>
              <a href={item.href} class="mobile-menu-link block py-3 hover:text-[#5D4E37] transition-colors flex-grow flex items-center font-['Manrope'] font-bold text-lg">
                {item.label}
              </a>
              <button class="mobile-toggle-btn w-10 h-10 flex items-center justify-center text-[#5D4E37] rounded-full active:bg-stone-100 transition-all z-20 cursor-pointer" aria-label="Toggle submenu">
                <svg class="w-4 h-4 transition-transform duration-300 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </button>
            </>
          ) : (
            <a href={item.href} class="mobile-menu-link block py-3 hover:text-[#5D4E37] transition-colors flex-grow flex items-center font-['Manrope'] font-bold text-lg">
              {item.label}
            </a>
          )}
        </div>
        {item.hasDropdown && item.children && (
          <div class="mobile-sub-menu bg-[#fafaf9] overflow-hidden max-h-0 transition-all duration-500 ease-out">
            {item.children.map((group) => (
              <div class="pt-4 pb-2">
                <div class="py-3 text-xs md:text-sm font-semibold text-[#8B7355] font-['Manrope'] uppercase tracking-wide">
                  {group.label}
                </div>
                {group.items.map((subItem) => (
                  <a href={subItem.href} class="flex items-center font-['Plus_Jakarta_Sans'] text-base md:text-lg font-medium text-stone-700 py-3 pl-6 transition-all duration-200 hover:text-[#8B7355] hover:pl-8">
                    <span class="mr-3 text-[#5D4E37]">→</span>
                    {subItem.label}
                  </a>
                ))}
              </div>
            ))}
          </div>
        )}
      </div>
    ))}
    <div class="pt-6 mt-6 border-t border-stone-100">
      <a href={`/${currentPath}quote`} class="block w-full py-4 bg-[#8B7355] text-white text-center text-sm font-bold uppercase tracking-widest rounded-sm shadow-lg">
        {quoteText}
      </a>
    </div>
  </div>
</div>

<style>
  /* Hide native browser search cancel button */
  input[type="search"]::-webkit-search-cancel-button {
    -webkit-appearance: none;
    appearance: none;
  }

  .mobile-sub-menu.open {
    max-height: 2000px !important;
  }
  .mobile-toggle-btn.rotated svg {
    transform: rotate(180deg);
  }
  #mobile-menu {
    border-bottom-left-radius: 1.5rem;
    border-bottom-right-radius: 1.5rem;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    height: 3px;
    background-color: #8B7355;
    transition: width 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
  .nav-link:hover::after {
    width: 100%;
  }

  /* Mega Menu Active State */
  #mega-menu-panel.active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  #mega-menu-panel .mega-menu-content.active {
    display: block !important;
  }

  /* Language Dropdown Scrollbar */
  .lang-dropdown-menu::-webkit-scrollbar {
    display: none;
  }
  .lang-dropdown-menu {
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }
</style>

<script>
  // Global timeout reference for mega menu
  let megaMenuTimeout: ReturnType<typeof setTimeout>;

  // Store handlers globally so we can properly remove them
  const storedHandlers = new WeakMap<Element, Map<string, EventListener>>();

  function getHandlerMap(element: Element): Map<string, EventListener> {
    if (!storedHandlers.has(element)) {
      storedHandlers.set(element, new Map());
    }
    return storedHandlers.get(element)!;
  }

  function setListener(element: Element, event: string, handler: EventListener) {
    const map = getHandlerMap(element);
    const oldHandler = map.get(event);
    if (oldHandler) {
      element.removeEventListener(event, oldHandler);
    }
    element.addEventListener(event, handler);
    map.set(event, handler);
  }

  // Global mega menu elements
  let megaMenuPanel: HTMLElement | null = null;
  let megaMenuContents: NodeListOf<Element> | null = null;

  function showMegaMenu(menuKey: string) {
    clearTimeout(megaMenuTimeout);

    megaMenuContents?.forEach(content => {
      content.classList.remove('active');
    });

    const targetContent = document.querySelector(`.mega-menu-content[data-menu="${menuKey}"]`);
    if (targetContent) {
      targetContent.classList.add('active');
    }

    megaMenuPanel?.classList.add('active');
    megaMenuPanel?.setAttribute('data-active-menu', menuKey);
  }

  function hideMegaMenu() {
    megaMenuTimeout = setTimeout(() => {
      megaMenuPanel?.classList.remove('active');
      megaMenuPanel?.setAttribute('data-active-menu', '');
    }, 150);
  }

  function initHeader() {
    megaMenuPanel = document.getElementById('mega-menu-panel');
    megaMenuContents = document.querySelectorAll('.mega-menu-content');

    // Update language switcher links to preserve search params (e.g. ?q=001)
    // This runs on page load AND handles clicks dynamically for View Transitions
    function updateLangLinks() {
      const currentSearch = window.location.search;
      if (currentSearch) {
        document.querySelectorAll('.lang-dropdown-menu a').forEach(link => {
          const href = link.getAttribute('href');
          if (href && !href.includes('?')) {
            link.setAttribute('href', href + currentSearch);
          }
        });
      }
    }
    updateLangLinks();

    // Also handle clicks on language links to ensure search params are preserved
    // This is needed because View Transitions might intercept navigation
    document.querySelectorAll('.lang-dropdown-menu').forEach(menu => {
      menu.addEventListener('click', (e) => {
        const link = (e.target as HTMLElement).closest('a');
        if (link) {
          const currentSearch = window.location.search;
          const href = link.getAttribute('href');
          if (currentSearch && href && !href.includes('?')) {
            // Update the href before the click processes
            link.setAttribute('href', href + currentSearch);
          }
        }
      });
    });

    // Mobile Menu Toggle
    const menuButton = document.getElementById('mobile-menu-button');
    const menuClose = document.getElementById('mobile-menu-close');
    const mobileMenu = document.getElementById('mobile-menu');

    function toggleMobileMenu() {
      if (!mobileMenu) return;
      mobileMenu.classList.toggle('hidden');
      document.body.style.overflow = mobileMenu.classList.contains('hidden') ? '' : 'hidden';
    }

    if (menuButton) {
      setListener(menuButton, 'click', toggleMobileMenu);
    }
    if (menuClose) {
      setListener(menuClose, 'click', toggleMobileMenu);
    }

    // Mobile Submenu Toggle
    document.querySelectorAll('.mobile-toggle-btn').forEach(btn => {
      const handler = () => {
        const parentDiv = btn.closest('.mobile-menu-item');
        const subMenu = parentDiv?.querySelector('.mobile-sub-menu');
        if (subMenu) {
          subMenu.classList.toggle('open');
          btn.classList.toggle('rotated');
        }
      };
      setListener(btn, 'click', handler);
    });

    // Mega Menu triggers
    const megaTriggers = document.querySelectorAll('[data-mega-trigger]');

    megaTriggers.forEach(trigger => {
      const menuKey = trigger.getAttribute('data-mega-trigger');

      const enterHandler = () => {
        if (menuKey) showMegaMenu(menuKey);
      };
      setListener(trigger, 'mouseenter', enterHandler);

      // Keyboard support for accessibility
      const keydownHandler = (e: Event) => {
        const keyEvent = e as KeyboardEvent;
        if (keyEvent.key === 'Enter' || keyEvent.key === ' ') {
          keyEvent.preventDefault();
          if (menuKey) {
            // Toggle menu on key press
            if (megaMenuPanel?.getAttribute('data-active-menu') === menuKey) {
              hideMegaMenu();
            } else {
              showMegaMenu(menuKey);
            }
          }
        }
      };
      setListener(trigger, 'keydown', keydownHandler);

      const parentLi = trigger.closest('li');
      if (parentLi) {
        const leaveHandler = (e: MouseEvent) => {
          const relatedTarget = e.relatedTarget as HTMLElement;
          if (!megaMenuPanel?.contains(relatedTarget)) {
            hideMegaMenu();
          }
        };
        setListener(parentLi, 'mouseleave', leaveHandler as EventListener);
      }
    });

    if (megaMenuPanel) {
      setListener(megaMenuPanel, 'mouseenter', () => clearTimeout(megaMenuTimeout));
      setListener(megaMenuPanel, 'mouseleave', () => hideMegaMenu());
    }

    // Header Search
    const headerSearchInput = document.getElementById('header-search-input') as HTMLInputElement;
    const headerSearchClear = document.getElementById('header-search-clear');

    if (headerSearchInput) {
      setListener(headerSearchInput, 'input', () => {
        if (headerSearchInput.value.trim()) {
          headerSearchClear?.classList.remove('hidden');
        } else {
          headerSearchClear?.classList.add('hidden');
        }
      });
    }

    if (headerSearchClear && headerSearchInput) {
      setListener(headerSearchClear, 'click', () => {
        headerSearchInput.value = '';
        headerSearchClear.classList.add('hidden');
        headerSearchInput.focus();
      });
    }

    // Mobile Search
    const mobileSearchInput = document.getElementById('mobile-search-input') as HTMLInputElement;
    const mobileSearchClear = document.getElementById('mobile-search-clear');

    if (mobileSearchInput) {
      setListener(mobileSearchInput, 'input', () => {
        if (mobileSearchInput.value.trim()) {
          mobileSearchClear?.classList.remove('hidden');
        } else {
          mobileSearchClear?.classList.add('hidden');
        }
      });
    }

    if (mobileSearchClear && mobileSearchInput) {
      setListener(mobileSearchClear, 'click', () => {
        mobileSearchInput.value = '';
        mobileSearchClear.classList.add('hidden');
        mobileSearchInput.focus();
      });
    }

    // Language Dropdown Scroll Hints
    document.querySelectorAll('.lang-dropdown-menu').forEach(menu => {
      const hint = menu.nextElementSibling as HTMLElement;
      if (!hint || !hint.classList.contains('scroll-hint')) return;

      const updateHint = () => {
        // If scrollable and not at bottom
        if (menu.scrollHeight > menu.clientHeight && Math.ceil(menu.scrollTop + menu.clientHeight) < menu.scrollHeight - 2) {
          hint.style.opacity = '1';
        } else {
          hint.style.opacity = '0';
        }
      };

      setListener(menu, 'scroll', updateHint);
      
      const container = menu.closest('.lang-dropdown-container');
      if (container) {
        setListener(container, 'mouseenter', () => {
          setTimeout(updateHint, 50); 
        });
      }
      
      // Try to use ResizeObserver
      if (typeof ResizeObserver !== 'undefined') {
        const observer = new ResizeObserver(updateHint);
        observer.observe(menu);
      }
      updateHint();
    });

    // Language Dropdown Click Toggle (for touch devices)
    document.querySelectorAll('.lang-dropdown-container').forEach(container => {
      const btn = container.querySelector('.lang-btn');
      const wrapper = container.querySelector('.lang-dropdown-wrapper') as HTMLElement;

      if (btn && wrapper) {
        setListener(btn, 'click', (e) => {
          e.preventDefault();
          e.stopPropagation();

          // Close all other language dropdowns first
          document.querySelectorAll('.lang-dropdown-wrapper').forEach(w => {
            if (w !== wrapper) {
              w.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
              w.classList.add('opacity-0', 'invisible', 'pointer-events-none');
            }
          });

          // Toggle current dropdown
          const isVisible = wrapper.classList.contains('opacity-100');
          if (isVisible) {
            wrapper.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
            wrapper.classList.add('opacity-0', 'invisible', 'pointer-events-none');
          } else {
            wrapper.classList.remove('opacity-0', 'invisible', 'pointer-events-none');
            wrapper.classList.add('opacity-100', 'visible', 'pointer-events-auto');
            // update hint when opened via click
            const menu = wrapper.querySelector('.lang-dropdown-menu');
            if (menu) {
              setTimeout(() => menu.dispatchEvent(new Event('scroll')), 50);
            }
          }
        });
      }
    });

    // Close language dropdowns when clicking outside
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!target.closest('.lang-dropdown-container')) {
        document.querySelectorAll('.lang-dropdown-wrapper').forEach(wrapper => {
          wrapper.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
          wrapper.classList.add('opacity-0', 'invisible', 'pointer-events-none');
        });
      }
    });
  }

  // Initialize on DOMContentLoaded (ensures DOM is ready on first load)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeader);
  } else {
    // DOM already loaded, initialize immediately
    initHeader();
  }

  // Re-initialize after View Transitions navigation
  document.addEventListener('astro:page-load', initHeader);
</script>

---
// Language Picker Component
interface Props {
  lang: string;
  currentPath?: string;
}

const { lang, currentPath = '' } = Astro.props;

const languages = [
  { code: 'en', name: 'English', flag: 'EN' },
  { code: 'it', name: 'Italiano', flag: 'IT' },
  { code: 'es', name: 'Español', flag: 'ES' },
  { code: 'fr', name: 'Français', flag: 'FR' },
  { code: 'de', name: 'Deutsch', flag: 'DE' },
  { code: 'pt', name: 'Português', flag: 'PT' },
  { code: 'ru', name: 'Русский', flag: 'RU' },
  { code: 'ja', name: '日本語', flag: 'JA' },
  { code: 'tr', name: 'Türkçe', flag: 'TR' },
  { code: 'ar', name: 'العربية', flag: 'AR' },
  { code: 'ko', name: '한국어', flag: 'KO' },
  { code: 'zh', name: '中文', flag: 'ZH' },
  { code: 'hi', name: 'हिन्दी', flag: 'HI' },
  { code: 'vi', name: 'Tiếng Việt', flag: 'VI' },
  { code: 'jv', name: 'ꦧꦱꦗꦮ', flag: 'JV' },
  { code: 'ms', name: 'Bahasa Melayu', flag: 'MS' },
  { code: 'tg', name: 'Тоҷикӣ', flag: 'TG' },
];

const currentLanguage = languages.find(l => l.code === lang) || languages[0];
---

<language-picker class="relative inline-block text-left z-50">
  <button
    type="button"
    class="inline-flex w-full items-center justify-between gap-x-2 rounded-lg bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:ring-2 focus:ring-[#8B7355] focus:outline-none transition-all duration-200 min-w-[140px]"
    aria-expanded="false"
    aria-haspopup="true"
  >
    <div class="flex items-center gap-2">
      <span class="flex h-5 w-5 items-center justify-center rounded-full bg-gray-100 text-[10px] font-bold text-gray-600 border border-gray-200">
        {currentLanguage.flag}
      </span>
      <span>{currentLanguage.name}</span>
    </div>
    <!-- Custom Arrow Icon -->
    <svg class="h-4 w-4 text-gray-400 transition-transform duration-200 arrow-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7 7" />
    </svg>
  </button>

  <div
    class="absolute right-0 z-50 mt-2 w-56 origin-top-right rounded-xl bg-white shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none opacity-0 invisible translate-y-[-10px] transition-all duration-200 ease-in-out menu-container"
    role="menu"
    aria-orientation="vertical"
    tabindex="-1"
  >
    <div class="py-2 max-h-[320px] overflow-y-auto custom-scrollbar" role="none">
      {languages.map((l) => {
        const url = l.code === 'en' ? `/${currentPath}` : `/${l.code}/${currentPath}`;
        const isSelected = lang === l.code;
        return (
          <a
            href={url}
            class={`group flex items-center justify-between px-4 py-2.5 text-sm transition-colors ${
              isSelected 
                ? 'bg-[#8B7355]/5 text-[#8B7355] font-semibold' 
                : 'text-gray-700 hover:bg-gray-50 hover:text-gray-900'
            }`}
            role="menuitem"
          >
            <div class="flex items-center gap-3">
              <span class={`flex h-6 w-6 items-center justify-center rounded-full text-[10px] font-bold transition-colors border ${
                isSelected ? 'bg-[#8B7355] text-white border-[#8B7355]' : 'bg-gray-50 text-gray-600 border-gray-200 group-hover:bg-white'
              }`}>
                {l.flag}
              </span>
              <span>{l.name}</span>
            </div>
            {isSelected && (
              <svg class="h-4 w-4 text-[#8B7355]" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
              </svg>
            )}
          </a>
        );
      })}
    </div>
  </div>
</language-picker>

<script>
  class LanguagePicker extends HTMLElement {
    constructor() {
      super();
      const button = this.querySelector('button');
      const menu = this.querySelector('.menu-container');
      const arrow = this.querySelector('.arrow-icon');
      
      if (!button || !menu) return;

      let isOpen = false;

      const toggleMenu = () => {
        isOpen = !isOpen;
        if (isOpen) {
          menu.classList.remove('opacity-0', 'invisible', 'translate-y-[-10px]');
          button.setAttribute('aria-expanded', 'true');
          if (arrow) arrow.classList.add('rotate-180');
        } else {
          menu.classList.add('opacity-0', 'invisible', 'translate-y-[-10px]');
          button.setAttribute('aria-expanded', 'false');
          if (arrow) arrow.classList.remove('rotate-180');
        }
      };

      button.addEventListener('click', toggleMenu);

      const closeMenu = (event) => {
        if (isOpen && event.target instanceof Node && !this.contains(event.target)) {
          toggleMenu();
        }
      };
      
      document.addEventListener('click', closeMenu);

      this.addEventListener('keydown', (event) => {
        if (isOpen && event.key === 'Escape') {
          toggleMenu();
          button.focus();
        }
      });

      const links = this.querySelectorAll('a');
      links.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const targetUrl = link.getAttribute('href');
          if (targetUrl) {
            window.location.href = targetUrl + window.location.search;
          }
        });
      });
    }
  }

  if (!customElements.get('language-picker')) {
    customElements.define('language-picker', LanguagePicker);
  }
</script>

<style>
  /* Hide scrollbar for Chrome, Safari and Opera */
  .custom-scrollbar::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .custom-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
    overflow-x: hidden;
  }
</style>

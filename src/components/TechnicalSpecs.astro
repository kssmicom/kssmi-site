---
/**
 * Technical Specifications Component
 * Displays detailed product specifications in a table format
 */

import { translations } from '../translations';


// Import all certification images















// Certification data with exact public string URLs pointing to /media/certifications/
const certifications = [
  { image: '/media/certifications/ISO 9001.webp', label: 'ISO 9001' },
  { image: '/media/certifications/BSCI.webp', label: 'BSCI' },
  { image: '/media/certifications/FDA.webp', label: 'FDA' },
  { image: '/media/certifications/CE.webp', label: 'CE' },
  { image: '/media/certifications/RoHS.webp', label: 'RoHS' },
  { image: '/media/certifications/Prop 65.webp', label: 'Prop 65' },
  { image: '/media/certifications/21 CFR 801.410 (Drop Ball Test).webp', label: '21 CFR 801.410' },
  { image: '/media/certifications/ANSI Z80.3.webp', label: 'ANSI Z80.3' },
  { image: '/media/certifications/ANSI Z87.1.webp', label: 'ANSI Z87.1' },
  { image: '/media/certifications/EN ISO 12312-1.webp', label: 'EN ISO 12312-1' },
  { image: '/media/certifications/EN ISO 12870.webp', label: 'EN ISO 12870' },
  { image: '/media/certifications/UKCA Mark.webp', label: 'UKCA Mark' },
  { image: '/media/certifications/ASNZS 1067.1.webp', label: 'AS/NZS 1067.1' },
  { image: '/media/certifications/ISO 13485.webp', label: 'ISO 13485' },
];

interface SpecProps {
  specs?: {
    size?: string;
    frameMaterial?: string;
    lensMaterial?: string;
    designStyle?: string;
    nosePads?: string;
    hinge?: string;
    electroplating?: string;
    logo?: string[];
  };
  product: {
    data: {
      slug?: string;
      materials?: string[];
      moq?: number;
      serviceMode?: string[];
    };
  };
  lang?: string;
}

const { specs, product, lang = 'en' } = Astro.props;
const t = translations[lang] || translations.en;

const serviceMode = product.data.serviceMode || ['OEM', 'ODM'];
const moq = product.data.moq || 100;

const pt = t.product || {
  technicalData: "Technical Data",
  size: "Size",
  frameMaterial: "Frame Material",
  lensMaterial: "Lenses Material",
  designStyle: "Design Style",
  nosePads: "Nose Pads",
  hinge: "Hinge",
  electroplating: "Electroplating Method",
  service: "Service",
  moq: "MOQ",
  logo: "Logo",
};
---

<section class="py-12 lg:py-16 bg-white border-b border-gray-100">
  <div class="w-[94%] lg:w-[90%] 2xl:w-[85%] max-w-[1800px] mx-auto px-4">
    <!-- Section Title -->
    <h2 class="text-2xl lg:text-3xl font-bold mb-8 text-gray-900">
      {pt.technicalData}
    </h2>

    <!-- Specifications Table -->
    <div class="overflow-x-auto">
      <table class="w-full border-collapse bg-white rounded-lg overflow-hidden shadow-sm border border-gray-200">
        <tbody>
          <!-- Size Row -->
          {specs?.size && (
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
              <td class="py-4 ps-6 font-medium text-gray-500 w-1/3 min-w-[200px]">
                {pt.size}
              </td>
              <td class="py-4 pe-6 text-gray-900">
                {specs.size} & Customization
              </td>
            </tr>
          )}

          <!-- Frame Material Row -->
          {specs?.frameMaterial && (
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
              <td class="py-4 ps-6 font-medium text-gray-500">
                {pt.frameMaterial}
              </td>
              <td class="py-4 pe-6 text-gray-900">
                {specs.frameMaterial} & Customization
              </td>
            </tr>
          )}

          <!-- Lens Material Row -->
          {specs?.lensMaterial && (
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
              <td class="py-4 ps-6 font-medium text-gray-500">
                {pt.lensMaterial}
              </td>
              <td class="py-4 pe-6 text-gray-900">
                Nylon Lens & Customization
              </td>
            </tr>
          )}

          <!-- Design Style Row -->
          {specs?.designStyle && (
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
              <td class="py-4 ps-6 font-medium text-gray-500">
                {pt.designStyle}
              </td>
              <td class="py-4 pe-6 text-gray-900">
                {specs.designStyle}
              </td>
            </tr>
          )}

          <!-- Nose Pads Row -->
          {specs?.nosePads && (
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
              <td class="py-4 ps-6 font-medium text-gray-500">
                {pt.nosePads}
              </td>
              <td class="py-4 pe-6 text-gray-900">
                {specs.nosePads}
              </td>
            </tr>
          )}

          <!-- Hinge Row -->
          {specs?.hinge && (
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
              <td class="py-4 ps-6 font-medium text-gray-500">
                {pt.hinge}
              </td>
              <td class="py-4 pe-6 text-gray-900">
                {specs.hinge}
              </td>
            </tr>
          )}

          <!-- Electroplating Row -->
          {specs?.electroplating && (
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
              <td class="py-4 ps-6 font-medium text-gray-500">
                {pt.electroplating}
              </td>
              <td class="py-4 pe-6 text-gray-900">
                {specs.electroplating}
              </td>
            </tr>
          )}

          <!-- Service Row -->
          <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
            <td class="py-4 ps-6 font-medium text-gray-500">
              {pt.service}
            </td>
            <td class="py-4 pe-6 text-gray-900">
              {serviceMode.join(', ')} customization
            </td>
          </tr>

          <!-- MOQ Row -->
          <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
            <td class="py-4 ps-6 font-medium text-gray-500">
              {pt.moq}
            </td>
            <td class="py-4 pe-6 text-gray-900">
              {moq} pairs/model
            </td>
          </tr>

          <!-- Logo Options Row -->
          {specs?.logo && specs.logo.length > 0 && (
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="py-4 ps-6 font-medium text-gray-500">
                {pt.logo}
              </td>
              <td class="py-4 pe-6 text-gray-900">
                {specs.logo.join(', ')}
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>

    <!-- Certification Badges - Elegant Grid Design -->
    <div class="mt-12 pt-10 border-t border-gray-200">
      <!-- Section Header -->
      <div class="text-center mb-8">
        <h3 class="text-lg font-semibold text-gray-800 mb-2">
          {pt.certificationsTitle || 'Certifications & Compliance'}
        </h3>
        <p class="text-sm text-gray-500">
          {pt.certificationsSubtitle || 'International Quality Standards'}
        </p>
      </div>

      <!-- Certifications Grid -->
      <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-7 gap-x-3 gap-y-5 sm:gap-x-4 sm:gap-y-6 justify-items-center">
        {certifications.map((cert) => (
          <div class="flex flex-col items-center group">
            <!-- Image Container with subtle shadow and hover effect -->
            <div class="relative w-20 h-20 lg:w-24 lg:h-24 mb-3 overflow-hidden rounded-xl shadow-sm border border-gray-100 group-hover:shadow-md group-hover:border-[#8B7355]/30 transition-all duration-300">
              <img
                src={cert.image}
                alt={cert.label}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                loading="lazy"
                decoding="async"
              />
            </div>
            <!-- Label with better typography -->
            <span class="text-xs text-gray-600 text-center font-medium leading-relaxed px-1 group-hover:text-[#8B7355] transition-colors duration-300 max-w-[90px]">
              {cert.label}
            </span>
          </div>
        ))}
      </div>

      <!-- Decorative bottom line -->
      <div class="mt-10 flex justify-center">
        <div class="w-24 h-0.5 bg-gradient-to-r from-transparent via-[#8B7355]/40 to-transparent rounded-full"></div>
      </div>
    </div>
  </div>
</section>




---
/**
 * Inquiry Form Component
 * Project intake form for B2B inquiries
 * Includes name, email, and project details fields
 * Integrates with PHP form handler via AJAX
 * Protected by Cloudflare Turnstile (can be disabled for testing)
 */

import { translations } from '../translations';

interface Props {
  lang?: string;
  productName?: string;
}

const { lang = 'en', productName = '' } = Astro.props;
const t = translations[lang] || translations.en;
const isRTL = lang === 'ar';

// Get product-specific translations (fallback to English)
const pt = t.product || {
  projectFormTitle: "Start Your Project",
  projectFormDesc: "Submit your project information, and our engineering team will deliver a detailed preliminary review within 24 hours.",
  nameOrg: "Name / Organization",
  officialEmail: "Official Email",
  projectDetails: "Project Details",
  submitRequest: "Submit Request",
};

// Turnstile error message translations
const turnstileErrorMessages = {
  en: "Please click the security verification checkbox above to prove you are human.",
  it: "Si prega di cliccare la casella di verifica sopra per dimostrare di essere umani.",
  es: "Por favor, haga clic en la casilla de verificación de seguridad de arriba para demostrar que es humano.",
  fr: "Veuillez cliquer sur la case de vérification de sécurité ci-dessus pour prouver que vous êtes humain.",
  de: "Bitte klicken Sie auf das Kontrollkästchen zur Sicherheitsüberprüfung oben, um zu beweisen, dass Sie ein Mensch sind.",
  pt: "Por favor, clique na caixa de verificação de segurança acima para provar que você é humano.",
  ru: "Пожалуйста, нажмите на флажок проверки безопасности выше, чтобы подтвердить, что вы человек.",
  ja: "人間であることを証明するために、上のセキュリティ確認チェックボックスをクリックしてください。",
  tr: "İnsan olduğunuzu kanıtlamak için lütfen yukarıdaki güvenlik doğrulama onay kutusuna tıklayın.",
  ar: "يرجى النقر فوق مربع التحقق الأمني أعلاه لإثبات أنك إنسان.",
};

const turnstileErrorMsg = turnstileErrorMessages[lang] || turnstileErrorMessages.en;

// Cloudflare Turnstile Site Key
const TURNSTILE_SITE_KEY = "0x4AAAAAACGlmQDIODBgCmpo";

// Check if we're in development (localhost) - Turnstile doesn't work on localhost
const isDev = import.meta.env.DEV;

// Current page URL for form context
const currentUrl = Astro.url.pathname;
---

<section class="py-16 lg:py-20 bg-gradient-to-b from-gray-50 to-white" dir={isRTL ? 'rtl' : 'ltr'}>
  <div class="w-[94%] lg:w-[90%] 2xl:w-[85%] max-w-[800px] mx-auto px-4">
    <!-- Form Header -->
    <div class="text-center mb-10">
      <h2 class="text-2xl lg:text-3xl font-bold mb-4 text-gray-900">
        {pt.projectFormTitle}
      </h2>
      <p class="text-gray-600 max-w-lg mx-auto">
        {pt.projectFormDesc}
      </p>
    </div>

    <!-- Form Container -->
    <div class="bg-white rounded-xl shadow-lg p-8 lg:p-10 border border-gray-100">
      <!-- Success Message (hidden by default) -->
      <div id="form-success" class="hidden text-center py-10">
        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Thank You!</h3>
        <p class="text-gray-600">Your inquiry has been sent successfully. We will contact you within 24 hours.</p>
      </div>

      <!-- Error Message (hidden by default) -->
      <div id="form-error" class="hidden text-center py-6 px-4 bg-red-50 rounded-lg mb-6">
        <div class="flex items-center justify-center gap-2 text-red-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span id="error-message">An error occurred. Please try again.</span>
        </div>
      </div>

      <!-- Form -->
      <form id="inquiry-form" class="space-y-6">
        <!-- Hidden Fields for Context -->
        <input type="hidden" name="source" value="product_page" />
        <input type="hidden" name="product_url" value={currentUrl} />
        <input type="hidden" name="language" value={lang} />
        {productName && (
          <input type="hidden" name="product_name" value={productName} />
        )}

        <!-- Name / Organization Field -->
        <div>
          <label
            for="name"
            class="block text-sm font-medium text-gray-700 mb-2"
          >
            {pt.nameOrg} <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name organization"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg
                   focus:ring-2 focus:ring-[#8B7355] focus:border-[#8B7355]
                   transition-colors duration-200
                   placeholder:text-gray-400"
            placeholder="Your name or company name"
          />
        </div>

        <!-- Email Field -->
        <div>
          <label
            for="email"
            class="block text-sm font-medium text-gray-700 mb-2"
          >
            {pt.officialEmail} <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg
                   focus:ring-2 focus:ring-[#8B7355] focus:border-[#8B7355]
                   transition-colors duration-200
                   placeholder:text-gray-400"
            placeholder="your@company.com"
          />
        </div>

        <!-- Project Details Field -->
        <div>
          <label
            for="details"
            class="block text-sm font-medium text-gray-700 mb-2"
          >
            {pt.projectDetails} <span class="text-red-500">*</span>
          </label>
          <textarea
            id="details"
            name="details"
            rows="7"
            required
            class="w-full px-4 py-3 border border-gray-300 rounded-lg
                   focus:ring-2 focus:ring-[#8B7355] focus:border-[#8B7355]
                   transition-colors duration-200 resize-y
                   placeholder:text-gray-400"
            placeholder="Describe your project requirements, quantities, timeline, etc."
          ></textarea>
        </div>

        <!-- Cloudflare Turnstile Widget (only in production) -->
        <div id="turnstile-container" class={`flex justify-center ${isDev ? 'hidden' : ''}`}>
          <!-- Widget will be rendered dynamically via JavaScript -->
        </div>

        <!-- Turnstile Error Message (hidden by default) - shown right below Turnstile -->
        <div id="turnstile-error" class="hidden text-center py-3 px-4 bg-red-50 rounded-lg">
          <div class="flex items-center justify-center gap-2 text-red-600">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <span id="turnstile-error-message" class="text-sm">Please click the security verification checkbox above to prove you are human.</span>
          </div>
        </div>

        <!-- Development Notice -->
        {isDev && (
          <div class="text-center text-xs text-amber-600 bg-amber-50 py-2 px-4 rounded-lg">
            Development Mode: Turnstile disabled for localhost testing
          </div>
        )}

        <!-- Submit Button -->
        <div class="pt-4">
          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-[#8B7355] text-white py-4 px-6 rounded-lg font-semibold
                   hover:bg-[#5D4E37] active:bg-[#4a4030]
                   transition-colors duration-200
                   focus:outline-none focus:ring-2 focus:ring-[#8B7355] focus:ring-offset-2
                   flex items-center justify-center gap-2
                   disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <span id="btn-text">{pt.submitRequest}</span>
            <svg id="btn-arrow" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
            <svg id="btn-spinner" class="hidden animate-spin w-5 h-5" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </button>
        </div>

        <!-- Security Notice -->
        <div class="pt-4 text-center">
          <div class="flex items-center justify-center gap-4 text-xs text-gray-500">
            <!-- Lock Icon -->
            <span class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
              Secure 256-bit Encrypted
            </span>
            <span class="text-gray-300">|</span>
            <span>NDAs available</span>
          </div>
        </div>
      </form>
    </div>

    <!-- Alternative Contact Methods -->
    <div class="mt-10 text-center">
      <p class="text-gray-500 text-sm mb-4">Or contact us directly:</p>
      <div class="flex flex-wrap justify-center gap-x-10 gap-y-4">
        <a
          href="tel:+86-135-1053-2553"
          class="flex items-center gap-2 text-gray-600 hover:text-[#8B7355] transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span class="text-sm">+86-135-1053-2553</span>
        </a>
        <a
          href="mailto:sales@kssmi.com"
          class="flex items-center gap-2 text-gray-600 hover:text-[#8B7355] transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span class="text-sm">sales#kssmi.com</span>
        </a>
        <a
          href="https://wa.me/8613510532553"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-gray-600 hover:text-green-600 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.5-.173-.007-.371-.009-.57-.009-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span class="text-sm">WhatsApp</span>
        </a>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ isDev, pt, turnstileErrorMsg, TURNSTILE_SITE_KEY }}>
  // Turnstile state tracking (module-level to persist across View Transitions)
  let turnstileToken = null;
  let turnstileWidgetId = null;
  let turnstileScriptLoaded = false;
  let initAttempts = 0;
  const MAX_INIT_ATTEMPTS = 50; // 5 seconds max

  // Generate unique ID for this form instance to avoid conflicts
  const formInstanceId = 'turnstile-' + Math.random().toString(36).substring(2, 9);

  // Load Turnstile script dynamically
  function loadTurnstileScript() {
    if (isDev) return Promise.resolve();
    if (window.turnstile) {
      turnstileScriptLoaded = true;
      return Promise.resolve();
    }
    if (document.querySelector('script[src*="turnstile"]')) {
      return new Promise((resolve) => {
        const checkLoaded = () => {
          if (window.turnstile) {
            turnstileScriptLoaded = true;
            resolve();
          } else {
            setTimeout(checkLoaded, 50);
          }
        };
        checkLoaded();
      });
    }

    return new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit';
      script.async = true;
      script.defer = true;
      script.onload = () => {
        turnstileScriptLoaded = true;
        resolve();
      };
      script.onerror = () => {
        console.error('Failed to load Turnstile script');
        reject(new Error('Turnstile script load failed'));
      };
      document.head.appendChild(script);
    });
  }

  // Callbacks for Turnstile (use unique names to avoid conflicts)
  const successCallbackName = 'onTurnstileSuccess_' + formInstanceId;
  const expiredCallbackName = 'onTurnstileExpired_' + formInstanceId;

  window[successCallbackName] = function(token) {
    turnstileToken = token;
    const errorEl = document.getElementById('turnstile-error');
    if (errorEl) errorEl.classList.add('hidden');
  };

  window[expiredCallbackName] = function() {
    turnstileToken = null;
  };

  // Initialize or re-initialize Turnstile widget
  async function initTurnstile() {
    if (isDev) return;

    const container = document.getElementById('turnstile-container');
    if (!container) return;

    // Reset attempts for new initialization
    initAttempts = 0;

    // Load script if not loaded
    try {
      await loadTurnstileScript();
    } catch (e) {
      console.error('Turnstile script load error:', e);
      return;
    }

    // Wait for Turnstile to be ready with retry
    const waitForTurnstile = () => {
      return new Promise((resolve) => {
        const check = () => {
          initAttempts++;
          if (window.turnstile && typeof window.turnstile.render === 'function') {
            resolve(true);
          } else if (initAttempts >= MAX_INIT_ATTEMPTS) {
            console.error('Turnstile failed to initialize after maximum attempts');
            resolve(false);
          } else {
            setTimeout(check, 100);
          }
        };
        check();
      });
    };

    const ready = await waitForTurnstile();
    if (!ready) return;

    // Remove existing widget if we have a widget ID
    if (turnstileWidgetId !== null) {
      try {
        window.turnstile.remove(turnstileWidgetId);
      } catch (e) {
        // Widget might not exist, ignore error
      }
      turnstileWidgetId = null;
    }

    // Clear the container
    container.innerHTML = '';

    // Create new widget div
    const widgetDiv = document.createElement('div');
    container.appendChild(widgetDiv);

    // Render new Turnstile widget
    try {
      turnstileWidgetId = window.turnstile.render(widgetDiv, {
        sitekey: TURNSTILE_SITE_KEY,
        theme: 'light',
        callback: window[successCallbackName],
        'expired-callback': window[expiredCallbackName]
      });
    } catch (e) {
      console.error('Turnstile render error:', e);
    }
  }

  // Initialize on first page load
  if (!isDev) {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTurnstile);
    } else {
      initTurnstile();
    }
  }

  // Re-initialize after View Transitions navigation
  document.addEventListener('astro:page-load', function() {
    if (!isDev) {
      turnstileToken = null; // Reset token on navigation
      turnstileWidgetId = null; // Reset widget ID since DOM is replaced
      initTurnstile();
    }
  });

  // Form elements - query fresh each time to handle View Transitions
  function getFormElements() {
    return {
      form: document.getElementById('inquiry-form'),
      submitBtn: document.getElementById('submit-btn'),
      btnText: document.getElementById('btn-text'),
      btnArrow: document.getElementById('btn-arrow'),
      btnSpinner: document.getElementById('btn-spinner'),
      errorContainer: document.getElementById('form-error'),
      errorMessage: document.getElementById('error-message'),
      turnstileErrorContainer: document.getElementById('turnstile-error'),
      turnstileErrorMessage: document.getElementById('turnstile-error-message'),
    };
  }

  // Show loading state
  function setLoading(loading) {
    const { submitBtn, btnText, btnArrow, btnSpinner } = getFormElements();
    if (loading) {
      if (submitBtn) submitBtn.disabled = true;
      if (btnText) btnText.textContent = 'Submitting...';
      if (btnArrow) btnArrow.classList.add('hidden');
      if (btnSpinner) btnSpinner.classList.remove('hidden');
    } else {
      if (submitBtn) submitBtn.disabled = false;
      if (btnText) btnText.textContent = pt.submitRequest || 'Submit Request';
      if (btnArrow) btnArrow.classList.remove('hidden');
      if (btnSpinner) btnSpinner.classList.add('hidden');
    }
  }

  // Show error (general form errors - shown at top)
  function showError(message) {
    const { errorContainer, errorMessage } = getFormElements();
    if (errorMessage) errorMessage.textContent = message;
    if (errorContainer) {
      errorContainer.classList.remove('hidden');
      errorContainer.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }

  // Hide error (general form errors)
  function hideError() {
    const { errorContainer } = getFormElements();
    if (errorContainer) errorContainer.classList.add('hidden');
  }

  // Show Turnstile error (shown below Turnstile widget)
  function showTurnstileError(message) {
    const { turnstileErrorContainer, turnstileErrorMessage } = getFormElements();
    if (turnstileErrorMessage) turnstileErrorMessage.textContent = message;
    if (turnstileErrorContainer) {
      turnstileErrorContainer.classList.remove('hidden');
      turnstileErrorContainer.style.display = 'block';
    }
  }

  // Hide Turnstile error
  function hideTurnstileError() {
    const { turnstileErrorContainer } = getFormElements();
    if (turnstileErrorContainer) turnstileErrorContainer.classList.add('hidden');
  }

  // Redirect to thank-you page
  function redirectToThankYou(lang) {
    const thankYouUrl = (lang === 'en') ? '/thank-you/' : `/${lang}/thank-you/`;
    window.location.href = thankYouUrl;
  }

  // Form submission - use fresh element reference
  function setupFormSubmission() {
    const { form } = getFormElements();
    if (!form) return;

    // Remove existing listener if any
    const newForm = form.cloneNode(true);
    form.parentNode.replaceChild(newForm, form);

    newForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      hideError();
      hideTurnstileError();

      // Check Turnstile (skip in dev mode)
      if (!isDev && !turnstileToken) {
        showTurnstileError(turnstileErrorMsg);
        return;
      }

      // Gather form data
      const formData = new FormData(newForm);
      if (!isDev && turnstileToken) {
        formData.append('cf-turnstile-response', turnstileToken);
      }

      setLoading(true);

      try {
        // In dev mode, use PHP server on port 4325
        const apiUrl = isDev ? 'http://localhost:4325/send-mail.php' : '/send-mail.php';

        const response = await fetch(apiUrl, {
          method: 'POST',
          body: formData
        });

        // Check if response is OK
        if (!response.ok) {
          const contentType = response.headers.get('content-type');

          // Check if PHP is not configured (returns HTML instead of JSON)
          if (contentType && contentType.includes('text/html')) {
            throw new Error('PHP_NOT_CONFIGURED');
          }

          throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }

        const result = await response.json();

        if (result.success) {
          // Redirect to thank-you page
          const currentLang = formData.get('language') || 'en';
          redirectToThankYou(currentLang);
        } else {
          const errorMsg = result.errors
            ? result.errors.join('. ')
            : (result.message || 'An error occurred. Please try again.');
          showError(errorMsg);

          // Show debug info if available
          if (result.debug) {
            console.error('Server debug info:', result.debug);
          }

          setLoading(false);
        }
      } catch (error) {
        console.error('Form submission error:', error);

        // For development without PHP, offer mailto fallback
        if (isDev && (error.message.includes('Failed to fetch') || error.message.includes('NetworkError') || error.message === 'PHP_NOT_CONFIGURED')) {
          const name = formData.get('name');
          const email = formData.get('email');
          const details = formData.get('details');
          const product = formData.get('product_name') || 'N/A';

          const subject = encodeURIComponent(`Inquiry from KSSMI Website - ${name}`);
          const body = encodeURIComponent(
            `Name: ${name}\nEmail: ${email}\nProduct: ${product}\n\nProject Details:\n${details}`
          );

          // Show message with option to use email client
          showError('PHP server not running. Click below to send via your email client:');

          // Add a button to use mailto
          const mailtoLink = document.createElement('a');
          mailtoLink.href = `mailto:sales@kssmi.com?subject=${subject}&body=${body}`;
          mailtoLink.className = 'inline-block mt-3 px-6 py-3 bg-[#8B7355] text-white rounded-lg hover:bg-[#5D4E37]';
          mailtoLink.textContent = 'Open Email Client';
          mailtoLink.id = 'mailto-fallback';

          // Remove existing button if any
          const existingBtn = document.getElementById('mailto-fallback');
          if (existingBtn) existingBtn.remove();

          const { errorContainer } = getFormElements();
          if (errorContainer) errorContainer.appendChild(mailtoLink);

          setLoading(false);
          return;
        }

        // Provide helpful error messages
        if (error.message === 'PHP_NOT_CONFIGURED') {
          showError('PHP is not configured on this server. Please contact the administrator or use the direct email link below.');
        } else if (error.message.includes('Failed to fetch') || error.message.includes('NetworkError')) {
          showError('Cannot connect to server. If testing locally, PHP server is required. Please use the direct email link below.');
        } else if (error.message.includes('Unexpected token')) {
          showError('Server returned an invalid response. PHP may not be installed. Please use the direct email link below.');
        } else {
          showError(`Error: ${error.message}. Please try again or use the direct email link below.`);
        }

        setLoading(false);
      }
    });
  }

  // Setup form on initial load
  setupFormSubmission();

  // Re-setup form after View Transitions
  document.addEventListener('astro:page-load', function() {
    setupFormSubmission();
  });
</script>

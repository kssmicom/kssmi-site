---
/**
 * SECTION: Acetate Manufacturing (Series 01)
 * THEME: Studio White (Theme A)
 * LAYOUT: Architectural Canvas (max-w-[1800px])
 *
 * Features:
 * - 2-column grid (5+7 span) with narrative and visual stack
 * - 3-layer image effect with hover transforms
 * - Floating glass badge with color palette
 * - 3 spec sheet cards with hover light strip
 * - Kinetic pill button with conic gradient
 */


import { translations } from '../../translations';

// ============================================================================
// PROPS
// ============================================================================

interface SpecCard {
  icon: 'leaf' | 'sparkles' | 'hand';
  title: string;
  description: string;
}

interface Props {
  lang?: string;
  eyebrow?: string;
  headline?: string;
  headlineAccent?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  mainImage?: string;
  paletteColors?: Array<{ color: string; name: string }>;
  specCards?: SpecCard[];
}

// ============================================================================
// FRONTMATTER LOGIC
// ============================================================================

const {
  lang = 'en',
  eyebrow = 'Material Origins',
  headline = 'Sculpted from blocks of cured',
  headlineAccent = 'bio-acetate',
  description = 'We reject injection molding. Every frame begins as a solid slab of plant-based cellulose, cured for 12 weeks before entering our 5-axis CNC machining centers for subtractive sculpting.',
  ctaText = 'Explore Series 01',
  ctaLink = '/products?cat=luxury',
  mainImage,
  paletteColors = [
    { color: 'bg-amber-800', name: 'Tortoise' },
    { color: 'bg-orange-700', name: 'Amber' },
    { color: 'bg-stone-800', name: 'Onyx' }
  ],
  specCards = [
    {
      icon: 'leaf',
      title: 'Bio-Acetate Base',
      description: 'Composed of 70% renewable wood pulp and cotton fibers. Our acetate is hypoallergenic, warm to the touch, and biodegradable.'
    },
    {
      icon: 'sparkles',
      title: '140-Hour Polish',
      description: 'Tumbled in oak barrels with bamboo chips and finishing wax for six days to achieve a glass-like surface that resists scratches.'
    },
    {
      icon: 'hand',
      title: 'Hand Assembly',
      description: 'Our master artisans inspect every hinge, rivet, and temple core, ensuring perfect alignment before the final seal of approval.'
    }
  ]
} = Astro.props;

const t = translations[lang] || translations.en;
const isRTL = lang === 'ar';

// Icon SVGs
const icons = {
  leaf: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />`,
  sparkles: `<path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />`,
  hand: `<path stroke-linecap="round" stroke-linejoin="round" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11" />`
};
---

<!-- SECTION: Acetate Manufacturing (Series 01) -->
<section class="w-full py-16 lg:py-24 bg-white relative z-10 overflow-hidden">

  <!-- LAYER 2: Constraint (Wider Canvas) -->
  <div class="relative w-full max-w-[1800px] mx-auto px-6 lg:px-12 z-10">

    <!-- LAYER 3: Content Block (Grid Layout) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center mb-20">

      <!-- COLUMN 1: NARRATIVE (5 SPAN) -->
      <div class={`lg:col-span-5 flex flex-col items-start ${isRTL ? 'lg:col-start-8 lg:order-2' : ''}`}>

        <!-- A. EYEBROW -->
        <div class={`flex items-center gap-3 mb-8 ${isRTL ? 'flex-row-reverse' : ''}`}>
          <span class="h-px w-12 bg-amber-600"></span>
          <span class="text-[10px] font-bold tracking-[0.25em] text-amber-700 uppercase">{eyebrow}</span>
        </div>

        <!-- B. HEADLINE (H2) -->
        <h2 class="text-3xl lg:text-5xl font-sans font-normal tracking-tight text-stone-950 leading-[1.1] mb-8">
          {headline} <span class="font-serif italic font-medium text-transparent bg-clip-text bg-gradient-to-br from-amber-700 via-orange-600 to-amber-800">{headlineAccent}</span>.
        </h2>

        <p class="text-lg text-stone-800 font-normal leading-relaxed mb-10 max-w-md">
          {description}
        </p>

        <!-- COMPONENT: Kinetic Pill Button -->
        <a href={ctaLink} class="group relative inline-flex items-center gap-5 px-9 py-5 bg-stone-950 text-white rounded-full overflow-hidden shadow-2xl shadow-stone-900/20 hover:shadow-amber-900/30 transition-all duration-500">
          <!-- Conic Gradient Background -->
          <span class="absolute inset-0 bg-[conic-gradient(from_90deg_at_50%_50%,#D97706_0%,#EA580C_50%,#D97706_100%)] transform origin-left scale-x-0 transition-transform duration-700 ease-[cubic-bezier(0.23,1,0.32,1)] group-hover:scale-x-100 opacity-90"></span>
          <!-- Text -->
          <span class="relative z-10 font-bold tracking-[0.15em] text-xs uppercase group-hover:text-white transition-colors">{ctaText}</span>
          <!-- Arrow Icon -->
          <svg class={`relative z-10 w-3.5 h-3.5 transform transition-transform duration-500 ${isRTL ? 'group-hover:-translate-x-1.5 rotate-180' : 'group-hover:translate-x-1.5'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- COLUMN 2: VISUAL STACK (7 SPAN) -->
      <div class={`lg:col-span-7 relative ${isRTL ? 'lg:order-1' : ''}`}>
        <!-- C. IMAGES (Physical Stack Effect) -->
        <div class="relative w-full aspect-[4/3] lg:aspect-[16/10] group perspective-1000">

          <!-- Back Plate (Raw Material) - LTR -->
          {!isRTL && (
            <div class="absolute inset-0 bg-stone-200 rounded-3xl transform rotate-3 scale-[0.98] translate-x-4 translate-y-4 transition-transform duration-700 ease-[cubic-bezier(0.23,1,0.32,1)] group-hover:rotate-6 group-hover:translate-x-6"></div>
          )}

          <!-- Back Plate (Raw Material) - RTL -->
          {isRTL && (
            <div class="absolute inset-0 bg-stone-200 rounded-3xl transform -rotate-3 scale-[0.98] -translate-x-4 translate-y-4 transition-transform duration-700 ease-[cubic-bezier(0.23,1,0.32,1)] group-hover:-rotate-6 group-hover:-translate-x-6"></div>
          )}

          <!-- Middle Plate (Process) - LTR -->
          {!isRTL && (
            <div class="absolute inset-0 bg-stone-800 rounded-3xl transform -rotate-2 scale-[0.98] -translate-x-2 -translate-y-2 transition-transform duration-700 ease-[cubic-bezier(0.23,1,0.32,1)] group-hover:-rotate-3 group-hover:-translate-x-4"></div>
          )}

          <!-- Middle Plate (Process) - RTL -->
          {isRTL && (
            <div class="absolute inset-0 bg-stone-800 rounded-3xl transform rotate-2 scale-[0.98] translate-x-2 -translate-y-2 transition-transform duration-700 ease-[cubic-bezier(0.23,1,0.32,1)] group-hover:rotate-3 group-hover:translate-x-4"></div>
          )}

          <!-- Main Image -->
          <div class="absolute inset-0 rounded-3xl overflow-hidden shadow-2xl z-10">
            {mainImage ? (
              <img src={mainImage}
                alt="Yeetian Acetate Manufacturing"
                class="w-full h-full object-cover transition-transform duration-1000 hover:scale-105"
              />
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-stone-100 to-stone-200 flex items-center justify-center">
                <span class="text-stone-400 text-sm">Acetate Manufacturing Image</span>
              </div>
            )}

            <!-- Floating Glass Badge -->
            <div class={`absolute bottom-6 ${isRTL ? 'right-6 lg:right-10' : 'left-6 lg:left-10'} lg:bottom-10 bg-white/80 backdrop-blur-md border border-white/50 px-6 py-4 rounded-xl shadow-lg flex items-center gap-4`}>
              <div class={`flex ${isRTL ? 'flex-row-reverse' : ''} -space-x-3`}>
                {paletteColors.map((c) => (
                  <div class={`w-8 h-8 rounded-full ${c.color} border-2 border-white`}></div>
                ))}
              </div>
              <div class="flex flex-col">
                <span class="text-[10px] font-bold tracking-wider text-stone-500 uppercase">Palette</span>
                <span class="text-xs font-bold text-stone-900">{paletteColors.map(c => c.name).join(' / ')}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- BOTTOM ROW: Spec Sheet Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {specCards.map((card) => (
        <div class="group relative p-8 bg-white rounded-2xl border border-stone-100 overflow-hidden hover:border-stone-200 hover:shadow-xl hover:shadow-stone-200/40 transition-all duration-500 flex flex-col">
          <!-- Hover Light Strip -->
          <div class="absolute top-0 start-0 w-full h-1 bg-[conic-gradient(from_90deg_at_50%_50%,#D97706_0%,#EA580C_50%,#D97706_100%)] transform scale-x-0 group-hover:scale-x-100 transition-transform duration-700 ease-[cubic-bezier(0.23,1,0.32,1)] origin-left"></div>

          <!-- Header: Icon + H3 -->
          <div class={`flex items-center gap-5 mb-8 ${isRTL ? 'flex-row-reverse' : ''}`}>
            <div class="w-12 h-12 rounded-lg bg-stone-50 text-stone-400 group-hover:bg-stone-900 group-hover:text-amber-500 flex items-center justify-center transition-colors duration-500 shrink-0">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={icons[card.icon]} />
            </div>
            <h3 class="text-lg font-bold text-stone-900 tracking-tight">{card.title}</h3>
          </div>

          <!-- Divider -->
          <div class="w-full h-px bg-stone-100 mb-6 group-hover:bg-stone-200 transition-colors duration-500"></div>

          <!-- Description -->
          <p class="text-sm text-stone-600 leading-relaxed">{card.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>


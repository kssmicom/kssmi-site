const currentLang = (lang as any) || 'en';
const qt = {
  fasterToMarket: (quoteText.fasterToMarket as any)[currentLang] || quoteText.fasterToMarket.en,
  fasterToMarketDesc: (quoteText.fasterToMarketDesc as any)[currentLang] || quoteText.fasterToMarketDesc.en,
  lowerRisk: (quoteText.lowerRisk as any)[currentLang] || quoteText.lowerRisk.en,
  lowerRiskDesc: (quoteText.lowerRiskDesc as any)[currentLang] || quoteText.lowerRiskDesc.en,
  betterMargins: (quoteText.betterMargins as any)[currentLang] || quoteText.betterMargins.en,

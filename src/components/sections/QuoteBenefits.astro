};
---

<section class="pt-12 pb-4 lg:pt-16 lg:pb-8 bg-gradient-to-b from-stone-50 to-white">
  <div class="w-[94%] lg:w-[90%] 2xl:w-[85%] max-w-[1200px] mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      <!-- Card 1 -->
      <div class="bg-[#FCFAF8] rounded-xl p-8 shadow-sm border border-[#8B7355]/10 text-center transition-all duration-500 ease-out hover:-translate-y-2 hover:shadow-xl hover:bg-white hover:border-[#8B7355]/30 cursor-default group">
        <div class="w-16 h-16 bg-white shadow-sm border border-[#8B7355]/10 rounded-2xl flex items-center justify-center mx-auto mb-6 transition-all duration-500 ease-out group-hover:scale-110 group-hover:shadow-md group-hover:bg-[#8B7355]/5 group-hover:border-[#8B7355]/20">
          <svg class="w-8 h-8 text-[#8B7355] transition-transform duration-500 ease-out" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-[#5D4E37] mb-3 transition-colors duration-500 group-hover:text-[#8B7355]">{qt.fasterToMarket}</h3>
        <p class="text-sm text-stone-600 leading-relaxed">{qt.fasterToMarketDesc}</p>
      </div>
      
      <!-- Card 2 -->
      <div class="bg-[#FCFAF8] rounded-xl p-8 shadow-sm border border-[#8B7355]/10 text-center transition-all duration-500 ease-out hover:-translate-y-2 hover:shadow-xl hover:bg-white hover:border-[#8B7355]/30 cursor-default group">
        <div class="w-16 h-16 bg-white shadow-sm border border-[#8B7355]/10 rounded-2xl flex items-center justify-center mx-auto mb-6 transition-all duration-500 ease-out group-hover:scale-110 group-hover:shadow-md group-hover:bg-[#8B7355]/5 group-hover:border-[#8B7355]/20">
          <svg class="w-8 h-8 text-[#8B7355] transition-transform duration-500 ease-out" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-[#5D4E37] mb-3 transition-colors duration-500 group-hover:text-[#8B7355]">{qt.lowerRisk}</h3>
        <p class="text-sm text-stone-600 leading-relaxed">{qt.lowerRiskDesc}</p>
      </div>
      
      <!-- Card 3 -->
      <div class="bg-[#FCFAF8] rounded-xl p-8 shadow-sm border border-[#8B7355]/10 text-center transition-all duration-500 ease-out hover:-translate-y-2 hover:shadow-xl hover:bg-white hover:border-[#8B7355]/30 cursor-default group">
        <div class="w-16 h-16 bg-white shadow-sm border border-[#8B7355]/10 rounded-2xl flex items-center justify-center mx-auto mb-6 transition-all duration-500 ease-out group-hover:scale-110 group-hover:shadow-md group-hover:bg-[#8B7355]/5 group-hover:border-[#8B7355]/20">
          <svg class="w-8 h-8 text-[#8B7355] transition-transform duration-500 ease-out" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-[#5D4E37] mb-3 transition-colors duration-500 group-hover:text-[#8B7355]">{qt.betterMargins}</h3>
        <p class="text-sm text-stone-600 leading-relaxed">{qt.betterMarginsDesc}</p>
      </div>
    </div>
  </div>
</section>

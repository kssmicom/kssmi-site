---

import { translations } from '../translations';

interface Props {
  product: any;
  lang: string;
}

const { product, lang } = Astro.props;

// Access data correctly - slug and other fields are inside data
const { data } = product;
const {
  title,
  slug,      // slug is inside data, not at product level
  itemNo,
  cover,
  categories
} = data;

const t = translations[lang] || translations.en;
const currentPath = lang === 'en' ? '' : `${lang}/`;

// Use slug from data, fallback to extracting from ID
const productSlug = slug || product.id.split('.')[0];
---

<a href={`/${currentPath}product/${productSlug}`} class="group block">
  <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-all duration-300">
    <!-- Product Image with Hover Overlay -->
    <div class="relative aspect-[4/3] overflow-hidden bg-gray-100">
      {cover ? (
        <img
          src={cover}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-gray-100 to-gray-200">
          <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      )}

      <!-- Hover Overlay with "View Details" -->
      <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
        <span class="bg-white text-[#8B7355] px-4 py-2 rounded-lg font-semibold text-sm flex items-center gap-2 transform translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
          {t.product?.viewDetails || 'View Details'}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </span>
      </div>
    </div>

    <!-- Product Info - Center Aligned -->
    <div class="p-4 xl:p-5 text-center">
      <!-- Item No (main identifier) - Bold -->
      {itemNo && (
        <p class="text-xs xl:text-sm text-[#8B7355] font-bold mb-1 xl:mb-2">
          {itemNo}
        </p>
      )}

      <!-- Product Title -->
      <h3 class="text-sm xl:text-base font-semibold text-gray-900 line-clamp-2 group-hover:text-[#8B7355] transition-colors">
        {title}
      </h3>
    </div>
  </div>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
